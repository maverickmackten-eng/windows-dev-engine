<Window x:Class="CyberNeon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBER OPS CENTER"
        Height="700" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- ── CyberNeon Palette ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgDeep"      Color="#0D0015"/>  <!-- Near-black purple -->
    <SolidColorBrush x:Key="BgPanel"     Color="#160026"/>
    <SolidColorBrush x:Key="BgCard"      Color="#1E003A"/>
    <SolidColorBrush x:Key="Magenta"     Color="#FF00FF"/>  <!-- Primary accent -->
    <SolidColorBrush x:Key="Cyan"        Color="#00FFCC"/>  <!-- Secondary accent -->
    <SolidColorBrush x:Key="Grid"        Color="#2A0044"/>  <!-- Faint purple grid lines -->
    <SolidColorBrush x:Key="TextPri"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSub"     Color="#AA88CC"/>

    <!-- Neon glow effects -->
    <DropShadowEffect x:Key="GlowMagenta" Color="#FF00FF" BlurRadius="20"
                      ShadowDepth="0" Opacity="0.8"/>
    <DropShadowEffect x:Key="GlowCyan"    Color="#00FFCC" BlurRadius="16"
                      ShadowDepth="0" Opacity="0.7"/>
    <DropShadowEffect x:Key="GlowSubtle"  Color="#FF00FF" BlurRadius="8"
                      ShadowDepth="0" Opacity="0.3"/>

    <!-- Button style with neon glow on hover -->
    <Style x:Key="NeonButton" TargetType="Button">
      <Setter Property="Background"        Value="Transparent"/>
      <Setter Property="Foreground"        Value="#FF00FF"/>
      <Setter Property="BorderBrush"       Value="#FF00FF"/>
      <Setter Property="BorderThickness"   Value="1"/>
      <Setter Property="Padding"           Value="16,8"/>
      <Setter Property="FontFamily"        Value="Impact"/>
      <Setter Property="FontSize"          Value="13"/>
      <Setter Property="Cursor"            Value="Hand"/>
      <Setter Property="Effect"            Value="{StaticResource GlowSubtle}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22FF00FF"/>
                <Setter Property="Effect"     Value="{StaticResource GlowMagenta}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#44FF00FF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Cyan variant -->
    <Style x:Key="NeonButtonCyan" TargetType="Button" BasedOn="{StaticResource NeonButton}">
      <Setter Property="Foreground"   Value="#00FFCC"/>
      <Setter Property="BorderBrush" Value="#00FFCC"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2200FFCC"/>
          <Setter Property="Effect"     Value="{StaticResource GlowCyan}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <!-- Root border with drop shadow -->
  <Border Background="{StaticResource BgDeep}"
          BorderBrush="#440066" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#FF00FF" Opacity="0.15"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>   <!-- Title bar -->
        <RowDefinition Height="*"/>    <!-- Content -->
        <RowDefinition Height="24"/>   <!-- Status -->
      </Grid.RowDefinitions>

      <!-- ── Background grid lines ────────────────────────────────── -->
      <Canvas Grid.RowSpan="3" IsHitTestVisible="False">
        <!-- Vertical grid lines -->
        <Rectangle Canvas.Left="183"  Width="1" Height="700" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Left="366"  Width="1" Height="700" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Left="549"  Width="1" Height="700" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Left="732"  Width="1" Height="700" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Left="915"  Width="1" Height="700" Fill="#0EFF00FF"/>
        <!-- Horizontal grid lines -->
        <Rectangle Canvas.Top="116"  Height="1" Width="1100" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Top="232"  Height="1" Width="1100" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Top="348"  Height="1" Width="1100" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Top="464"  Height="1" Width="1100" Fill="#0EFF00FF"/>
        <Rectangle Canvas.Top="580"  Height="1" Width="1100" Fill="#0EFF00FF"/>
      </Canvas>

      <!-- Animated scanline ───────────────────────────────────────── -->
      <Rectangle x:Name="scanLine"
                 Grid.RowSpan="3"
                 Height="2" Width="1100"
                 VerticalAlignment="Top"
                 IsHitTestVisible="False"
                 Opacity="0.08">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="Transparent" Offset="0"/>
            <GradientStop Color="#FF00FF"     Offset="0.5"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
        <Rectangle.RenderTransform>
          <TranslateTransform x:Name="scanTranslate" Y="0"/>
        </Rectangle.RenderTransform>
        <Rectangle.Triggers>
          <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
              <Storyboard RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="scanTranslate"
                                 Storyboard.TargetProperty="Y"
                                 From="0" To="700" Duration="0:0:6"
                                 EasingFunction="{x:Null}"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </Rectangle.Triggers>
      </Rectangle>

      <!-- ── Title Bar ──────────────────────────────────────────── -->
      <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="CYBER OPS CENTER"
                   FontFamily="Impact" FontSize="18"
                   Foreground="#FF00FF"
                   LetterSpacing="5"
                   VerticalAlignment="Center" Margin="20,0"
                   Effect="{StaticResource GlowMagenta}"/>

        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="─" Foreground="#AA88CC" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48"
                  FontSize="14" Click="BtnMinimize_Click"/>
          <Button Content="□" Foreground="#AA88CC" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48"
                  FontSize="14" Click="BtnMaximize_Click"/>
          <Button Content="✕" Foreground="#FF00FF" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48"
                  FontSize="14" Click="BtnClose_Click">
            <Button.Triggers>
              <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.15"/>
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Button.Triggers>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ── Content ────────────────────────────────────────────── -->
      <Grid Grid.Row="1" Margin="24,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">
          <TextBlock Text="SYSTEM STATUS"
                     Foreground="#AA88CC" FontFamily="Cascadia Code"
                     FontSize="10" LetterSpacing="2" Margin="0,0,0,12"/>

          <!-- Status indicators -->
          <Border Background="{StaticResource BgPanel}"
                  BorderBrush="#440066" BorderThickness="1"
                  CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="8" Height="8" Fill="#00FFCC"
                       VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Effect>
                  <DropShadowEffect Color="#00FFCC" BlurRadius="6" ShadowDepth="0"/>
                </Ellipse.Effect>
              </Ellipse>
              <TextBlock Text="NEURAL LINK ACTIVE" Foreground="#00FFCC"
                         FontFamily="Cascadia Code" FontSize="11"/>
            </StackPanel>
          </Border>

          <Border Background="{StaticResource BgPanel}"
                  BorderBrush="#440066" BorderThickness="1"
                  CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="8" Height="8" Fill="#FF00FF"
                       VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Effect>
                  <DropShadowEffect Color="#FF00FF" BlurRadius="6" ShadowDepth="0"/>
                </Ellipse.Effect>
              </Ellipse>
              <TextBlock Text="MATRIX ONLINE" Foreground="#FF00FF"
                         FontFamily="Cascadia Code" FontSize="11"
                         Effect="{StaticResource GlowSubtle}"/>
            </StackPanel>
          </Border>

          <!-- Buttons -->
          <Button Content="INITIATE SCAN" Style="{StaticResource NeonButton}"
                  Margin="0,16,0,8" HorizontalAlignment="Stretch"/>
          <Button Content="DEPLOY SEQUENCE" Style="{StaticResource NeonButtonCyan}"
                  HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- Main panel -->
        <Border Grid.Column="1"
                Background="{StaticResource BgPanel}"
                BorderBrush="#440066" BorderThickness="1"
                CornerRadius="8">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="█ CYBER OPS CENTER █"
                       FontFamily="Impact" FontSize="36"
                       Foreground="#FF00FF" LetterSpacing="4"
                       HorizontalAlignment="Center"
                       Effect="{StaticResource GlowMagenta}"
                       Margin="0,0,0,12"/>
            <TextBlock Text="synthwave • neon • tactical"
                       FontFamily="Cascadia Code" FontSize="13"
                       Foreground="#00FFCC"
                       HorizontalAlignment="Center"
                       Effect="{StaticResource GlowCyan}"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Status Bar ──────────────────────────────────────────── -->
      <Grid Grid.Row="2" Background="#0A0012">
        <TextBlock Text="CYBER OPS CENTER — v1.0.0 — ONLINE"
                   Foreground="#440066" FontSize="10"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center" Margin="16,0"/>
        <TextBlock Text="&#x25CF; SECURE"
                   Foreground="#00FFCC" FontSize="10"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,16,0"/>
      </Grid>

    </Grid>
  </Border>
</Window>
