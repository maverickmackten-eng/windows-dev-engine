<Window x:Class="CyberNeon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBER OPS CENTER"
        Width="1280" Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{DynamicResource BackgroundDeepBrush}"
        WindowStartupLocation="CenterScreen">
    <!--
        CyberNeon Theme Sample
        ======================
        Palette: #0D0015 bg, #FF00FF magenta accent, #00FFCC cyan secondary
        Features: neon glow on interactive elements, animated scanline, grid overlay
    -->
    <Window.Resources>
        <!-- Scanline animation -->
        <Storyboard x:Key="ScanlineSweep" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Scanline"
                             Storyboard.TargetProperty="(Canvas.Top)"
                             From="-2" To="800" Duration="0:0:4"/>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ScanlineSweep}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- ── Subtle grid overlay (faint purple lines) ───────────── -->
        <Border IsHitTestVisible="False" Opacity="0.08">
            <Border.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="Transparent">
                            <GeometryDrawing.Pen>
                                <Pen Brush="#AA00FF" Thickness="0.5"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="40,0" EndPoint="40,40"/>
                                    <LineGeometry StartPoint="0,40" EndPoint="40,40"/>
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.Background>
        </Border>

        <!-- Scanline sweep -->
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="Scanline" Canvas.Top="0" Width="1280" Height="2"
                       Opacity="0.08" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#00FFCC" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Canvas>

        <!-- Main layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#150022">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CYBER OPS CENTER"
                           FontFamily="Impact" FontSize="18"
                           Foreground="#FF00FF" VerticalAlignment="Center" Margin="16,0"
                           IsHitTestVisible="False">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FF00FF" BlurRadius="16" ShadowDepth="0" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <!-- Window buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="—" Width="46" Height="48"
                            Background="Transparent" Foreground="#CC88FF"
                            BorderThickness="0" FontSize="16"
                            Click="MinimizeClick"/>
                    <Button Content="&#x2716;" Width="46" Height="48"
                            Background="Transparent" Foreground="#FF00FF"
                            BorderThickness="0" FontSize="14"
                            Click="CloseClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#44FF0055"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content area -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#150022"
                        BorderBrush="#3D0066" BorderThickness="1" CornerRadius="8">
                    <StackPanel Margin="12" Spacing="6">
                        <TextBlock Text="NAVIGATION" FontSize="9" FontWeight="Bold"
                                   Foreground="#662299" Margin="4,0,0,8"/>
                        <!-- Nav buttons with neon glow -->
                        <Button Content="📊  DASHBOARD" Style="{DynamicResource PrimaryButtonStyle}" HorizontalAlignment="Stretch">
                            <Button.Effect><DropShadowEffect Color="#FF00FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/></Button.Effect>
                        </Button>
                        <Button Content="⚡  OPS CENTER" Background="Transparent" Foreground="#CC88FF"
                                BorderBrush="#3D0066" BorderThickness="1" Padding="12,8"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="🔒  SECURE ZONE" Background="Transparent" Foreground="#CC88FF"
                                BorderBrush="#3D0066" BorderThickness="1" Padding="12,8"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="⚙️  CONFIG" Background="Transparent" Foreground="#CC88FF"
                                BorderBrush="#3D0066" BorderThickness="1" Padding="12,8"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Main panel -->
                <Border Grid.Column="2" Background="#150022"
                        BorderBrush="#3D0066" BorderThickness="1" CornerRadius="8"
                        Padding="24">
                    <StackPanel>
                        <!-- Stats row -->
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                            <Border Width="160" Height="80" Background="#0D0015"
                                    BorderBrush="#FF00FF" BorderThickness="1" CornerRadius="6" Padding="14">
                                <Border.Effect><DropShadowEffect Color="#FF00FF" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="THREATS" FontSize="9" Foreground="#CC88FF" FontWeight="Bold"/>
                                    <TextBlock Text="247" FontFamily="Impact" FontSize="32" Foreground="#FF00FF"/>
                                </StackPanel>
                            </Border>
                            <Border Width="160" Height="80" Background="#0D0015"
                                    BorderBrush="#00FFCC" BorderThickness="1" CornerRadius="6" Padding="14">
                                <Border.Effect><DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="SECURED" FontSize="9" Foreground="#66DDCC" FontWeight="Bold"/>
                                    <TextBlock Text="1,893" FontFamily="Impact" FontSize="32" Foreground="#00FFCC"/>
                                </StackPanel>
                            </Border>
                            <Border Width="160" Height="80" Background="#0D0015"
                                    BorderBrush="#FFD700" BorderThickness="1" CornerRadius="6" Padding="14">
                                <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="ACTIVE OPS" FontSize="9" Foreground="#CCAA00" FontWeight="Bold"/>
                                    <TextBlock Text="12" FontFamily="Impact" FontSize="32" Foreground="#FFD700"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Activity log -->
                        <TextBlock Text="ACTIVITY FEED" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF00FF" Margin="0,0,0,12"/>
                        <Border Background="#0D0015" BorderBrush="#3D0066" BorderThickness="1"
                                CornerRadius="4" Padding="12" Height="200">
                            <StackPanel Spacing="6">
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#662299">14:23:01</Run><Run Foreground="#CC88FF">  [INF] Connection established — Node 7</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#662299">14:22:58</Run><Run Foreground="#FF2D55">  [WRN] Anomaly detected on subnet 192.168.7.x</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#662299">14:22:55</Run><Run Foreground="#00FFCC">  [OK ] Firewall rules updated — 247 entries</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#662299">14:22:50</Run><Run Foreground="#CC88FF">  [INF] Scan complete — 0 critical findings</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Grid Grid.Row="2" Background="#150022">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="● SYSTEM ONLINE — ALL NODES ACTIVE"
                           FontFamily="Cascadia Code, Consolas" FontSize="10"
                           Foreground="#00FFCC" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock.Effect><DropShadowEffect Color="#00FFCC" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/></TextBlock.Effect>
                </TextBlock>
                <TextBlock Grid.Column="1" Text="CYBER NEON v1.0"
                           FontFamily="Cascadia Code, Consolas" FontSize="10"
                           Foreground="#662299" VerticalAlignment="Center" Margin="12,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
