<Window x:Class="CyberNeon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CYBEROPS CENTER — Neon Theme"
        Width="1100" Height="720"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"      Color="#04040C"/>
        <SolidColorBrush x:Key="Bg1"      Color="#080816"/>
        <SolidColorBrush x:Key="Bg2"      Color="#0D0D22"/>
        <SolidColorBrush x:Key="Cyan"     Color="#00FFFF"/>
        <SolidColorBrush x:Key="Pink"     Color="#FF00AA"/>
        <SolidColorBrush x:Key="Green"    Color="#00FF41"/>
        <SolidColorBrush x:Key="Yellow"   Color="#FFE600"/>
        <SolidColorBrush x:Key="BorderC"  Color="#00FFFF33"/>
        <SolidColorBrush x:Key="TextDim"  Color="#556677"/>
    </Window.Resources>

    <Border Background="{StaticResource Bg0}" CornerRadius="10"
            BorderBrush="{StaticResource Cyan}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#00FFFF" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <!-- Scanline overlay (thin repeating lines for CRT effect) -->
            <Rectangle Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.04">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#FFFFFF">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,1,1"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Grid pattern background -->
            <Rectangle Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.06">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="Transparent">
                                    <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,40,40"/></GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Pen><Pen Brush="#00FFFF" Thickness="0.5"/></GeometryDrawing.Pen>
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <LineGeometry StartPoint="0,0" EndPoint="40,0"/>
                                            <LineGeometry StartPoint="0,0" EndPoint="0,40"/>
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Title bar -->
            <Border Background="{StaticResource Bg1}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡ " Foreground="{StaticResource Cyan}" FontSize="14"/>
                        <TextBlock Text="CYBEROPS CENTER" Foreground="{StaticResource Cyan}"
                                   FontFamily="Impact" FontSize="16" LetterSpacing="4">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="  //  NEON INTERFACE v2.0" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="─" Width="36" Height="36" Click="MinBtn_Click"
                                Background="Transparent" Foreground="{StaticResource TextDim}"
                                BorderThickness="0" Cursor="Hand"/>
                        <Button Content="✕" Width="36" Height="36" Click="CloseBtn_Click"
                                Background="Transparent" Foreground="{StaticResource Pink}"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Left nav -->
                <Border Background="{StaticResource Bg1}"
                        BorderBrush="{StaticResource BorderC}" BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,16">
                        <TextBlock Text="// NAVIGATION" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="9" Margin="16,0,0,12"/>
                        <!-- Active item -->
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4"
                                Background="#1100FFFF" BorderBrush="{StaticResource Cyan}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <TextBlock Text="[ DASHBOARD ]" Foreground="{StaticResource Cyan}"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4" Cursor="Hand">
                            <TextBlock Text="[ NETWORK ]" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4" Cursor="Hand">
                            <TextBlock Text="[ EXPLOITS ]" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4" Cursor="Hand">
                            <TextBlock Text="[ TARGETS ]" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4" Cursor="Hand">
                            <TextBlock Text="[ LOGS ]" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>
                        <Border Margin="8,2" Padding="12,10" CornerRadius="4" Cursor="Hand">
                            <TextBlock Text="[ CONFIG ]" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>

                        <Rectangle Height="1" Fill="{StaticResource BorderC}" Margin="8,16"/>

                        <!-- System status -->
                        <TextBlock Text="// SYS STATUS" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="9" Margin="16,0,0,8"/>
                        <StackPanel Margin="16,3">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Green}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="FIREWALL  ACTIVE" Foreground="{StaticResource Green}"
                                           FontFamily="Consolas" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="16,3">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Cyan}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="VPN       ONLINE" Foreground="{StaticResource Cyan}"
                                           FontFamily="Consolas" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="16,3">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Pink}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="INTRUSION DETECT" Foreground="{StaticResource Pink}"
                                           FontFamily="Consolas" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Center content -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">

                        <!-- Giant display title -->
                        <TextBlock Text="CYBEROPS" HorizontalAlignment="Center"
                                   FontFamily="Impact" FontSize="64" Foreground="{StaticResource Cyan}"
                                   LetterSpacing="8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="COMMAND  CENTER" HorizontalAlignment="Center"
                                   FontFamily="Consolas" FontSize="14" Foreground="{StaticResource Pink}"
                                   LetterSpacing="6" Margin="0,-8,0,24">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF00AA" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- Animated scan bar -->
                        <Border Height="2" Background="{StaticResource Cyan}" Margin="0,0,0,24"
                                HorizontalAlignment="Stretch">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="scanBar"/>
                            </Border.RenderTransform>
                        </Border>

                        <!-- Stat cards -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border Margin="8" Padding="16,12" CornerRadius="6" MinWidth="150"
                                    Background="{StaticResource Bg2}"
                                    BorderBrush="{StaticResource Cyan}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FFFF" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="ACTIVE NODES" Foreground="{StaticResource TextDim}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="2,847" Foreground="{StaticResource Cyan}"
                                               FontFamily="Consolas" FontSize="32" FontWeight="Bold"/>
                                    <TextBlock Text="+143 online" Foreground="{StaticResource Green}"
                                               FontFamily="Consolas" FontSize="9"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8" Padding="16,12" CornerRadius="6" MinWidth="150"
                                    Background="{StaticResource Bg2}"
                                    BorderBrush="{StaticResource Pink}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF00AA" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="THREATS BLOCKED" Foreground="{StaticResource TextDim}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="14,203" Foreground="{StaticResource Pink}"
                                               FontFamily="Consolas" FontSize="32" FontWeight="Bold"/>
                                    <TextBlock Text="last 24h" Foreground="{StaticResource TextDim}"
                                               FontFamily="Consolas" FontSize="9"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8" Padding="16,12" CornerRadius="6" MinWidth="150"
                                    Background="{StaticResource Bg2}"
                                    BorderBrush="{StaticResource Green}" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FF41" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="UPTIME" Foreground="{StaticResource TextDim}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="99.9%" Foreground="{StaticResource Green}"
                                               FontFamily="Consolas" FontSize="32" FontWeight="Bold"/>
                                    <TextBlock Text="127 days clean" Foreground="{StaticResource Green}"
                                               FontFamily="Consolas" FontSize="9"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Activity log -->
                        <Border Background="{StaticResource Bg2}" CornerRadius="6"
                                BorderBrush="{StaticResource BorderC}" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="// LIVE ACTIVITY FEED" Foreground="{StaticResource Cyan}"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Text="[14:23:01] NODE 192.168.0.44 connected — AUTH OK"
                                           Foreground="{StaticResource Green}" FontFamily="Consolas" FontSize="11"/>
                                <TextBlock Text="[14:22:58] INTRUSION ATTEMPT blocked — SRC 45.33.32.156"
                                           Foreground="{StaticResource Pink}" FontFamily="Consolas" FontSize="11"/>
                                <TextBlock Text="[14:22:45] PACKET SCAN initiated on subnet /24"
                                           Foreground="{StaticResource Cyan}" FontFamily="Consolas" FontSize="11"/>
                                <TextBlock Text="[14:22:33] FIREWALL RULE updated — port 8443 restricted"
                                           Foreground="{StaticResource Yellow}" FontFamily="Consolas" FontSize="11"/>
                                <TextBlock Text="[14:22:21] NODE 10.0.0.7 disconnected — TIMEOUT"
                                           Foreground="{StaticResource TextDim}" FontFamily="Consolas" FontSize="11"/>
                                <TextBlock Text="[14:22:09] ENCRYPTION KEY rotated — AES-256"
                                           Foreground="{StaticResource Green}" FontFamily="Consolas" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <!-- Progress bars neon style -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="// SYSTEM LOAD" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="9" Margin="0,0,0,8"/>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="CPU  " Foreground="{StaticResource Cyan}" FontFamily="Consolas" FontSize="10" Width="50"/>
                                <Border Height="8" Background="#1100FFFF" CornerRadius="4">
                                    <Border HorizontalAlignment="Left" Width="280" Height="8" CornerRadius="4" Background="{StaticResource Cyan}">
                                        <Border.Effect><DropShadowEffect Color="#00FFFF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock Text="  73%" Foreground="{StaticResource Cyan}" FontFamily="Consolas" FontSize="10"/>
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="MEM  " Foreground="{StaticResource Pink}" FontFamily="Consolas" FontSize="10" Width="50"/>
                                <Border Height="8" Background="#11FF00AA" CornerRadius="4">
                                    <Border HorizontalAlignment="Left" Width="180" Height="8" CornerRadius="4" Background="{StaticResource Pink}">
                                        <Border.Effect><DropShadowEffect Color="#FF00AA" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock Text="  46%" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontSize="10"/>
                            </DockPanel>
                            <DockPanel Margin="0,4">
                                <TextBlock Text="NET  " Foreground="{StaticResource Green}" FontFamily="Consolas" FontSize="10" Width="50"/>
                                <Border Height="8" Background="#1100FF41" CornerRadius="4">
                                    <Border HorizontalAlignment="Left" Width="350" Height="8" CornerRadius="4" Background="{StaticResource Green}">
                                        <Border.Effect><DropShadowEffect Color="#00FF41" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                                    </Border>
                                </Border>
                                <TextBlock Text="  88%" Foreground="{StaticResource Green}" FontFamily="Consolas" FontSize="10"/>
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Right panel -->
                <Border Grid.Column="2" Background="{StaticResource Bg1}"
                        BorderBrush="{StaticResource BorderC}" BorderThickness="1,0,0,0">
                    <StackPanel Margin="16">
                        <TextBlock Text="// QUICK ACTIONS" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="9" Margin="0,16,0,12"/>
                        <Border Margin="0,3" Padding="12,10" CornerRadius="4" Cursor="Hand"
                                Background="#1100FFFF" BorderBrush="{StaticResource Cyan}" BorderThickness="1">
                            <TextBlock Text="⚡ RUN SCAN" Foreground="{StaticResource Cyan}"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Border Margin="0,3" Padding="12,10" CornerRadius="4" Cursor="Hand"
                                Background="#11FF00AA" BorderBrush="{StaticResource Pink}" BorderThickness="1">
                            <TextBlock Text="🔒 LOCKDOWN" Foreground="{StaticResource Pink}"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Border Margin="0,3" Padding="12,10" CornerRadius="4" Cursor="Hand"
                                Background="#1100FF41" BorderBrush="{StaticResource Green}" BorderThickness="1">
                            <TextBlock Text="📡 BROADCAST" Foreground="{StaticResource Green}"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                        </Border>
                        <Border Margin="0,3" Padding="12,10" CornerRadius="4" Cursor="Hand"
                                Background="#0D0D22" BorderBrush="{StaticResource BorderC}" BorderThickness="1">
                            <TextBlock Text="📋 REPORT" Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </Border>

                        <Rectangle Height="1" Fill="{StaticResource BorderC}" Margin="0,16"/>

                        <TextBlock Text="// THREAT LEVEL" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,8"/>
                        <TextBlock Text="CRITICAL" HorizontalAlignment="Center"
                                   FontFamily="Impact" FontSize="28" Foreground="{StaticResource Pink}"
                                   LetterSpacing="3">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF00AA" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="2 active intrusions" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" FontFamily="Consolas" FontSize="9"/>

                        <Rectangle Height="1" Fill="{StaticResource BorderC}" Margin="0,16"/>

                        <TextBlock Text="// OPERATOR" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="9" Margin="0,0,0,8"/>
                        <TextBlock Text="MAVERICK" HorizontalAlignment="Center"
                                   FontFamily="Impact" FontSize="20" Foreground="{StaticResource Cyan}"
                                   LetterSpacing="3"/>
                        <TextBlock Text="CLEARANCE: LEVEL 5" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Yellow}" FontFamily="Consolas" FontSize="9"/>
                        <TextBlock Text="SESSION: 04:17:23" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" FontFamily="Consolas" FontSize="9"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{StaticResource Bg1}" CornerRadius="0,0,10,10">
                <DockPanel Margin="12,0">
                    <TextBlock Text="◉ SECURE CONNECTION  //  AES-256  //  TOR RELAY ACTIVE"
                               Foreground="{StaticResource Green}" FontFamily="Consolas" FontSize="8"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="CYBEROPS v2.0 · ESC TO EXIT"
                               Foreground="{StaticResource TextDim}" FontFamily="Consolas" FontSize="8"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="scanBar"
                                     Storyboard.TargetProperty="Y"
                                     From="-2" To="720" Duration="0:0:3">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
