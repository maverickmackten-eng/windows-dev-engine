<Window x:Class="ArcaneWizard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARCANE SPELLBOOK — Wizard Theme"
        Width="1000" Height="700"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"    Color="#08030F"/>
        <SolidColorBrush x:Key="Bg1"    Color="#0D0520"/>
        <SolidColorBrush x:Key="Bg2"    Color="#130828"/>
        <SolidColorBrush x:Key="Purple" Color="#AA44FF"/>
        <SolidColorBrush x:Key="Gold"   Color="#FFD700"/>
        <SolidColorBrush x:Key="Teal"   Color="#00DDCC"/>
        <SolidColorBrush x:Key="Dim"    Color="#554466"/>
        <SolidColorBrush x:Key="BorderP" Color="#7700BB44"/>
    </Window.Resources>

    <Border Background="{StaticResource Bg0}" CornerRadius="12"
            BorderBrush="#7700BB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#9900FF" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Bg1}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown" BorderBrush="#33AA44FF" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <TextBlock Text="✦ ARCANE SPELLBOOK" FontFamily="Georgia" FontSize="16"
                               FontStyle="Italic" Foreground="{StaticResource Purple}" VerticalAlignment="Center">
                        <TextBlock.Effect><DropShadowEffect Color="#AA44FF" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/></TextBlock.Effect>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="─" Width="36" Height="36" Click="MinBtn_Click"
                                Background="Transparent" Foreground="{StaticResource Dim}" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="✕" Width="36" Height="36" Click="CloseBtn_Click"
                                Background="Transparent" Foreground="#FF2D55" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource BorderP}" BorderThickness="0,0,1,0">
                    <StackPanel Margin="8,16">
                        <TextBlock Text="SPELL SCHOOLS" Foreground="{StaticResource Dim}"
                                   FontFamily="Georgia" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <Border Margin="4,2" Padding="12,10" CornerRadius="6"
                                Background="#1AAA44FF" BorderBrush="{StaticResource Purple}" BorderThickness="1">
                            <Border.Effect><DropShadowEffect Color="#AA44FF" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/></Border.Effect>
                            <TextBlock Text="✦ Evocation" Foreground="{StaticResource Purple}" FontFamily="Georgia" FontSize="12"/>
                        </Border>
                        <Border Margin="4,2" Padding="12,10" CornerRadius="6" Cursor="Hand">
                            <TextBlock Text="◈ Illusion" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="12"/>
                        </Border>
                        <Border Margin="4,2" Padding="12,10" CornerRadius="6" Cursor="Hand">
                            <TextBlock Text="◉ Necromancy" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="12"/>
                        </Border>
                        <Border Margin="4,2" Padding="12,10" CornerRadius="6" Cursor="Hand">
                            <TextBlock Text="⬡ Transmutation" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="12"/>
                        </Border>
                        <Border Margin="4,2" Padding="12,10" CornerRadius="6" Cursor="Hand">
                            <TextBlock Text="◎ Divination" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="12"/>
                        </Border>
                        <Rectangle Height="1" Fill="#33AA44FF" Margin="8,12"/>
                        <TextBlock Text="MANA" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <Border Height="10" Background="#0FAA44FF" CornerRadius="5" Margin="8,0">
                            <Border HorizontalAlignment="Left" Width="120" Height="10" CornerRadius="5" Background="{StaticResource Purple}">
                                <Border.Effect><DropShadowEffect Color="#AA44FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                            </Border>
                        </Border>
                        <TextBlock Text="78 / 100" Foreground="{StaticResource Purple}" FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,24">
                        <TextBlock Text="✦ ARCANE COMPENDIUM ✦" HorizontalAlignment="Center"
                                   FontFamily="Georgia" FontSize="32" FontStyle="Italic" Foreground="{StaticResource Purple}" Margin="0,0,0,4">
                            <TextBlock.Effect><DropShadowEffect Color="#AA44FF" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/></TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="The collected works of Master Maverick — Volume VII" HorizontalAlignment="Center"
                                   Foreground="{StaticResource Dim}" FontFamily="Georgia" FontStyle="Italic" FontSize="12" Margin="0,0,0,24"/>

                        <!-- Spell cards -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border Margin="8" Padding="16,14" CornerRadius="8" Width="200"
                                    Background="{StaticResource Bg2}" BorderBrush="{StaticResource Purple}" BorderThickness="1">
                                <Border.Effect><DropShadowEffect Color="#AA44FF" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="⚡ CHAIN LIGHTNING" Foreground="{StaticResource Purple}"
                                               FontFamily="Georgia" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="School: Evocation" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10" Margin="0,4,0,0"/>
                                    <TextBlock Text="Level: 6" Foreground="{StaticResource Gold}" FontFamily="Georgia" FontSize="10"/>
                                    <TextBlock Text="Cast: 1 Action" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10"/>
                                    <TextBlock Text="Dmg: 10d8 lightning" Foreground="#00DDCC" FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8" Padding="16,14" CornerRadius="8" Width="200"
                                    Background="{StaticResource Bg2}" BorderBrush="{StaticResource Gold}" BorderThickness="1">
                                <Border.Effect><DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="✦ WISH" Foreground="{StaticResource Gold}"
                                               FontFamily="Georgia" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="School: Conjuration" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10" Margin="0,4,0,0"/>
                                    <TextBlock Text="Level: 9" Foreground="{StaticResource Gold}" FontFamily="Georgia" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="Cast: 1 Action" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10"/>
                                    <TextBlock Text="Effect: Reality bend" Foreground="{StaticResource Gold}" FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8" Padding="16,14" CornerRadius="8" Width="200"
                                    Background="{StaticResource Bg2}" BorderBrush="{StaticResource Teal}" BorderThickness="1">
                                <Border.Effect><DropShadowEffect Color="#00DDCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="◈ MIRROR IMAGE" Foreground="{StaticResource Teal}"
                                               FontFamily="Georgia" FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="School: Illusion" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10" Margin="0,4,0,0"/>
                                    <TextBlock Text="Level: 2" Foreground="{StaticResource Gold}" FontFamily="Georgia" FontSize="10"/>
                                    <TextBlock Text="Cast: 1 Action" Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="10"/>
                                    <TextBlock Text="Dur: 1 minute" Foreground="{StaticResource Teal}" FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Arcane text block -->
                        <Border Background="{StaticResource Bg2}" CornerRadius="8"
                                BorderBrush="#33AA44FF" BorderThickness="1" Padding="20">
                            <StackPanel>
                                <TextBlock Text="✦ ARCANE NOTES" Foreground="{StaticResource Purple}"
                                           FontFamily="Georgia" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Dim}"
                                           FontFamily="Georgia" FontSize="12" FontStyle="Italic"
                                           Text="The art of Evocation demands precision of thought and purity of intent. When the mana flows through the weave, one must visualize the destination of each particle of energy, lest the chaos consume the caster whole. Master Maverick has documented seventeen distinct casting methodologies within these pages..."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource Bg1}" CornerRadius="0,0,12,12"
                    BorderBrush="#33AA44FF" BorderThickness="0,1,0,0">
                <TextBlock Text="✦ The Arcane Arts — Master Maverick — Spellbook VII  ✦  ESC to close"
                           Foreground="{StaticResource Dim}" FontFamily="Georgia" FontSize="9"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
