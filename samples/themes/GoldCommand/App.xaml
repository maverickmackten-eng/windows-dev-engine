<Application x:Class="GoldCommand.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ══ GOLD COMMAND PALETTE ══════════════════════════ -->
            <SolidColorBrush x:Key="BackgroundDeepBrush"     Color="#0C0800"/>
            <SolidColorBrush x:Key="BackgroundPanelBrush"    Color="#150E00"/>
            <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="#1E1600"/>
            <SolidColorBrush x:Key="BorderSubtleBrush"       Color="#3D2E00"/>
            <SolidColorBrush x:Key="BorderActiveBrush"       Color="#FFB800"/>
            <SolidColorBrush x:Key="AccentPrimaryBrush"      Color="#FFB800"/>  <!-- Gold -->
            <SolidColorBrush x:Key="AccentSecondaryBrush"    Color="#CC6600"/>  <!-- Amber -->
            <SolidColorBrush x:Key="AccentSuccessBrush"      Color="#88DD44"/>
            <SolidColorBrush x:Key="AccentDangerBrush"       Color="#FF4422"/>
            <SolidColorBrush x:Key="TextPrimaryBrush"        Color="#FFE566"/>
            <SolidColorBrush x:Key="TextSecondaryBrush"      Color="#AA8822"/>
            <SolidColorBrush x:Key="TextDisabledBrush"       Color="#554400"/>
            <!-- Primary button -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#FFB800"/>
                <Setter Property="Foreground" Value="#0C0800"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFB800" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#FFCC33"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#CC8800"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
