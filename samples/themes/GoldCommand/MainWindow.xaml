<Window x:Class="GoldCommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COMMAND AUTHORITY"
        Width="1280" Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="{DynamicResource BackgroundDeepBrush}"
        WindowStartupLocation="CenterScreen">
    <!--
        GoldCommand Theme Sample
        ========================
        Palette: #0C0800 deep black, #FFB800 gold accent, #CC6600 amber secondary
        Features: subtle grid tile pattern, gold borders with inner glow,
                  all icons and text in gold/amber tones
    -->
    <Grid>
        <!-- Subtle grid tile pattern overlay -->
        <Border IsHitTestVisible="False" Opacity="0.04">
            <Border.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,32,32" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen><Pen Brush="#FFB800" Thickness="0.5"/></GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="32,0" EndPoint="32,32"/>
                                    <LineGeometry StartPoint="0,32" EndPoint="32,32"/>
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.Background>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#150E00">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Gold accent left stripe -->
                <Border Grid.Column="0" Width="4" Background="#FFB800">
                    <Border.Effect><DropShadowEffect Color="#FFB800" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                </Border>
                <TextBlock Grid.Column="1" Text="COMMAND AUTHORITY"
                           FontFamily="Segoe UI Black" FontSize="16"
                           Foreground="#FFB800" VerticalAlignment="Center" Margin="16,0"
                           IsHitTestVisible="False">
                    <TextBlock.Effect><DropShadowEffect Color="#FFB800" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/></TextBlock.Effect>
                </TextBlock>
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="—" Width="46" Height="48" Background="Transparent"
                            Foreground="#AA8822" BorderThickness="0" FontSize="16" Click="MinimizeClick"/>
                    <Button Content="&#x2716;" Width="46" Height="48" Background="Transparent"
                            Foreground="#FFB800" BorderThickness="0" FontSize="14" Click="CloseClick"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="#150E00"
                        BorderBrush="#3D2E00" BorderThickness="1" CornerRadius="4">
                    <Border.Effect><DropShadowEffect Color="#FFB800" BlurRadius="8" ShadowDepth="0" Opacity="0.15"/></Border.Effect>
                    <StackPanel Margin="12" Spacing="6">
                        <TextBlock Text="COMMAND DECK" FontSize="8" FontWeight="Bold"
                                   Foreground="#554400" Margin="4,0,0,10"/>
                        <Button Content="📊  OPERATIONS" Style="{DynamicResource PrimaryButtonStyle}" HorizontalAlignment="Stretch"/>
                        <Button Content="🛡️  DEFENSE" Background="Transparent"
                                Foreground="#AA8822" BorderBrush="#3D2E00" BorderThickness="1"
                                Padding="12,8" HorizontalAlignment="Stretch"/>
                        <Button Content="📈  INTELLIGENCE" Background="Transparent"
                                Foreground="#AA8822" BorderBrush="#3D2E00" BorderThickness="1"
                                Padding="12,8" HorizontalAlignment="Stretch"/>
                        <Button Content="🎯  TARGETING" Background="Transparent"
                                Foreground="#AA8822" BorderBrush="#3D2E00" BorderThickness="1"
                                Padding="12,8" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Main panel -->
                <Border Grid.Column="2" Background="#150E00"
                        BorderBrush="#3D2E00" BorderThickness="1" CornerRadius="4" Padding="24">
                    <StackPanel>
                        <!-- KPI row -->
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
                            <Border Width="160" Height="80" Background="#0C0800"
                                    BorderBrush="#FFB800" BorderThickness="1" CornerRadius="4" Padding="14">
                                <Border.Effect><DropShadowEffect Color="#FFB800" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="ACTIVE UNITS" FontSize="8" FontWeight="Bold" Foreground="#AA8822"/>
                                    <TextBlock Text="48" FontFamily="Segoe UI Black" FontSize="32" Foreground="#FFB800"/>
                                </StackPanel>
                            </Border>
                            <Border Width="160" Height="80" Background="#0C0800"
                                    BorderBrush="#CC6600" BorderThickness="1" CornerRadius="4" Padding="14">
                                <Border.Effect><DropShadowEffect Color="#CC6600" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="OBJECTIVES" FontSize="8" FontWeight="Bold" Foreground="#884400"/>
                                    <TextBlock Text="7/12" FontFamily="Segoe UI Black" FontSize="32" Foreground="#CC6600"/>
                                </StackPanel>
                            </Border>
                            <Border Width="160" Height="80" Background="#0C0800"
                                    BorderBrush="#88DD44" BorderThickness="1" CornerRadius="4" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="MISSION STATUS" FontSize="8" FontWeight="Bold" Foreground="#558822"/>
                                    <TextBlock Text="GO" FontFamily="Segoe UI Black" FontSize="32" Foreground="#88DD44"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Ops log -->
                        <TextBlock Text="OPERATIONS LOG" FontSize="9" FontWeight="Bold"
                                   Foreground="#FFB800" Margin="0,0,0,10"/>
                        <Border Background="#0C0800" BorderBrush="#3D2E00" BorderThickness="1"
                                CornerRadius="4" Padding="12" Height="200">
                            <StackPanel Spacing="6">
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#554400">14:23:01</Run><Run Foreground="#AA8822">  ALPHA team confirmed at grid 447-892</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#554400">14:22:47</Run><Run Foreground="#FF4422">  CONTACT REPORT — north perimeter</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#554400">14:22:33</Run><Run Foreground="#88DD44">  Objective DELTA secured</Run>
                                </TextBlock>
                                <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="11">
                                    <Run Foreground="#554400">14:21:58</Run><Run Foreground="#AA8822">  BRAVO team in position, awaiting orders</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Grid Grid.Row="2" Background="#150E00">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="■ MISSION ACTIVE — CONDITION YELLOW"
                           FontFamily="Cascadia Code, Consolas" FontSize="10"
                           Foreground="#FFB800" VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" Text="GOLD COMMAND v1.0"
                           FontFamily="Cascadia Code, Consolas" FontSize="10"
                           Foreground="#554400" VerticalAlignment="Center" Margin="12,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
