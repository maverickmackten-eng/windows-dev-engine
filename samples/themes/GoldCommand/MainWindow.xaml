<Window x:Class="GoldCommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COMMAND AUTHORITY"
        Height="700" Width="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- ── GoldCommand Palette ────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgDeep"    Color="#0C0800"/>  <!-- Deep black with warm hint -->
    <SolidColorBrush x:Key="BgPanel"   Color="#14100A"/>
    <SolidColorBrush x:Key="BgCard"    Color="#1E180A"/>
    <SolidColorBrush x:Key="Gold"      Color="#FFB800"/>  <!-- Primary gold -->
    <SolidColorBrush x:Key="Amber"     Color="#CC6600"/>  <!-- Secondary amber -->
    <SolidColorBrush x:Key="GoldDim"   Color="#775500"/>  <!-- Muted gold -->
    <SolidColorBrush x:Key="TextPri"   Color="#FFE0A0"/>
    <SolidColorBrush x:Key="TextSub"   Color="#886600"/>

    <!-- Glow effects -->
    <DropShadowEffect x:Key="GlowGold"  Color="#FFB800" BlurRadius="18"
                      ShadowDepth="0" Opacity="0.7"/>
    <DropShadowEffect x:Key="GlowAmber" Color="#CC6600" BlurRadius="12"
                      ShadowDepth="0" Opacity="0.6"/>
    <DropShadowEffect x:Key="GlowSubtle" Color="#FFB800" BlurRadius="6"
                      ShadowDepth="0" Opacity="0.25"/>

    <!-- Gold button style -->
    <Style x:Key="GoldButton" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#FFB800"/>
      <Setter Property="BorderBrush"    Value="#FFB800"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="16,8"/>
      <Setter Property="FontFamily"      Value="Segoe UI Black"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22FFB800"/>
                <Setter Property="Effect"     Value="{StaticResource GlowGold}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#44FFB800"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Background="{StaticResource BgDeep}"
          BorderBrush="#332200" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="#FFB800" Opacity="0.08"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="24"/>
      </Grid.RowDefinitions>

      <!-- Subtle grid tile pattern (inline via Canvas) -->
      <Canvas Grid.RowSpan="3" IsHitTestVisible="False">
        <Rectangle Canvas.Left="183"  Width="1" Height="700" Fill="#08FFB800"/>
        <Rectangle Canvas.Left="366"  Width="1" Height="700" Fill="#08FFB800"/>
        <Rectangle Canvas.Left="549"  Width="1" Height="700" Fill="#08FFB800"/>
        <Rectangle Canvas.Left="732"  Width="1" Height="700" Fill="#08FFB800"/>
        <Rectangle Canvas.Left="915"  Width="1" Height="700" Fill="#08FFB800"/>
        <Rectangle Canvas.Top="116"  Height="1" Width="1100" Fill="#08FFB800"/>
        <Rectangle Canvas.Top="232"  Height="1" Width="1100" Fill="#08FFB800"/>
        <Rectangle Canvas.Top="348"  Height="1" Width="1100" Fill="#08FFB800"/>
        <Rectangle Canvas.Top="464"  Height="1" Width="1100" Fill="#08FFB800"/>
        <Rectangle Canvas.Top="580"  Height="1" Width="1100" Fill="#08FFB800"/>
      </Canvas>

      <!-- ── Accent line top ── -->
      <Rectangle Height="1" VerticalAlignment="Top" Grid.RowSpan="3"
                 IsHitTestVisible="False">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="Transparent" Offset="0"/>
            <GradientStop Color="#FFB800"     Offset="0.5"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
      </Rectangle>

      <!-- ── Title Bar ── -->
      <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="COMMAND AUTHORITY"
                   FontFamily="Segoe UI Black" FontSize="17"
                   Foreground="#FFB800"
                   LetterSpacing="4"
                   VerticalAlignment="Center" Margin="20,0"
                   Effect="{StaticResource GlowGold}"/>

        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="─" Foreground="#775500" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48" FontSize="14"
                  Click="BtnMinimize_Click"/>
          <Button Content="□" Foreground="#775500" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48" FontSize="14"
                  Click="BtnMaximize_Click"/>
          <Button Content="✕" Foreground="#FFB800" Background="Transparent"
                  BorderThickness="0" Width="40" Height="48" FontSize="14"
                  Click="BtnClose_Click"/>
        </StackPanel>
      </Grid>

      <!-- ── Content ── -->
      <Grid Grid.Row="1" Margin="24,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel -->
        <StackPanel Grid.Column="0" Margin="0,0,16,0">
          <TextBlock Text="COMMAND STATUS"
                     Foreground="#886600" FontFamily="Cascadia Code"
                     FontSize="10" LetterSpacing="2" Margin="0,0,0,12"/>

          <Border Background="{StaticResource BgPanel}"
                  BorderBrush="#332200" BorderThickness="1"
                  CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="8" Height="8" Fill="#FFB800"
                       VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse.Effect>
                  <DropShadowEffect Color="#FFB800" BlurRadius="6" ShadowDepth="0"/>
                </Ellipse.Effect>
              </Ellipse>
              <TextBlock Text="AUTHORITY ACTIVE" Foreground="#FFB800"
                         FontFamily="Cascadia Code" FontSize="11"
                         Effect="{StaticResource GlowSubtle}"/>
            </StackPanel>
          </Border>

          <Border Background="{StaticResource BgPanel}"
                  BorderBrush="#332200" BorderThickness="1"
                  CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="8" Height="8" Fill="#CC6600"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock Text="MISSION READY" Foreground="#CC6600"
                         FontFamily="Cascadia Code" FontSize="11"/>
            </StackPanel>
          </Border>

          <Button Content="EXECUTE ORDER" Style="{StaticResource GoldButton}"
                  Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
          <Button Content="STAND DOWN" HorizontalAlignment="Stretch"
                  Background="Transparent" Foreground="#886600"
                  BorderBrush="#332200" BorderThickness="1"
                  Padding="16,8" FontFamily="Segoe UI Black" FontSize="12"
                  Cursor="Hand"/>
        </StackPanel>

        <!-- Main panel -->
        <Border Grid.Column="1"
                Background="{StaticResource BgPanel}"
                BorderBrush="#332200" BorderThickness="1"
                CornerRadius="8">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Gold eagle/command icon (Segoe MDL2) -->
            <TextBlock Text="&#xE753;"
                       FontFamily="Segoe MDL2 Assets" FontSize="56"
                       Foreground="#FFB800"
                       HorizontalAlignment="Center"
                       Effect="{StaticResource GlowGold}"
                       Margin="0,0,0,16"/>
            <TextBlock Text="COMMAND AUTHORITY"
                       FontFamily="Segoe UI Black" FontSize="28"
                       Foreground="#FFB800" LetterSpacing="4"
                       HorizontalAlignment="Center"
                       Effect="{StaticResource GlowGold}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="gold • amber • command-center"
                       FontFamily="Cascadia Code" FontSize="12"
                       Foreground="#886600"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ── Status Bar ── -->
      <Grid Grid.Row="2" Background="#0A0800">
        <TextBlock Text="COMMAND AUTHORITY — v1.0.0 — OPERATIONAL"
                   Foreground="#332200" FontSize="10"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center" Margin="16,0"/>
        <TextBlock Text="&#x2605; AUTHORIZED"
                   Foreground="#FFB800" FontSize="10"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,16,0"/>
      </Grid>
    </Grid>
  </Border>
</Window>
