<Window x:Class="DarkMilitary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dark Military Theme Showcase"
        Width="1100" Height="750"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Theme Colors -->
        <SolidColorBrush x:Key="BgDeep"      Color="#0A0D12"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#12171F"/>
        <SolidColorBrush x:Key="BgElevated"  Color="#1C2333"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2A3347"/>
        <SolidColorBrush x:Key="Accent"      Color="#00B4FF"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF6B35"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00FF94"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#FF2D55"/>
        <SolidColorBrush x:Key="AccentGold"  Color="#FFD700"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#8899AA"/>
    </Window.Resources>

    <Border Background="{StaticResource BgDeep}" CornerRadius="12"
            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Background="{StaticResource BgPanel}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <DockPanel Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" Foreground="{StaticResource Accent}" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="DARK MILITARY" Foreground="{StaticResource Accent}"
                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text=" — THEME SHOWCASE" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="─" Width="40" Height="36" Click="MinBtn_Click"
                                Background="Transparent" Foreground="{StaticResource TextMuted}"
                                BorderThickness="0" Cursor="Hand" FontSize="14"/>
                        <Button Content="✕" Width="40" Height="36" Click="CloseBtn_Click"
                                Background="Transparent" Foreground="{StaticResource AccentRed}"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="8,16">
                        <TextBlock Text="NAVIGATION" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="9" Margin="8,0,0,8"/>

                        <!-- Nav items -->
                        <Border Background="{StaticResource BgElevated}" CornerRadius="6" Margin="4,2">
                            <StackPanel Orientation="Horizontal" Margin="12,10">
                                <TextBlock Text="⬛" Foreground="{StaticResource Accent}" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Dashboard" Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Margin="4,2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Margin="12,10">
                                <TextBlock Text="◈" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Missions" Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Margin="4,2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Margin="12,10">
                                <TextBlock Text="◉" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Intelligence" Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Margin="4,2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Margin="12,10">
                                <TextBlock Text="◎" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Assets" Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="6" Margin="4,2" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Margin="12,10">
                                <TextBlock Text="⚙" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Settings" Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Separator Background="{StaticResource BorderColor}" Margin="8,16"/>

                        <!-- Status indicators -->
                        <TextBlock Text="SYSTEM STATUS" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="9" Margin="8,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="12,4">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Networks Online" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="12,4">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGold}" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="2 Alerts Pending" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="12,4">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Accent}" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Sync Active" Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Content area -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">

                        <!-- Header row -->
                        <DockPanel Margin="0,0,0,24">
                            <StackPanel>
                                <TextBlock Text="MISSION CONTROL" Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas" FontSize="28" FontWeight="Bold"/>
                                <TextBlock Text="Active operations dashboard — Commander Maverick"
                                           Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Action buttons -->
                                <Border Background="{StaticResource Accent}" CornerRadius="6"
                                        Margin="8,0,0,0" Cursor="Hand">
                                    <TextBlock Text="  LAUNCH MISSION  " Foreground="#000000"
                                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                               Padding="0,8"/>
                                </Border>
                                <Border Background="{StaticResource BgElevated}" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                        Margin="8,0,0,0" Cursor="Hand">
                                    <TextBlock Text="  REPORTS  " Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="12"
                                               Padding="0,8"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>

                        <!-- Stat cards row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <!-- Card 1 -->
                            <Border Margin="0,0,16,0" Padding="20,16" CornerRadius="8" MinWidth="180"
                                    Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE MISSIONS" Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="7" Foreground="{StaticResource Accent}"
                                               FontFamily="Consolas" FontSize="40" FontWeight="Bold"/>
                                    <TextBlock Text="+2 from yesterday" Foreground="{StaticResource AccentGreen}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 2 -->
                            <Border Margin="0,0,16,0" Padding="20,16" CornerRadius="8" MinWidth="180"
                                    Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ASSETS DEPLOYED" Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="23" Foreground="{StaticResource AccentOrange}"
                                               FontFamily="Consolas" FontSize="40" FontWeight="Bold"/>
                                    <TextBlock Text="4 awaiting orders" Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 3 -->
                            <Border Margin="0,0,16,0" Padding="20,16" CornerRadius="8" MinWidth="180"
                                    Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource AccentRed}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CRITICAL ALERTS" Foreground="{StaticResource AccentRed}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="2" Foreground="{StaticResource AccentRed}"
                                               FontFamily="Consolas" FontSize="40" FontWeight="Bold"/>
                                    <TextBlock Text="Requires immediate action" Foreground="{StaticResource AccentRed}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 4 -->
                            <Border Padding="20,16" CornerRadius="8" MinWidth="180"
                                    Background="{StaticResource BgPanel}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SUCCESS RATE" Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock Text="94%" Foreground="{StaticResource AccentGreen}"
                                               FontFamily="Consolas" FontSize="40" FontWeight="Bold"/>
                                    <TextBlock Text="Last 30 missions" Foreground="{StaticResource TextMuted}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Data table -->
                        <Border Background="{StaticResource BgPanel}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1" CornerRadius="8" Margin="0,0,0,24">
                            <!-- Table header -->
                            <StackPanel>
                                <Border Background="{StaticResource BgElevated}"
                                        CornerRadius="8,8,0,0" Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="MISSION NAME" Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="COMMANDER"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="STATUS"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="PRIORITY"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="ETA"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                                <!-- Row 1 -->
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Operation Nighthawk" Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="MAVERICK"
                                                   Foreground="{StaticResource Accent}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <Border Grid.Column="2" Background="#1500FF94" CornerRadius="4"
                                                HorizontalAlignment="Left" Padding="8,3">
                                            <TextBlock Text="ACTIVE" Foreground="{StaticResource AccentGreen}"
                                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="⬛ CRITICAL"
                                                   Foreground="{StaticResource AccentRed}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="02:14"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </Grid>
                                </Border>
                                <!-- Row 2 -->
                                <Border Background="#050A0F" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Operation Iceman" Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="ICEMAN"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <Border Grid.Column="2" Background="#15FFB800" CornerRadius="4"
                                                HorizontalAlignment="Left" Padding="8,3">
                                            <TextBlock Text="STANDBY" Foreground="{StaticResource AccentGold}"
                                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="◈ HIGH"
                                                   Foreground="{StaticResource AccentOrange}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="04:30"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </Grid>
                                </Border>
                                <!-- Row 3 -->
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Operation Ghostrider" Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text="GHOST"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <Border Grid.Column="2" Background="#1500B4FF" CornerRadius="4"
                                                HorizontalAlignment="Left" Padding="8,3">
                                            <TextBlock Text="COMPLETE" Foreground="{StaticResource Accent}"
                                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="○ MEDIUM"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                        <TextBlock Grid.Column="4" Text="DONE"
                                                   Foreground="{StaticResource AccentGreen}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Buttons showcase row -->
                        <TextBlock Text="BUTTON VARIANTS" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="{StaticResource Accent}" CornerRadius="6" Margin="0,0,8,0" Cursor="Hand">
                                <TextBlock Text="  PRIMARY ACTION  " Foreground="#000" FontFamily="Consolas"
                                           FontSize="12" FontWeight="Bold" Padding="0,10"/>
                            </Border>
                            <Border Background="Transparent" BorderBrush="{StaticResource Accent}"
                                    BorderThickness="1" CornerRadius="6" Margin="0,0,8,0" Cursor="Hand">
                                <TextBlock Text="  SECONDARY  " Foreground="{StaticResource Accent}"
                                           FontFamily="Consolas" FontSize="12" Padding="0,10"/>
                            </Border>
                            <Border Background="{StaticResource AccentRed}" CornerRadius="6" Margin="0,0,8,0" Cursor="Hand">
                                <TextBlock Text="  DANGER  " Foreground="#FFFFFF" FontFamily="Consolas"
                                           FontSize="12" FontWeight="Bold" Padding="0,10"/>
                            </Border>
                            <Border Background="{StaticResource BgElevated}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                    CornerRadius="6" Margin="0,0,8,0" Cursor="Hand">
                                <TextBlock Text="  GHOST  " Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="12" Padding="0,10"/>
                            </Border>
                        </StackPanel>

                        <!-- Input fields showcase -->
                        <TextBlock Text="INPUT FIELDS" Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="{StaticResource BgPanel}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,16,0" Width="250">
                                <TextBlock Text="Search missions..." Foreground="{StaticResource TextMuted}"
                                           FontFamily="Consolas" FontSize="13"/>
                            </Border>
                            <Border Background="{StaticResource BgPanel}" CornerRadius="8"
                                    BorderBrush="{StaticResource Accent}" BorderThickness="1"
                                    Padding="12,10" Margin="0,0,16,0" Width="250">
                                <TextBlock Text="maverick@topgun.mil" Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas" FontSize="13"/>
                            </Border>
                            <Border Background="{StaticResource BgPanel}" CornerRadius="8"
                                    BorderBrush="{StaticResource AccentRed}" BorderThickness="1"
                                    Padding="12,10" Width="250">
                                <TextBlock Text="Invalid callsign" Foreground="{StaticResource AccentRed}"
                                           FontFamily="Consolas" FontSize="13"/>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                    CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                <DockPanel Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreen}" Margin="0,0,6,0"/>
                        <TextBlock Text="All systems nominal  |  Last sync: 14:23:01"
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Dark Military v1.0" Foreground="#334455"
                               FontFamily="Consolas" FontSize="9"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
