<Window x:Class="DropdownMenuDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DROPDOWN &amp; MENU CONTROLS"
        Width="1000" Height="720"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"   Color="#0A0D12"/>
        <SolidColorBrush x:Key="Bg1"   Color="#12171F"/>
        <SolidColorBrush x:Key="Bg2"   Color="#1C2333"/>
        <SolidColorBrush x:Key="Acc"   Color="#00B4FF"/>
        <SolidColorBrush x:Key="Acc2"  Color="#FF6B35"/>
        <SolidColorBrush x:Key="Green" Color="#00FF94"/>
        <SolidColorBrush x:Key="Dim"   Color="#445566"/>
        <SolidColorBrush x:Key="Text"  Color="#CCDDEE"/>
        <SolidColorBrush x:Key="Bord"  Color="#2A3347"/>

        <!-- Custom ComboBox item style -->
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A00B4FF"/>
                                <Setter Property="Foreground" Value="{StaticResource Acc}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Acc}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ComboBox style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bord}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="12,8,36,8" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="placeholder" Text="Select an option..." Margin="12,8,36,8"
                                               Foreground="{StaticResource Dim}" VerticalAlignment="Center"
                                               Visibility="Collapsed" IsHitTestVisible="False"/>
                                    <ToggleButton x:Name="toggleButton" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Width="36"
                                                  Cursor="Hand">
                                        <TextBlock Text="▾" Foreground="{StaticResource Dim}" FontSize="12" HorizontalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" PopupAnimation="Slide"
                                   MinWidth="{TemplateBinding ActualWidth}" PlacementTarget="{RelativeSource Self}"
                                   Placement="Bottom">
                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Acc}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Acc}"/>
                            </Trigger>
                            <Trigger Property="SelectedIndex" Value="-1">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu style -->
        <Style x:Key="DarkMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bord}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
        </Style>
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Bg0}" CornerRadius="10" BorderBrush="#2A3347" BorderThickness="1">
        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Background="{StaticResource Bg1}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown" BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <TextBlock Text="◈  DROPDOWN &amp; MENU CONTROLS" Foreground="{StaticResource Acc}"
                               FontFamily="Cascadia Code" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button Content="─" Width="36" Height="36" Click="MinBtn_Click"
                                Background="Transparent" Foreground="{StaticResource Dim}" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="✕" Width="36" Height="36" Click="CloseBtn_Click"
                                Background="Transparent" Foreground="#FF2D55" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,24">

                    <!-- Section: Styled ComboBoxes -->
                    <TextBlock Text="STYLED COMBOBOXES" Foreground="{StaticResource Acc}"
                               FontFamily="Cascadia Code" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                    <WrapPanel Margin="0,0,0,32">
                        <StackPanel Margin="0,0,24,16" Width="220">
                            <TextBlock Text="Weapon System" Foreground="{StaticResource Dim}"
                                       FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource DarkCombo}" SelectedIndex="1">
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🚀 Photon Torpedoes</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">⚡ Phaser Array</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🛡 Deflector Shields</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">💣 Quantum Mines</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🔥 Plasma Cannon</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,24,16" Width="220">
                            <TextBlock Text="Mission Priority" Foreground="{StaticResource Dim}"
                                       FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource DarkCombo}" SelectedIndex="0">
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🔴 CRITICAL</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🟡 HIGH</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">🔵 MEDIUM</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">⚪ LOW</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,24,16" Width="220">
                            <TextBlock Text="Unselected (placeholder)" Foreground="{StaticResource Dim}"
                                       FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource DarkCombo}">
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">Option Alpha</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">Option Bravo</ComboBoxItem>
                                <ComboBoxItem Style="{StaticResource DarkComboItem}">Option Charlie</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>

                    <!-- Section: Right-click context menus -->
                    <TextBlock Text="CONTEXT MENUS  (right-click the zones below)" Foreground="{StaticResource Acc}"
                               FontFamily="Cascadia Code" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                    <WrapPanel Margin="0,0,0,32">
                        <Border Margin="0,0,16,0" Width="280" Height="100" CornerRadius="8"
                                Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}" BorderThickness="1"
                                Cursor="ContextMenu">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource DarkMenu}">
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="✏  Edit Target"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="📋  Copy Coordinates"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="🔒  Lock Position"/>
                                    <Separator Background="#2A3347"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="🗑  Delete Target" Foreground="#FF2D55"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="TACTICAL TARGET" Foreground="{StaticResource Dim}"
                                           FontFamily="Cascadia Code" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="Right-click me" Foreground="{StaticResource Text}"
                                           FontFamily="Segoe UI" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Width="280" Height="100" CornerRadius="8"
                                Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}" BorderThickness="1"
                                Cursor="ContextMenu">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource DarkMenu}">
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="🚀  Launch Attack"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="📡  Scan Object"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}" Header="⚙  Configure"/>
                                    <MenuItem Style="{StaticResource DarkMenuItem}">
                                        <MenuItem.Header>
                                            <TextBlock Text="▶  Submenu"/>
                                        </MenuItem.Header>
                                        <MenuItem Style="{StaticResource DarkMenuItem}" Header="  Option A"/>
                                        <MenuItem Style="{StaticResource DarkMenuItem}" Header="  Option B"/>
                                        <MenuItem Style="{StaticResource DarkMenuItem}" Header="  Option C"/>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="COMMAND NODE" Foreground="{StaticResource Dim}"
                                           FontFamily="Cascadia Code" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="Right-click me" Foreground="{StaticResource Text}"
                                           FontFamily="Segoe UI" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- Section: Popup-style dropdown panels -->
                    <TextBlock Text="CUSTOM POPUP DROPDOWNS  (click buttons)" Foreground="{StaticResource Acc}"
                               FontFamily="Cascadia Code" FontSize="11" FontWeight="Bold" Margin="0,0,0,16"/>

                    <WrapPanel Margin="0,0,0,32">
                        <!-- Popup 1: notification bell style -->
                        <Grid Margin="0,0,24,0">
                            <Button x:Name="notifBtn" Content="🔔  Notifications  ▾" Click="NotifBtn_Click"
                                    Background="{StaticResource Bg2}" Foreground="{StaticResource Text}"
                                    BorderBrush="{StaticResource Bord}" BorderThickness="1" Padding="14,9"
                                    FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Acc}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup x:Name="notifPopup" PlacementTarget="{Binding ElementName=notifBtn}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Acc}"
                                        BorderThickness="1" CornerRadius="8" Width="300" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.25"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Border Background="{StaticResource Bg1}" CornerRadius="8,8,0,0" Padding="14,10">
                                            <TextBlock Text="NOTIFICATIONS" Foreground="{StaticResource Acc}"
                                                       FontFamily="Cascadia Code" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Border Padding="14,10" BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="🔴  Hull breach on Deck 7" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                                                <TextBlock Text="2 minutes ago" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="10" Margin="20,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="14,10" BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="🟡  Shield recharge at 94%" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                                                <TextBlock Text="8 minutes ago" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="10" Margin="20,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="14,10">
                                            <StackPanel>
                                                <TextBlock Text="🟢  Warp core stable" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                                                <TextBlock Text="15 minutes ago" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="10" Margin="20,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Popup 2: user account style -->
                        <Grid>
                            <Button x:Name="userBtn" Content="👤  Commander Maverick  ▾" Click="UserBtn_Click"
                                    Background="#1A00B4FF" Foreground="{StaticResource Acc}"
                                    BorderBrush="{StaticResource Acc}" BorderThickness="1" Padding="14,9"
                                    FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Popup x:Name="userPopup" PlacementTarget="{Binding ElementName=userBtn}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}"
                                        BorderThickness="1" CornerRadius="8" Width="220" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <Border Background="{StaticResource Bg1}" CornerRadius="8,8,0,0" Padding="16,12">
                                            <StackPanel>
                                                <TextBlock Text="👤 Commander Maverick" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                                                <TextBlock Text="NCC-1701-M  •  Captain" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Padding="8,4">
                                            <StackPanel>
                                                <Button Content="⚙  Settings" Background="Transparent" Foreground="{StaticResource Text}"
                                                        BorderThickness="0" Padding="8,8" HorizontalContentAlignment="Left"
                                                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                                                <Button Content="📋  Profile" Background="Transparent" Foreground="{StaticResource Text}"
                                                        BorderThickness="0" Padding="8,8" HorizontalContentAlignment="Left"
                                                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                                                <Button Content="🔓  Sign Out" Background="Transparent" Foreground="#FF2D55"
                                                        BorderThickness="0" Padding="8,8" HorizontalContentAlignment="Left"
                                                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </WrapPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{StaticResource Bg1}" CornerRadius="0,0,10,10"
                    BorderBrush="#1A2A3A" BorderThickness="0,1,0,0">
                <TextBlock Text="◈ DROPDOWN &amp; MENU DEMO  //  RIGHT-CLICK ZONES  //  CLICK BUTTONS TO OPEN POPUPS  //  ESC TO EXIT"
                           Foreground="{StaticResource Dim}" FontFamily="Cascadia Code" FontSize="8"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
