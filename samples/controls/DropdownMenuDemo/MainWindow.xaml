<Window x:Class="DropdownMenuDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dropdown Menu Demo"
        Width="1100" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0A0D12"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"      Color="#12171F"/>
        <SolidColorBrush x:Key="BgElevated"   Color="#1C2333"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#2A3347"/>
        <SolidColorBrush x:Key="Accent"       Color="#00B4FF"/>
        <!-- Popup menu item base style -->
        <Style x:Key="PopupMenuItem" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bg" Property="Background" Value="#1C2333"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bg" Property="Background" Value="#0D3A5C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#12171F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2A3347"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="200"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- Title bar -->
        <Grid Height="48" VerticalAlignment="Top" Background="#12171F">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Dropdown Menu Demo — 3 Patterns"
                       FontFamily="Segoe UI Black" FontSize="15" Foreground="#00B4FF"
                       VerticalAlignment="Center" Margin="16,0" IsHitTestVisible="False"/>
            <Button Grid.Column="1" Content="×" Width="46" Height="48"
                    Background="Transparent" Foreground="#8899AA" BorderThickness="0"
                    FontSize="18" Click="CloseClick"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>
        <!-- Three columns -->
        <Grid Margin="24,60,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Pattern 1: Styled ComboBox -->
            <Border Grid.Column="0" Background="#12171F" BorderBrush="#2A3347"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="1 — Styled ComboBox" FontFamily="Segoe UI Black"
                               FontSize="14" Foreground="#00B4FF" Margin="0,0,0,6"/>
                    <TextBlock Text="Dark bg, accent on selection, animated chevron."
                               FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <ComboBox x:Name="StyledComboBox" Style="{StaticResource DarkComboBox}"
                              SelectionChanged="ComboBox_SelectionChanged">
                        <ComboBoxItem Content="Dashboard"/>
                        <ComboBoxItem Content="Operations" IsSelected="True"/>
                        <ComboBoxItem Content="Settings"/>
                        <ComboBoxItem Content="Reports"/>
                        <ComboBoxItem Content="Analytics"/>
                        <ComboBoxItem Content="Security"/>
                    </ComboBox>
                    <TextBlock x:Name="ComboResult" Text="Selected: Operations"
                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                               Foreground="#8899AA" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
            <!-- Pattern 2: Popup menu -->
            <Border Grid.Column="2" Background="#12171F" BorderBrush="#2A3347"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="2 — Popup Menu" FontFamily="Segoe UI Black"
                               FontSize="14" Foreground="#00B4FF" Margin="0,0,0,6"/>
                    <TextBlock Text="Click button to open. Icon + label + keyboard hint. Closes on outside click."
                               FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <Button x:Name="PopupMenuTrigger" Content="Actions ▾"
                            Background="#1C2333" Foreground="White" BorderBrush="#2A3347"
                            BorderThickness="1" Padding="12,8" Cursor="Hand"
                            HorizontalAlignment="Left" Click="PopupMenuTrigger_Click"/>
                    <Popup x:Name="PopupMenu" PlacementTarget="{Binding ElementName=PopupMenuTrigger}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="#12171F" BorderBrush="#00B4FF"
                                BorderThickness="1" CornerRadius="6" MinWidth="220" Padding="0,4">
                            <Border.Effect><DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="4"/></Border.Effect>
                            <StackPanel>
                                <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="MenuItem_NewFile">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4FF" FontSize="13"/>
                                        <TextBlock Text="New File" FontSize="13"/>
                                        <TextBlock Text="Ctrl+N" FontSize="10" Foreground="#445566" Margin="20,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="MenuItem_Open">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4FF" FontSize="13"/>
                                        <TextBlock Text="Open..." FontSize="13"/>
                                        <TextBlock Text="Ctrl+O" FontSize="10" Foreground="#445566" Margin="20,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Height="1" Fill="#2A3347" Margin="8,2"/>
                                <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="MenuItem_Delete">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#FF2D55" FontSize="13"/>
                                        <TextBlock Text="Delete" FontSize="13" Foreground="#FF2D55"/>
                                        <TextBlock Text="Del" FontSize="10" Foreground="#445566" Margin="32,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <TextBlock x:Name="PopupResult" Text="— click an item"
                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                               Foreground="#8899AA" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
            <!-- Pattern 3: Cascading submenu -->
            <Border Grid.Column="4" Background="#12171F" BorderBrush="#2A3347"
                    BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="3 — Cascading Submenu" FontFamily="Segoe UI Black"
                               FontSize="14" Foreground="#00B4FF" Margin="0,0,0,6"/>
                    <TextBlock Text="Item with arrow opens nested Popup to the right. Pure XAML/code-behind."
                               FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <Button x:Name="CascadeTrigger" Content="Export ▾"
                            Background="#1C2333" Foreground="White" BorderBrush="#2A3347"
                            BorderThickness="1" Padding="12,8" Cursor="Hand"
                            HorizontalAlignment="Left" Click="CascadeTrigger_Click"/>
                    <Popup x:Name="CascadePopup" PlacementTarget="{Binding ElementName=CascadeTrigger}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="#12171F" BorderBrush="#00B4FF"
                                BorderThickness="1" CornerRadius="6" MinWidth="180" Padding="0,4">
                            <Border.Effect><DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="4"/></Border.Effect>
                            <StackPanel>
                                <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="Export_CSV">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4FF" FontSize="13"/>
                                        <TextBlock Text="Export CSV" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="Export_JSON">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4FF" FontSize="13"/>
                                        <TextBlock Text="Export JSON" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Height="1" Fill="#2A3347" Margin="8,2"/>
                                <!-- Submenu trigger -->
                                <Button x:Name="MoreFormatsBtn" Style="{StaticResource PopupMenuItem}"
                                        HorizontalAlignment="Stretch" MouseEnter="MoreFormats_MouseEnter">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Foreground="#00B4FF" FontSize="13"/>
                                        <TextBlock Text="More Formats" FontSize="13"/>
                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9" Foreground="#8899AA" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Level 2 submenu -->
                                <Popup x:Name="SubMenu" PlacementTarget="{Binding ElementName=MoreFormatsBtn}"
                                       Placement="Right" StaysOpen="False"
                                       AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#12171F" BorderBrush="#00B4FF"
                                            BorderThickness="1" CornerRadius="6" MinWidth="140" Padding="0,4">
                                        <Border.Effect><DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="4"/></Border.Effect>
                                        <StackPanel>
                                            <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="Export_XML">
                                                <TextBlock Text="📄  XML" FontSize="13" Foreground="White"/>
                                            </Button>
                                            <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="Export_PDF">
                                                <TextBlock Text="📄  PDF" FontSize="13" Foreground="White"/>
                                            </Button>
                                            <Button Style="{StaticResource PopupMenuItem}" HorizontalAlignment="Stretch" Click="Export_XLSX">
                                                <TextBlock Text="📄  XLSX" FontSize="13" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <TextBlock x:Name="CascadeResult" Text="— click an item"
                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                               Foreground="#8899AA" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
