<Window x:Class="ToastDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast Demo" Height="600" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Border Background="#0A0D12" BorderBrush="#2A3347" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="#12171F" MouseLeftButtonDown="TitleBar_MouseDown">
        <TextBlock Text="TOAST NOTIFICATION DEMO" FontFamily="Segoe UI Black" FontSize="13"
                   Foreground="#00B4FF" LetterSpacing="2"
                   VerticalAlignment="Center" Margin="16,0"/>
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                Foreground="#FF2D55" Background="Transparent" BorderThickness="0"
                Width="40" Height="48" HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
      </Grid>

      <!-- Content -->
      <Grid Grid.Row="1">

        <!-- Trigger buttons in centre -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal">

          <Button Content="&#xE946;  INFO" Margin="0,0,12,0"
                  Background="#12171F" Foreground="#00B4FF"
                  BorderBrush="#00B4FF" BorderThickness="1"
                  Padding="20,12" FontSize="13"
                  Click="BtnInfo_Click"/>

          <Button Content="&#xE73E;  SUCCESS" Margin="0,0,12,0"
                  Background="#12171F" Foreground="#00FF94"
                  BorderBrush="#00FF94" BorderThickness="1"
                  Padding="20,12" FontSize="13"
                  Click="BtnSuccess_Click"/>

          <Button Content="&#xE7BA;  WARNING" Margin="0,0,12,0"
                  Background="#12171F" Foreground="#FFD700"
                  BorderBrush="#FFD700" BorderThickness="1"
                  Padding="20,12" FontSize="13"
                  Click="BtnWarning_Click"/>

          <Button Content="&#xEA39;  ERROR"
                  Background="#12171F" Foreground="#FF2D55"
                  BorderBrush="#FF2D55" BorderThickness="1"
                  Padding="20,12" FontSize="13"
                  Click="BtnError_Click"/>
        </StackPanel>

        <!-- Toast stack: ItemsControl bound to ToastQueue -->
        <!-- Positioned bottom-right, stacks upward -->
        <ItemsControl x:Name="toastHost"
                      VerticalAlignment="Bottom" HorizontalAlignment="Right"
                      Margin="0,0,20,20"
                      Width="320">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <!-- Each toast is a Border with left accent bar -->
              <Border x:Name="toastCard"
                      Background="#1C2333"
                      BorderBrush="#2A3347" BorderThickness="1"
                      CornerRadius="8" Margin="0,0,0,8"
                      Opacity="0">
                <Border.RenderTransform>
                  <TranslateTransform x:Name="toastSlide" Y="40"/>
                </Border.RenderTransform>
                <Border.Triggers>
                  <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="toastCard"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.25"/>
                        <DoubleAnimation Storyboard.TargetName="toastSlide"
                                         Storyboard.TargetProperty="Y"
                                         From="40" To="0" Duration="0:0:0.3">
                          <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                          </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                      </Storyboard>
                    </BeginStoryboard>
                  </EventTrigger>
                </Border.Triggers>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <Rectangle Grid.Column="0" Fill="{Binding AccentColor}" RadiusX="8" RadiusY="0"/>
                  <StackPanel Grid.Column="1" Margin="12,10">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                      <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                 FontSize="14" Foreground="{Binding AccentColor}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                      <TextBlock Text="{Binding Title}" Foreground="#FFFFFF"
                                 FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Message}" Foreground="#8899AA"
                               FontSize="12" TextWrapping="Wrap"/>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </Grid>
    </Grid>
  </Border>
</Window>
