<Window x:Class="ToastDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast Notification Demo"
        Width="960" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0A0D12"
        WindowStartupLocation="CenterScreen">
    <!--
        ToastDemo — In-window toast notification system
        ================================================
        Toast types: Info (blue), Success (green), Warning (gold), Error (red)
        Stack:       Toasts stack vertically in a Canvas at bottom-right
        Animation:   Slide-in from right, fade in. Auto-dismiss after N seconds.
        Close:       X button on each toast
        Persistent:  "Sticky" mode toggle — toasts only close via X

        Implementation notes:
        - Each toast is a self-contained Border + Storyboard
        - ToastHost Canvas is positioned bottom-right via Margin
        - Each new toast is inserted at index 0 (top of stack) in the canvas
        - Auto-dismiss is a DispatcherTimer per toast
    -->
    <Window.Resources>
        <!-- Shared slide-in storyboard template (applied per-instance in code-behind) -->
        <SolidColorBrush x:Key="BgPanel" Color="#12171F"/>
    </Window.Resources>
    <Grid>
        <!-- Title bar -->
        <Grid Height="48" VerticalAlignment="Top" Background="#12171F">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Toast Notification Demo"
                       FontFamily="Segoe UI Black" FontSize="15"
                       Foreground="#00B4FF" VerticalAlignment="Center" Margin="16,0"
                       IsHitTestVisible="False"/>
            <Button Grid.Column="1" Content="×" Width="46" Height="48"
                    Background="Transparent" Foreground="#8899AA" BorderThickness="0"
                    FontSize="18" Click="CloseClick"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>
        <!-- Control panel -->
        <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Padding="28" Width="520"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="0,-40,0,0">
            <StackPanel Spacing="20">
                <TextBlock Text="Fire Toasts" FontFamily="Segoe UI Black" FontSize="20"
                           Foreground="White"/>
                <!-- Type buttons row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ℹ Info"
                            Background="#00B4FF" Foreground="#0A0D12"
                            FontWeight="Bold" Padding="0,10" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,6,0" Click="Fire_Info"/>
                    <Button Grid.Column="1" Content="✔ Success"
                            Background="#00C47A" Foreground="#0A0D12"
                            FontWeight="Bold" Padding="0,10" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,6,0" Click="Fire_Success"/>
                    <Button Grid.Column="2" Content="⚠ Warning"
                            Background="#FFD700" Foreground="#0A0D12"
                            FontWeight="Bold" Padding="0,10" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,6,0" Click="Fire_Warning"/>
                    <Button Grid.Column="3" Content="✖ Error"
                            Background="#FF2D55" Foreground="White"
                            FontWeight="Bold" Padding="0,10" BorderThickness="0"
                            Cursor="Hand" Click="Fire_Error"/>
                </Grid>
                <!-- Options row -->
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <!-- Duration -->
                    <StackPanel>
                        <TextBlock Text="AUTO-DISMISS (sec)" FontSize="9" FontWeight="Bold"
                                   Foreground="#8899AA" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="Dur2Btn"  Content="2s"  Tag="2000"  Padding="10,6"
                                    Background="#1C2333" Foreground="#8899AA"
                                    BorderBrush="#2A3347" BorderThickness="1" Cursor="Hand"
                                    Click="DurBtn_Click"/>
                            <Button x:Name="Dur4Btn"  Content="4s"  Tag="4000"  Padding="10,6"
                                    Background="#0D3A5C" Foreground="#00B4FF"
                                    BorderBrush="#00B4FF" BorderThickness="1" Cursor="Hand"
                                    Click="DurBtn_Click"/>
                            <Button x:Name="Dur8Btn"  Content="8s"  Tag="8000"  Padding="10,6"
                                    Background="#1C2333" Foreground="#8899AA"
                                    BorderBrush="#2A3347" BorderThickness="1" Cursor="Hand"
                                    Click="DurBtn_Click"/>
                            <Button x:Name="DurSticky" Content="Sticky" Tag="0" Padding="10,6"
                                    Background="#1C2333" Foreground="#8899AA"
                                    BorderBrush="#2A3347" BorderThickness="1" Cursor="Hand"
                                    Click="DurBtn_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Position -->
                    <StackPanel>
                        <TextBlock Text="POSITION" FontSize="9" FontWeight="Bold"
                                   Foreground="#8899AA" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="PosTopRight" Content="Top-R" Tag="TopRight" Padding="10,6"
                                    Background="#1C2333" Foreground="#8899AA"
                                    BorderBrush="#2A3347" BorderThickness="1" Cursor="Hand"
                                    Click="PosBtn_Click"/>
                            <Button x:Name="PosBotRight" Content="Bot-R" Tag="BottomRight" Padding="10,6"
                                    Background="#0D3A5C" Foreground="#00B4FF"
                                    BorderBrush="#00B4FF" BorderThickness="1" Cursor="Hand"
                                    Click="PosBtn_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <!-- Counter -->
                <TextBlock x:Name="FiredCount" Text="Toasts fired: 0"
                           FontFamily="Cascadia Code, Consolas" FontSize="12"
                           Foreground="#8899AA"/>
            </StackPanel>
        </Border>
        <!-- Toast host canvas (bottom-right) -->
        <Canvas x:Name="ToastHost" IsHitTestVisible="True"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,20,20" Width="340"/>
    </Grid>
</Window>
