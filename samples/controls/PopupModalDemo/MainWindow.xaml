<Window x:Class="PopupModalDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Popup Modal Demo"
        Width="1000" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0A0D12"
        WindowStartupLocation="CenterScreen">
    <!--
        PopupModalDemo — Three modal/overlay patterns
        ==============================================
        Pattern 1: Confirm/Cancel dialog  — scale-in animation, dim overlay, Esc = cancel
        Pattern 2: Form modal             — title + input fields + validation + save/cancel
        Pattern 3: Detail drawer          — slides in from the right (300px panel)

        All modals are in-window overlays (no separate Window), driven by Visibility.
        The dim overlay is a full-Grid semi-transparent layer on top.
    -->
    <Window.Resources>
        <!-- Shared colors -->
        <SolidColorBrush x:Key="BgPanel"  Color="#12171F"/>
        <SolidColorBrush x:Key="Border1"  Color="#2A3347"/>
        <SolidColorBrush x:Key="Accent"   Color="#00B4FF"/>
        <SolidColorBrush x:Key="Danger"   Color="#FF2D55"/>

        <!-- Scale-in entry animation for modal panels -->
        <Storyboard x:Key="ModalScaleIn">
            <DoubleAnimation Storyboard.TargetName="ModalScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.88" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.88" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ModalPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.18"/>
        </Storyboard>
        <!-- Drawer slide-in from right -->
        <Storyboard x:Key="DrawerSlideIn">
            <DoubleAnimation Storyboard.TargetName="DrawerTranslate"
                             Storyboard.TargetProperty="X"
                             From="320" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="DrawerSlideOut" Completed="DrawerSlideOut_Completed">
            <DoubleAnimation Storyboard.TargetName="DrawerTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="320" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Root grid — content + overlays stacked -->
    <Grid>
        <!-- ── BACKGROUND CONTENT ────────────────────────────── -->
        <Grid>
            <!-- Title bar -->
            <Grid Height="48" VerticalAlignment="Top" Background="#12171F">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Popup Modal Demo — 3 Patterns"
                           FontFamily="Segoe UI Black" FontSize="15"
                           Foreground="#00B4FF" VerticalAlignment="Center" Margin="16,0"
                           IsHitTestVisible="False"/>
                <Button Grid.Column="1" Content="×" Width="46" Height="48"
                        Background="Transparent" Foreground="#8899AA" BorderThickness="0"
                        FontSize="18" Click="CloseClick"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
            <!-- Launch buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Spacing="20">
                <!-- Pattern 1: Confirm dialog -->
                <Border Background="#12171F" BorderBrush="#2A3347"
                        BorderThickness="1" CornerRadius="8" Padding="28,24" Width="260">
                    <StackPanel>
                        <TextBlock Text="1 — Confirm Dialog"
                                   FontFamily="Segoe UI Black" FontSize="13"
                                   Foreground="#00B4FF" Margin="0,0,0,8"/>
                        <TextBlock Text="Scale-in animation, dim overlay, Esc = cancel, Enter = confirm."
                                   FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Button Content="Open Confirm"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" Padding="12,8" BorderThickness="0"
                                Cursor="Hand" Click="OpenConfirm_Click"/>
                        <TextBlock x:Name="ConfirmResult" Text=""
                                   FontFamily="Cascadia Code, Consolas" FontSize="11"
                                   Foreground="#8899AA" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Pattern 2: Form modal -->
                <Border Background="#12171F" BorderBrush="#2A3347"
                        BorderThickness="1" CornerRadius="8" Padding="28,24" Width="260">
                    <StackPanel>
                        <TextBlock Text="2 — Form Modal"
                                   FontFamily="Segoe UI Black" FontSize="13"
                                   Foreground="#00B4FF" Margin="0,0,0,8"/>
                        <TextBlock Text="Input fields with validation, Save / Cancel. Shows collected data."
                                   FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Button Content="Open Form"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" Padding="12,8" BorderThickness="0"
                                Cursor="Hand" Click="OpenForm_Click"/>
                        <TextBlock x:Name="FormResult" Text=""
                                   FontFamily="Cascadia Code, Consolas" FontSize="11"
                                   Foreground="#8899AA" Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <!-- Pattern 3: Drawer -->
                <Border Background="#12171F" BorderBrush="#2A3347"
                        BorderThickness="1" CornerRadius="8" Padding="28,24" Width="260">
                    <StackPanel>
                        <TextBlock Text="3 — Detail Drawer"
                                   FontFamily="Segoe UI Black" FontSize="13"
                                   Foreground="#00B4FF" Margin="0,0,0,8"/>
                        <TextBlock Text="Slides in from the right, partial-dim overlay, click outside to close."
                                   FontSize="11" Foreground="#8899AA" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Button Content="Open Drawer"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" Padding="12,8" BorderThickness="0"
                                Cursor="Hand" Click="OpenDrawer_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ── OVERLAY 1: Confirm Dialog ───────────────────────── -->
        <Grid x:Name="ConfirmOverlay" Visibility="Collapsed" Panel.ZIndex="10"
              Background="#BB000000" KeyDown="Overlay_KeyDown" Focusable="True">
            <Border x:Name="ConfirmPanel" Background="#12171F"
                    BorderBrush="#00B4FF" BorderThickness="1"
                    CornerRadius="10" Padding="28" Width="400"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ModalScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Opacity="0.6" ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Confirm Action" FontFamily="Segoe UI Black" FontSize="18"
                               Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock Text="Are you sure you want to proceed? This action cannot be undone."
                               FontSize="13" Foreground="#8899AA" TextWrapping="Wrap"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="Cancel" Padding="16,8" Cursor="Hand"
                                Background="#1C2333" Foreground="#8899AA"
                                BorderBrush="#2A3347" BorderThickness="1"
                                Click="ConfirmCancel_Click" IsCancel="True"/>
                        <Button Content="Confirm" Padding="16,8" Cursor="Hand"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" BorderThickness="0"
                                Click="ConfirmOK_Click" IsDefault="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── OVERLAY 2: Form Modal ───────────────────────────── -->
        <Grid x:Name="FormOverlay" Visibility="Collapsed" Panel.ZIndex="10"
              Background="#BB000000">
            <Border Background="#12171F" BorderBrush="#00B4FF" BorderThickness="1"
                    CornerRadius="10" Padding="28" Width="440"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Opacity="0.6" ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel Spacing="14">
                    <TextBlock Text="New Entry" FontFamily="Segoe UI Black" FontSize="18"
                               Foreground="White"/>
                    <!-- Name field -->
                    <StackPanel>
                        <TextBlock Text="Name *" FontSize="11" Foreground="#8899AA" Margin="0,0,0,4"/>
                        <Border BorderBrush="#2A3347" BorderThickness="1" CornerRadius="5">
                            <TextBox x:Name="NameField" Background="#1C2333" Foreground="White"
                                     BorderThickness="0" Padding="10,8" FontSize="13"
                                     TextChanged="NameField_TextChanged"/>
                        </Border>
                        <TextBlock x:Name="NameError" Text="Name is required."
                                   Foreground="#FF2D55" FontSize="10" Margin="0,2,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                    <!-- Category field -->
                    <StackPanel>
                        <TextBlock Text="Category" FontSize="11" Foreground="#8899AA" Margin="0,0,0,4"/>
                        <Border BorderBrush="#2A3347" BorderThickness="1" CornerRadius="5">
                            <ComboBox x:Name="CategoryField" Background="#1C2333"
                                      Foreground="White" BorderThickness="0" FontSize="13">
                                <ComboBoxItem Content="Operations" IsSelected="True"/>
                                <ComboBoxItem Content="Security"/>
                                <ComboBoxItem Content="Analytics"/>
                                <ComboBoxItem Content="Reports"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                    <!-- Notes field -->
                    <StackPanel>
                        <TextBlock Text="Notes" FontSize="11" Foreground="#8899AA" Margin="0,0,0,4"/>
                        <Border BorderBrush="#2A3347" BorderThickness="1" CornerRadius="5">
                            <TextBox x:Name="NotesField" Background="#1C2333" Foreground="White"
                                     BorderThickness="0" Padding="10,8" FontSize="13"
                                     AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="Cancel" Padding="16,8" Cursor="Hand"
                                Background="#1C2333" Foreground="#8899AA"
                                BorderBrush="#2A3347" BorderThickness="1"
                                Click="FormCancel_Click"/>
                        <Button Content="Save" Padding="16,8" Cursor="Hand"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" BorderThickness="0"
                                Click="FormSave_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── OVERLAY 3: Detail Drawer ─────────────────────────── -->
        <Grid x:Name="DrawerOverlay" Visibility="Collapsed" Panel.ZIndex="10">
            <!-- Partial-dim backdrop — click closes drawer -->
            <Border Background="#66000000" MouseDown="DrawerBackdrop_MouseDown"/>
            <!-- Drawer panel -->
            <Border x:Name="DrawerPanel" Width="320" HorizontalAlignment="Right"
                    Background="#12171F" BorderBrush="#00B4FF"
                    BorderThickness="1,0,0,0" Padding="24">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="DrawerTranslate" X="320"/>
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Detail View" FontFamily="Segoe UI Black" FontSize="18"
                                   Foreground="White"/>
                        <Button Content="×" HorizontalAlignment="Right"
                                Background="Transparent" Foreground="#8899AA"
                                BorderThickness="0" FontSize="18" Padding="4" Cursor="Hand"
                                Click="CloseDrawer_Click"/>
                    </Grid>
                    <!-- Drawer content -->
                    <TextBlock Text="ITEM DETAILS" FontSize="9" FontWeight="Bold"
                               Foreground="#00B4FF" Margin="0,0,0,12"/>
                    <StackPanel Spacing="10">
                        <Grid>
                            <TextBlock Text="ID" FontSize="12" Foreground="#8899AA"/>
                            <TextBlock Text="#A-2047" HorizontalAlignment="Right"
                                       FontFamily="Cascadia Code, Consolas"
                                       FontSize="12" Foreground="White"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#2A3347"/>
                        <Grid>
                            <TextBlock Text="Status" FontSize="12" Foreground="#8899AA"/>
                            <Border HorizontalAlignment="Right" Background="#0D3A5C"
                                    BorderBrush="#00B4FF" BorderThickness="1" CornerRadius="4"
                                    Padding="8,2">
                                <TextBlock Text="Active" FontSize="11" Foreground="#00B4FF"/>
                            </Border>
                        </Grid>
                        <Rectangle Height="1" Fill="#2A3347"/>
                        <Grid>
                            <TextBlock Text="Priority" FontSize="12" Foreground="#8899AA"/>
                            <TextBlock Text="High" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="#FF9500" FontWeight="SemiBold"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#2A3347"/>
                        <Grid>
                            <TextBlock Text="Assigned" FontSize="12" Foreground="#8899AA"/>
                            <TextBlock Text="Maverick" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                    <!-- Action buttons -->
                    <StackPanel Spacing="8" Margin="0,28,0,0">
                        <Button Content="Edit Entry" HorizontalAlignment="Stretch"
                                Background="#00B4FF" Foreground="#0A0D12"
                                FontWeight="Bold" Padding="12,8" BorderThickness="0" Cursor="Hand"
                                Click="DrawerEdit_Click"/>
                        <Button Content="Delete" HorizontalAlignment="Stretch"
                                Background="#1C2333" Foreground="#FF2D55"
                                BorderBrush="#FF2D55" BorderThickness="1" Padding="12,8" Cursor="Hand"
                                Click="DrawerDelete_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
