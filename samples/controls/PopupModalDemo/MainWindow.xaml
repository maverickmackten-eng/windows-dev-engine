<Window x:Class="PopupModalDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Popup Modal Demo" Height="700" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Border Background="#0A0D12" BorderBrush="#2A3347" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="32"/>  <!-- Status bar -->
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="#12171F" MouseLeftButtonDown="TitleBar_MouseDown">
        <TextBlock Text="POPUP &amp; MODAL DEMO" FontFamily="Segoe UI Black" FontSize="13"
                   Foreground="#00B4FF" LetterSpacing="2"
                   VerticalAlignment="Center" Margin="16,0"/>
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                Foreground="#FF2D55" Background="Transparent" BorderThickness="0"
                Width="40" Height="48" HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
      </Grid>

      <!-- Three demo buttons -->
      <StackPanel Grid.Row="1" Orientation="Horizontal"
                  HorizontalAlignment="Center" VerticalAlignment="Center">

        <Button Content="&#xE8A0;  SLIDE PANEL" Margin="0,0,16,0"
                Background="#12171F" Foreground="#FFFFFF"
                BorderBrush="#3D5A8A" BorderThickness="1"
                Padding="20,12" FontSize="13"
                Click="BtnSlidePanel_Click"/>

        <Button Content="&#xE8C8;  CENTER MODAL" Margin="0,0,16,0"
                Background="#12171F" Foreground="#FFFFFF"
                BorderBrush="#3D5A8A" BorderThickness="1"
                Padding="20,12" FontSize="13"
                Click="BtnCenterModal_Click"/>

        <Button Content="&#xE74D;  CONFIRM BOX"
                Background="#1A0A0A" Foreground="#FF6B35"
                BorderBrush="#FF6B35" BorderThickness="1"
                Padding="20,12" FontSize="13"
                Click="BtnConfirmBox_Click"/>
      </StackPanel>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#0D1117">
        <TextBlock x:Name="txtStatus" Text="Click a button to see the interaction pattern"
                   Foreground="#8899AA" FontSize="12"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center" Margin="16,0"/>
      </Border>

      <!-- ══════════════════════════════════════════════════
           PATTERN 1: Slide-in right panel
           TranslateTransform animated X: +350 (off-screen) to 0
      ══════════════════════════════════════════════════ -->
      <Grid x:Name="slidePanelHost" Grid.RowSpan="3" Visibility="Collapsed">
        <!-- Dim overlay — click to close -->
        <Rectangle Fill="#88000000" MouseLeftButtonDown="Overlay_Close"
                   IsHitTestVisible="True"/>
        <!-- Panel -->
        <Border x:Name="slidePanel"
                Width="350" HorizontalAlignment="Right"
                Background="#1C2333" BorderBrush="#3D5A8A" BorderThickness="1,0,0,0"
                Padding="24">
          <Border.RenderTransform>
            <TranslateTransform x:Name="slidePanelTranslate" X="350"/>
          </Border.RenderTransform>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
              <TextBlock Text="SLIDE PANEL" FontFamily="Segoe UI Black"
                         FontSize="16" Foreground="#FFFFFF"/>
              <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                      Foreground="#8899AA" Background="Transparent" BorderThickness="0"
                      HorizontalAlignment="Right" Width="32"
                      Click="SlidePanel_Close"/>
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="This panel slides in from the right edge. Click the dim overlay or X to close it."
                       Foreground="#8899AA" FontSize="13"
                       TextWrapping="Wrap" Margin="0,16,0,0"/>
            <Button Grid.Row="2" Content="CLOSE PANEL"
                    Background="Transparent" Foreground="#00B4FF"
                    BorderBrush="#00B4FF" BorderThickness="1"
                    Padding="16,8" HorizontalAlignment="Right"
                    Click="SlidePanel_Close"/>
          </Grid>
        </Border>
      </Grid>

      <!-- ══════════════════════════════════════════════════
           PATTERN 2: Center modal
           Scale 0.8→1.0 + fade in on open
      ══════════════════════════════════════════════════ -->
      <Grid x:Name="centerModalHost" Grid.RowSpan="3" Visibility="Collapsed"
            Background="#88000000">
        <Border x:Name="centerModal"
                Background="#1C2333" BorderBrush="#3D5A8A" BorderThickness="1"
                CornerRadius="10" Padding="32" MaxWidth="480"
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border.RenderTransform>
            <ScaleTransform x:Name="modalScale" ScaleX="0.85" ScaleY="0.85"
                            CenterX="240" CenterY="120"/>
          </Border.RenderTransform>
          <StackPanel>
            <Grid Margin="0,0,0,16">
              <TextBlock Text="CENTER MODAL" FontFamily="Segoe UI Black"
                         FontSize="18" Foreground="#FFFFFF"/>
              <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                      Foreground="#8899AA" Background="Transparent" BorderThickness="0"
                      HorizontalAlignment="Right" Width="32"
                      Click="CenterModal_Close"/>
            </Grid>
            <TextBlock Text="This dialog scales in from 85% → 100% with a fade. Press ESC or click X to close."
                       Foreground="#8899AA" FontSize="13" TextWrapping="Wrap"
                       Margin="0,0,0,24"/>
            <Button Content="CLOSE MODAL"
                    Background="#00B4FF" Foreground="#000000"
                    BorderThickness="0" Padding="20,10"
                    HorizontalAlignment="Right" FontWeight="Bold"
                    Click="CenterModal_Close"/>
          </StackPanel>
        </Border>
      </Grid>

    </Grid>
  </Border>
</Window>
