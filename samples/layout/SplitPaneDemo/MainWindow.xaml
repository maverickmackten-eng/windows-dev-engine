<Window x:Class="SplitPaneDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Pane Demo"
        Width="1280" Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0A0D12"
        WindowStartupLocation="CenterScreen">
    <!--
        SplitPaneDemo
        =============
        Three layout modes toggled via tab buttons:
          1. Horizontal — left list / right detail (1 vertical GridSplitter)
          2. Vertical   — top editor / bottom log  (1 horizontal GridSplitter)
          3. Triple     — tree / main / props       (2 vertical GridSplitters)

        Splitter styling: 5px, dark bg, hover accent #00B4FF, drag-handle dots.
        Double-click a splitter resets panes to equal size.
        MinWidth/MinHeight guards prevent pane collapse.
    -->
    <Window.Resources>
        <!-- Vertical splitter style -->
        <Style x:Key="VSplitter" TargetType="GridSplitter">
            <Setter Property="Width"               Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment"   Value="Stretch"/>
            <Setter Property="Background"          Value="#1E2D3D"/>
            <Setter Property="Cursor"              Value="SizeWE"/>
            <Setter Property="ResizeBehavior"      Value="PreviousAndNext"/>
        </Style>
        <!-- Horizontal splitter style -->
        <Style x:Key="HSplitter" TargetType="GridSplitter">
            <Setter Property="Height"              Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment"   Value="Stretch"/>
            <Setter Property="Background"          Value="#1E2D3D"/>
            <Setter Property="Cursor"              Value="SizeNS"/>
            <Setter Property="ResizeBehavior"      Value="PreviousAndNext"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#12171F">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Split Pane Demo"
                       FontFamily="Segoe UI Black" FontSize="15"
                       Foreground="#00B4FF" VerticalAlignment="Center" Margin="16,0"
                       IsHitTestVisible="False"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Width="46" Height="48" Background="Transparent"
                        Foreground="#8899AA" BorderThickness="0" FontSize="14" Click="MinimizeClick"/>
                <Button Content="×" Width="46" Height="48" Background="Transparent"
                        Foreground="#8899AA" BorderThickness="0" FontSize="18" Click="CloseClick"/>
            </StackPanel>
        </Grid>
        <!-- Layout selector -->
        <Border Grid.Row="1" Background="#0E1318"
                BorderBrush="#1E2D3D" BorderThickness="0,0,0,1" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <Button x:Name="BtnH" Content="Horizontal Split" Tag="H" Click="LayoutBtn_Click"
                        Background="#0D3A5C" Foreground="#00B4FF" BorderBrush="#00B4FF"
                        BorderThickness="1" Padding="14,6" Cursor="Hand"/>
                <Button x:Name="BtnV" Content="Vertical Split"   Tag="V" Click="LayoutBtn_Click"
                        Background="#1C2333" Foreground="#8899AA" BorderBrush="#2A3347"
                        BorderThickness="1" Padding="14,6" Cursor="Hand"/>
                <Button x:Name="BtnT" Content="Triple Split"     Tag="T" Click="LayoutBtn_Click"
                        Background="#1C2333" Foreground="#8899AA" BorderBrush="#2A3347"
                        BorderThickness="1" Padding="14,6" Cursor="Hand"/>
                <TextBlock Text="Tip: drag splitter to resize — double-click to reset to equal"
                           FontSize="11" Foreground="#445566"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>
        <!-- Dynamic split content host -->
        <ContentControl Grid.Row="2" x:Name="SplitHost"/>
    </Grid>
</Window>
