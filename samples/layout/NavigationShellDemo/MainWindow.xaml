<Window x:Class="NavigationShellDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Navigation Shell Demo"
        Width="1280" Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#0A0D12"
        WindowStartupLocation="CenterScreen">
    <!--
        NavigationShellDemo
        ===================
        Layout:   Fixed sidebar (200px) + content area
        Nav:      5 nav items, active item highlighted with accent left-border
        Pages:    Each page is a UserControl swapped into ContentHost
        Anim:     Fade-out old page, translate+fade-in new page (150ms each)
        Collapse: Sidebar collapses to 52px icon-only mode via toggle button
    -->
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgDeep"    Color="#0A0D12"/>
        <SolidColorBrush x:Key="BgSide"    Color="#0E1318"/>
        <SolidColorBrush x:Key="BgPanel"   Color="#12171F"/>
        <SolidColorBrush x:Key="Border1"   Color="#1E2D3D"/>
        <SolidColorBrush x:Key="Accent"    Color="#00B4FF"/>
        <SolidColorBrush x:Key="TextPri"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSec"   Color="#8899AA"/>

        <!-- Nav item style -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="#8899AA"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="0"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Height"                 Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Active left-border accent -->
                            <Border x:Name="ActiveBar" Width="3"
                                    HorizontalAlignment="Left"
                                    Background="#00B4FF"
                                    Opacity="0" CornerRadius="0,2,2,0"/>
                            <!-- Hover/active bg -->
                            <Border x:Name="Bg" Background="Transparent"
                                    Margin="3,0,0,0">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#0F1E2D"/>
                                <Setter Property="Foreground" Value="#CCDDEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Page fade-in animation (applied in code) -->
        <Storyboard x:Key="PageFadeIn">
            <DoubleAnimation Storyboard.TargetName="ContentHost"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="PageTranslate"
                             Storyboard.TargetProperty="X"
                             From="18" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Sidebar collapse animation -->
        <Storyboard x:Key="SideCollapse">
            <DoubleAnimation Storyboard.TargetName="Sidebar"
                             Storyboard.TargetProperty="Width"
                             To="52" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SideExpand">
            <DoubleAnimation Storyboard.TargetName="Sidebar"
                             Storyboard.TargetProperty="Width"
                             To="200" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- title bar -->
            <RowDefinition Height="*"/>   <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── TITLE BAR ─────────────────────────────── -->
        <Grid Grid.Row="0" Background="#0E1318">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>   <!-- aligns with sidebar -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="DEV ENGINE"
                       FontFamily="Segoe UI Black" FontSize="13"
                       Foreground="#00B4FF" VerticalAlignment="Center" Margin="16,0"
                       IsHitTestVisible="False"/>
            <TextBlock Grid.Column="1" x:Name="PageTitleBar"
                       Text="Dashboard" FontFamily="Segoe UI" FontSize="13"
                       Foreground="#8899AA" VerticalAlignment="Center" Margin="20,0"
                       IsHitTestVisible="False"/>
            <!-- Window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Width="46" Height="48" Background="Transparent"
                        Foreground="#8899AA" BorderThickness="0" FontSize="14"
                        Click="MinimizeClick"/>
                <Button Content="×" Width="46" Height="48" Background="Transparent"
                        Foreground="#8899AA" BorderThickness="0" FontSize="18"
                        Click="CloseClick"/>
            </StackPanel>
        </Grid>

        <!-- ── BODY ─────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" x:Name="SidebarCol"/>  <!-- sidebar -->
                <ColumnDefinition Width="*"/>                        <!-- content -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border x:Name="Sidebar" Grid.Column="0"
                    Background="#0E1318"
                    BorderBrush="#1E2D3D" BorderThickness="0,0,1,0"
                    Width="200" ClipToBounds="True">
                <Grid>
                    <StackPanel Margin="0,8,0,0">
                        <!-- Nav items -->
                        <Button x:Name="NavDashboard" Style="{StaticResource NavItem}"
                                Tag="Dashboard" Click="NavItem_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblDashboard" Text="Dashboard"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavOps" Style="{StaticResource NavItem}"
                                Tag="Operations" Click="NavItem_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="&#xECAA;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblOps" Text="Operations"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavAnalytics" Style="{StaticResource NavItem}"
                                Tag="Analytics" Click="NavItem_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblAnalytics" Text="Analytics"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSecurity" Style="{StaticResource NavItem}"
                                Tag="Security" Click="NavItem_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblSecurity" Text="Security"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSettings" Style="{StaticResource NavItem}"
                                Tag="Settings" Click="NavItem_Click">
                            <StackPanel Orientation="Horizontal" Margin="14,0">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Width="28" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblSettings" Text="Settings"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Collapse toggle (bottom of sidebar) -->
                    <Button x:Name="CollapseBtn"
                            VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                            Height="44" Background="Transparent" BorderThickness="0"
                            Foreground="#445566" Cursor="Hand"
                            Click="CollapseBtn_Click">
                        <TextBlock x:Name="CollapseIcon" Text="&#xE761;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT HOST -->
            <Border Grid.Column="1" Background="#0A0D12">
                <ContentControl x:Name="ContentHost" Opacity="1">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="PageTranslate" X="0"/>
                    </ContentControl.RenderTransform>
                </ContentControl>
            </Border>
        </Grid>
    </Grid>
</Window>
