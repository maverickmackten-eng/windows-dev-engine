<Window x:Class="MaverickMach10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commander Maverick — Mach 10"
        Width="1200" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#060A14" CornerRadius="12"
            BorderBrush="#1A3050" BorderThickness="1">

        <Canvas x:Name="scene" ClipToBounds="True">

            <!-- Sky gradient — high altitude blue -->
            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="1200" Height="600">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#020408" Offset="0"/>
                        <GradientStop Color="#061020" Offset="0.3"/>
                        <GradientStop Color="#0A2040" Offset="0.7"/>
                        <GradientStop Color="#153060" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Stars at altitude -->
            <Ellipse Canvas.Left="100" Canvas.Top="30" Width="2" Height="2" Fill="#AAFFFF" Opacity="0.7"/>
            <Ellipse Canvas.Left="250" Canvas.Top="55" Width="3" Height="3" Fill="#FFFFFF" Opacity="0.5"/>
            <Ellipse Canvas.Left="450" Canvas.Top="20" Width="2" Height="2" Fill="#CCFFFF" Opacity="0.6"/>
            <Ellipse Canvas.Left="700" Canvas.Top="40" Width="2" Height="2" Fill="#FFFFFF" Opacity="0.4"/>
            <Ellipse Canvas.Left="900" Canvas.Top="25" Width="3" Height="3" Fill="#AAFFFF" Opacity="0.7"/>
            <Ellipse Canvas.Left="1050" Canvas.Top="60" Width="2" Height="2" Fill="#FFFFFF" Opacity="0.5"/>

            <!-- Horizon glow -->
            <Rectangle Canvas.Left="0" Canvas.Top="380" Width="1200" Height="220">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#1500AAFF" Offset="0.4"/>
                        <GradientStop Color="#2000AAFF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Clouds far below (streaks at high speed) -->
            <Canvas x:Name="cloudStreak1" Canvas.Left="0" Canvas.Top="420">
                <Rectangle Width="300" Height="6" Fill="#10FFFFFF" RadiusX="3" RadiusY="3"/>
            </Canvas>
            <Canvas x:Name="cloudStreak2" Canvas.Left="400" Canvas.Top="450">
                <Rectangle Width="200" Height="4" Fill="#0CFFFFFF" RadiusX="2" RadiusY="2"/>
            </Canvas>
            <Canvas x:Name="cloudStreak3" Canvas.Left="800" Canvas.Top="480">
                <Rectangle Width="250" Height="5" Fill="#0EFFFFFF" RadiusX="2" RadiusY="2"/>
            </Canvas>
            <Canvas x:Name="cloudStreak4" Canvas.Left="200" Canvas.Top="500">
                <Rectangle Width="180" Height="3" Fill="#08FFFFFF" RadiusX="2" RadiusY="2"/>
            </Canvas>

            <!-- ═══ JET ═══ -->
            <Canvas x:Name="jetContainer" Canvas.Left="-300" Canvas.Top="220">

                <!-- Afterburner glow (behind engine) -->
                <Canvas x:Name="afterburner" Canvas.Left="200" Canvas.Top="22">
                    <Ellipse Width="120" Height="18">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFF88" Offset="0"/>
                                <GradientStop Color="#FF6600" Offset="0.3"/>
                                <GradientStop Color="#FF330080" Offset="0.7"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>

                <!-- Shock diamonds (Mach speed visual) -->
                <Canvas x:Name="shockDiamonds" Canvas.Left="220" Canvas.Top="28" Opacity="0.7">
                    <Ellipse Canvas.Left="0"   Width="16" Height="8" Fill="#AAFFDD"/>
                    <Ellipse Canvas.Left="20"  Width="12" Height="6" Fill="#88FFBB" Opacity="0.7"/>
                    <Ellipse Canvas.Left="36"  Width="10" Height="5" Fill="#66FFAA" Opacity="0.5"/>
                    <Ellipse Canvas.Left="50"  Width="8"  Height="4" Fill="#44FF88" Opacity="0.3"/>
                    <Ellipse Canvas.Left="62"  Width="6"  Height="3" Fill="#22FF66" Opacity="0.2"/>
                </Canvas>

                <!-- F-18 / F-22 style fuselage -->
                <Path Fill="#1C2A3A" Stroke="#2A4060" StrokeThickness="1">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="200,30">
                                <!-- Nose -->
                                <BezierSegment Point1="180,30" Point2="80,25" Point3="0,28"/>
                                <BezierSegment Point1="-30,29" Point2="-50,30" Point3="-60,30"/>
                                <!-- Bottom -->
                                <BezierSegment Point1="-50,32" Point2="-30,33" Point3="0,32"/>
                                <BezierSegment Point1="80,35" Point2="180,31" Point3="200,30"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Cockpit canopy -->
                <Path Fill="#112233">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="80,28">
                                <BezierSegment Point1="100,18" Point2="130,16" Point3="150,20"/>
                                <BezierSegment Point1="160,22" Point2="160,28" Point3="155,29"/>
                                <BezierSegment Point1="140,30" Point2="110,30" Point3="80,28"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                    <Path.Effect>
                        <DropShadowEffect Color="#00AAFF" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                    </Path.Effect>
                </Path>

                <!-- Canopy reflection -->
                <Path Fill="#1A00B4FF" Stroke="Transparent">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="90,22">
                                <BezierSegment Point1="110,18" Point2="135,17" Point3="148,21"/>
                                <BezierSegment Point1="135,21" Point2="110,21" Point3="90,22"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Main delta wings -->
                <Path Fill="#141E2A" Stroke="#1E2E40" StrokeThickness="1">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="160,30">
                                <LineSegment Point="40,30"/>
                                <LineSegment Point="30,80"/>
                                <LineSegment Point="160,35"/>
                                <LineSegment Point="160,30"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>
                <Path Fill="#141E2A" Stroke="#1E2E40" StrokeThickness="1">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="160,30">
                                <LineSegment Point="40,30"/>
                                <LineSegment Point="30,-20"/>
                                <LineSegment Point="160,25"/>
                                <LineSegment Point="160,30"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Tail fins -->
                <Polygon Points="200,25 185,5 195,25" Fill="#1A2A38" Stroke="#2A3A50" StrokeThickness="1"/>
                <Polygon Points="200,35 185,55 195,35" Fill="#1A2A38" Stroke="#2A3A50" StrokeThickness="1"/>

                <!-- Engine nacelles -->
                <Rectangle Canvas.Left="160" Canvas.Top="25" Width="50" Height="10" Fill="#0F1820" RadiusX="3" RadiusY="3"/>

                <!-- Maverick callsign on fuselage -->
                <TextBlock Canvas.Left="70" Canvas.Top="21"
                           Text="MAVERICK" Foreground="#AADDFF"
                           FontFamily="Consolas" FontSize="7" FontWeight="Bold"/>

                <!-- Speed lines / motion blur -->
                <Canvas x:Name="speedLines" Canvas.Left="150" Canvas.Top="0" Opacity="0.4">
                    <Line X1="0" Y1="10" X2="300" Y2="10" Stroke="#22AAFFFF" StrokeThickness="1"/>
                    <Line X1="0" Y1="20" X2="250" Y2="20" Stroke="#1500AAFF" StrokeThickness="0.5"/>
                    <Line X1="0" Y1="32" X2="280" Y2="32" Stroke="#1100BBFF" StrokeThickness="1"/>
                    <Line X1="0" Y1="42" X2="220" Y2="42" Stroke="#1500AAFF" StrokeThickness="0.5"/>
                    <Line X1="0" Y1="50" X2="260" Y2="50" Stroke="#1100CCFF" StrokeThickness="1"/>
                </Canvas>

                <!-- Sonic boom ring (appears at high speed) -->
                <Ellipse x:Name="sonicBoom"
                         Canvas.Left="70" Canvas.Top="-30"
                         Width="2" Height="120"
                         Stroke="#5500FFFF" StrokeThickness="2"
                         Fill="Transparent"
                         Opacity="0">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#00FFFF" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                    </Ellipse.Effect>
                </Ellipse>

            </Canvas>

            <!-- HUD-style display -->
            <Border Canvas.Left="20" Canvas.Top="20"
                    Background="#11002233" BorderBrush="#3300AAFF"
                    BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="CALLSIGN: MAVERICK" Foreground="#00CCFF"
                               FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="SPEED: MACH 10.0" Foreground="#00FF88"
                               FontFamily="Consolas" FontSize="10"/>
                    <TextBlock Text="ALT: 62,000 FT" Foreground="#00FF88"
                               FontFamily="Consolas" FontSize="10"/>
                    <TextBlock Text="HEADING: 090°" Foreground="#FFCC00"
                               FontFamily="Consolas" FontSize="10"/>
                    <TextBlock Text="STATUS: ENGAGED" Foreground="#FF4444"
                               FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Mach number display -->
            <TextBlock Canvas.Left="1000" Canvas.Top="20"
                       Text="MACH" Foreground="#334455"
                       FontFamily="Consolas" FontSize="12"/>
            <TextBlock x:Name="machDisplay"
                       Canvas.Left="960" Canvas.Top="35"
                       Text="10.0" Foreground="#00FFCC"
                       FontFamily="Consolas" FontSize="48" FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#00FFCC" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Close hint -->
            <TextBlock Canvas.Left="20" Canvas.Top="565"
                       Text="ESC to close"
                       Foreground="#33FFFFFF"
                       FontFamily="Consolas" FontSize="9"/>

        </Canvas>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard x:Name="flightStoryboard">
                <Storyboard>
                    <!-- Jet screams across left to right very fast -->
                    <DoubleAnimation
                        Storyboard.TargetName="jetContainer"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="-300" To="1300"
                        Duration="0:0:3"
                        RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <ExponentialEase EasingMode="EaseIn" Exponent="2"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Jet banks slightly on approach -->
                    <DoubleAnimation
                        Storyboard.TargetName="jetContainer"
                        Storyboard.TargetProperty="(Canvas.Top)"
                        From="250" To="200"
                        Duration="0:0:3"
                        RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Afterburner pulses -->
                    <DoubleAnimation
                        Storyboard.TargetName="afterburner"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="200" To="190"
                        Duration="0:0:0.15"
                        RepeatBehavior="Forever"
                        AutoReverse="True"/>

                    <!-- Sonic boom ring expands -->
                    <DoubleAnimationUsingKeyFrames
                        Storyboard.TargetName="sonicBoom"
                        Storyboard.TargetProperty="Opacity"
                        RepeatBehavior="Forever">
                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.8"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <DoubleAnimationUsingKeyFrames
                        Storyboard.TargetName="sonicBoom"
                        Storyboard.TargetProperty="Width"
                        RepeatBehavior="Forever">
                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="2"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="200"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3" Value="2"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Cloud streaks fly past (right to left — parallax) -->
                    <DoubleAnimation
                        Storyboard.TargetName="cloudStreak1"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="1200" To="-400"
                        Duration="0:0:1.5"
                        RepeatBehavior="Forever"/>
                    <DoubleAnimation
                        Storyboard.TargetName="cloudStreak2"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="1200" To="-300"
                        Duration="0:0:1.1"
                        RepeatBehavior="Forever"/>
                    <DoubleAnimation
                        Storyboard.TargetName="cloudStreak3"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="1200" To="-350"
                        Duration="0:0:1.3"
                        RepeatBehavior="Forever"/>
                    <DoubleAnimation
                        Storyboard.TargetName="cloudStreak4"
                        Storyboard.TargetProperty="(Canvas.Left)"
                        From="1200" To="-280"
                        Duration="0:0:0.9"
                        RepeatBehavior="Forever"/>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
