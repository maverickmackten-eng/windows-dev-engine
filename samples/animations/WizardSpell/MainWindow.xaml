<Window x:Class="WizardSpell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wizard Casting Spell"
        Width="900" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#08030F" CornerRadius="12"
            BorderBrush="#3A1A5A" BorderThickness="1">

        <Canvas x:Name="scene" ClipToBounds="True">

            <!-- Deep arcane background -->
            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="900" Height="700">
                <Rectangle.Fill>
                    <RadialGradientBrush Center="0.5,0.6" GradientOrigin="0.5,0.6" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="#140830" Offset="0"/>
                        <GradientStop Color="#08030F" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Ground/floor plane -->
            <Rectangle Canvas.Left="0" Canvas.Top="580" Width="900" Height="120">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0F0820" Offset="0"/>
                        <GradientStop Color="#05030A" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ═══ MAGIC CIRCLE ON FLOOR ═══ -->
            <Canvas Canvas.Left="350" Canvas.Top="510">
                <!-- Outer ring -->
                <Ellipse Width="300" Height="80" Canvas.Left="-150" Canvas.Top="-40"
                         Stroke="#6600AA" StrokeThickness="2" Fill="Transparent">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#AA00FF" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="outerCircleRot" CenterX="150" CenterY="40"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- Inner ring -->
                <Ellipse Width="200" Height="54" Canvas.Left="-100" Canvas.Top="-27"
                         Stroke="#9900CC" StrokeThickness="1.5" Fill="Transparent">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="innerCircleRot" CenterX="100" CenterY="27"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <!-- Glow fill -->
                <Ellipse Width="220" Height="58" Canvas.Left="-110" Canvas.Top="-29">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#1AAA00FF" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Rune marks at cardinal points -->
                <TextBlock Canvas.Left="-8" Canvas.Top="-60" Text="✦" Foreground="#CC00FF" FontSize="16"/>
                <TextBlock Canvas.Left="140" Canvas.Top="-10" Text="⬡" Foreground="#9900CC" FontSize="12"/>
                <TextBlock Canvas.Left="-160" Canvas.Top="-10" Text="⬡" Foreground="#9900CC" FontSize="12"/>
                <TextBlock Canvas.Left="-8" Canvas.Top="35" Text="✦" Foreground="#CC00FF" FontSize="16"/>
            </Canvas>

            <!-- ═══ ARCANE CIRCLES (rotating in center) ═══ -->
            <Canvas Canvas.Left="450" Canvas.Top="300">
                <!-- Large outer circle -->
                <Ellipse x:Name="arcCircle1"
                         Width="280" Height="280" Canvas.Left="-140" Canvas.Top="-140"
                         Stroke="#7700BB" StrokeThickness="2"
                         StrokeDashArray="8 4"
                         Fill="Transparent"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="arcCircle1Rot"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#9900FF" BlurRadius="12" ShadowDepth="0" Opacity="0.6"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Medium circle (opposite direction) -->
                <Ellipse x:Name="arcCircle2"
                         Width="200" Height="200" Canvas.Left="-100" Canvas.Top="-100"
                         Stroke="#AA44FF" StrokeThickness="1.5"
                         StrokeDashArray="4 8"
                         Fill="Transparent"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="arcCircle2Rot"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#CC66FF" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Inner glowing orb -->
                <Ellipse Width="80" Height="80" Canvas.Left="-40" Canvas.Top="-40">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#EEDDFF" Offset="0"/>
                            <GradientStop Color="#9900FF" Offset="0.4"/>
                            <GradientStop Color="#5500AA" Offset="0.7"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#AA00FF" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Orb core (pulsing) -->
                <Ellipse x:Name="orbCore" Width="30" Height="30" Canvas.Left="-15" Canvas.Top="-15" Fill="White">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FFFFFF" BlurRadius="20" ShadowDepth="0" Opacity="1"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Energy beam going up -->
                <Rectangle x:Name="energyBeam"
                           Canvas.Left="-4" Canvas.Top="-400"
                           Width="8" Height="400">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#AA9900FF" Offset="0.6"/>
                            <GradientStop Color="#EEDDFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#AA00FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                    </Rectangle.Effect>
                </Rectangle>

                <!-- Spark particles (simplified as small ellipses positioned around orbit) -->
                <Canvas x:Name="sparks" RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="sparksRot"/>
                    </Canvas.RenderTransform>
                    <Ellipse Canvas.Left="120" Canvas.Top="-5" Width="6" Height="6" Fill="#FFAAFF" Opacity="0.9"/>
                    <Ellipse Canvas.Left="-130" Canvas.Top="-5" Width="4" Height="4" Fill="#AAFFDD" Opacity="0.7"/>
                    <Ellipse Canvas.Left="-5" Canvas.Top="-130" Width="5" Height="5" Fill="#FFDDFF" Opacity="0.8"/>
                    <Ellipse Canvas.Left="-5" Canvas.Top="120"  Width="4" Height="4" Fill="#CCAAFF" Opacity="0.6"/>
                    <Ellipse Canvas.Left="85" Canvas.Top="-90" Width="3" Height="3" Fill="#FFFFFF" Opacity="0.9"/>
                    <Ellipse Canvas.Left="-95" Canvas.Top="80"  Width="3" Height="3" Fill="#DDAAFF" Opacity="0.8"/>
                    <Ellipse Canvas.Left="80" Canvas.Top="80"   Width="4" Height="4" Fill="#FFCCFF" Opacity="0.7"/>
                    <Ellipse Canvas.Left="-95" Canvas.Top="-85" Width="3" Height="3" Fill="#AADDFF" Opacity="0.9"/>
                </Canvas>

            </Canvas>

            <!-- ═══ WIZARD SILHOUETTE ═══ -->
            <Canvas Canvas.Left="150" Canvas.Top="300">
                <!-- Robe body -->
                <Path Fill="#0D0520">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="30,20">
                                <BezierSegment Point1="20,80" Point2="10,180" Point3="0,280"/>
                                <LineSegment Point="80,280"/>
                                <BezierSegment Point1="80,180" Point2="75,80" Point3="70,20"/>
                                <BezierSegment Point1="60,10" Point2="40,10" Point3="30,20"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Wizard head -->
                <Ellipse Canvas.Left="20" Canvas.Top="-10" Width="40" Height="45" Fill="#1A0D05"/>

                <!-- Wizard hat (tall, pointed) -->
                <Polygon Points="40,-10 55,20 25,20" Fill="#0D0520"/>
                <Rectangle Canvas.Left="18" Canvas.Top="17" Width="44" Height="8" Fill="#120A25"/>

                <!-- Staff arm (outstretched) -->
                <Path Stroke="#1A0D05" StrokeThickness="8" Fill="Transparent"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                    <Path.Data>
                        <PathGeometry>
                            <PathFigure StartPoint="60,60">
                                <BezierSegment Point1="180,20" Point2="280,10" Point3="300,-20"/>
                            </PathFigure>
                        </PathGeometry>
                    </Path.Data>
                </Path>

                <!-- Staff top gem glow -->
                <Ellipse Canvas.Left="295" Canvas.Top="-35" Width="20" Height="20">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#AA00FF" Offset="0.5"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#AA00FF" BlurRadius="25" ShadowDepth="0" Opacity="1"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Robe stars/decoration -->
                <TextBlock Canvas.Left="25" Canvas.Top="80" Text="✦" Foreground="#2A1A40" FontSize="10"/>
                <TextBlock Canvas.Left="50" Canvas.Top="130" Text="★" Foreground="#1A0D30" FontSize="8"/>
                <TextBlock Canvas.Left="30" Canvas.Top="180" Text="✦" Foreground="#2A1A40" FontSize="10"/>
            </Canvas>

            <!-- Title -->
            <TextBlock Canvas.Left="30" Canvas.Top="25"
                       Text="WIZARD CASTING ARCANE SPELL"
                       Foreground="#8833AA"
                       FontFamily="Georgia"
                       FontSize="20"
                       FontStyle="Italic"
                       FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#AA00FF" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Canvas.Left="30" Canvas.Top="660"
                       Text="ESC to close"
                       Foreground="#33FFFFFF"
                       FontFamily="Consolas" FontSize="9"/>

        </Canvas>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>

                    <!-- Outer circle rotates clockwise -->
                    <DoubleAnimation
                        Storyboard.TargetName="arcCircle1Rot"
                        Storyboard.TargetProperty="Angle"
                        From="0" To="360"
                        Duration="0:0:8"
                        RepeatBehavior="Forever"/>

                    <!-- Inner circle rotates counter-clockwise -->
                    <DoubleAnimation
                        Storyboard.TargetName="arcCircle2Rot"
                        Storyboard.TargetProperty="Angle"
                        From="360" To="0"
                        Duration="0:0:5"
                        RepeatBehavior="Forever"/>

                    <!-- Sparks orbit fast -->
                    <DoubleAnimation
                        Storyboard.TargetName="sparksRot"
                        Storyboard.TargetProperty="Angle"
                        From="0" To="360"
                        Duration="0:0:3"
                        RepeatBehavior="Forever"/>

                    <!-- Floor magic circle outer ring rotates -->
                    <DoubleAnimation
                        Storyboard.TargetName="outerCircleRot"
                        Storyboard.TargetProperty="Angle"
                        From="0" To="360"
                        Duration="0:0:12"
                        RepeatBehavior="Forever"/>

                    <!-- Floor circle inner ring opposite -->
                    <DoubleAnimation
                        Storyboard.TargetName="innerCircleRot"
                        Storyboard.TargetProperty="Angle"
                        From="360" To="0"
                        Duration="0:0:8"
                        RepeatBehavior="Forever"/>

                    <!-- Orb core pulses -->
                    <DoubleAnimation
                        Storyboard.TargetName="orbCore"
                        Storyboard.TargetProperty="Width"
                        From="20" To="40"
                        Duration="0:0:0.8"
                        RepeatBehavior="Forever"
                        AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                        Storyboard.TargetName="orbCore"
                        Storyboard.TargetProperty="Height"
                        From="20" To="40"
                        Duration="0:0:0.8"
                        RepeatBehavior="Forever"
                        AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Energy beam pulses opacity -->
                    <DoubleAnimation
                        Storyboard.TargetName="energyBeam"
                        Storyboard.TargetProperty="Opacity"
                        From="0.3" To="1.0"
                        Duration="0:0:0.6"
                        RepeatBehavior="Forever"
                        AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Energy beam width flickers -->
                    <DoubleAnimation
                        Storyboard.TargetName="energyBeam"
                        Storyboard.TargetProperty="Width"
                        From="6" To="14"
                        Duration="0:0:0.15"
                        RepeatBehavior="Forever"
                        AutoReverse="True"/>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
