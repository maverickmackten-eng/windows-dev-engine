<Window x:Class="BombsAndExplosions.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bombs and Explosions"
        Width="1000" Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0A0806" CornerRadius="12"
            BorderBrush="#3A2010" BorderThickness="1">

        <Canvas x:Name="scene" ClipToBounds="True">

            <!-- Sky -->
            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="1000" Height="700">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#050810" Offset="0"/>
                        <GradientStop Color="#101520" Offset="0.5"/>
                        <GradientStop Color="#1A1008" Offset="0.8"/>
                        <GradientStop Color="#2A1500" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Ground -->
            <Rectangle Canvas.Left="0" Canvas.Top="580" Width="1000" Height="120" Fill="#1A0A00"/>
            <!-- Ground detail -->
            <Rectangle Canvas.Left="0" Canvas.Top="578" Width="1000" Height="4" Fill="#2A1500"/>

            <!-- Target markers on ground -->
            <!-- Target 1 -->
            <Canvas Canvas.Left="200" Canvas.Top="578">
                <Ellipse Width="40" Height="10" Canvas.Left="-20" Canvas.Top="-5" Stroke="#FF4400" StrokeThickness="1" Fill="Transparent"/>
                <Line X1="-20" Y1="0" X2="20" Y2="0" Stroke="#FF4400" StrokeThickness="1"/>
                <Line X1="0" Y1="-5" X2="0" Y2="5" Stroke="#FF4400" StrokeThickness="1"/>
            </Canvas>
            <!-- Target 2 -->
            <Canvas Canvas.Left="550" Canvas.Top="578">
                <Ellipse Width="40" Height="10" Canvas.Left="-20" Canvas.Top="-5" Stroke="#FF4400" StrokeThickness="1" Fill="Transparent"/>
                <Line X1="-20" Y1="0" X2="20" Y2="0" Stroke="#FF4400" StrokeThickness="1"/>
                <Line X1="0" Y1="-5" X2="0" Y2="5" Stroke="#FF4400" StrokeThickness="1"/>
            </Canvas>
            <!-- Target 3 -->
            <Canvas Canvas.Left="800" Canvas.Top="578">
                <Ellipse Width="40" Height="10" Canvas.Left="-20" Canvas.Top="-5" Stroke="#FF4400" StrokeThickness="1" Fill="Transparent"/>
                <Line X1="-20" Y1="0" X2="20" Y2="0" Stroke="#FF4400" StrokeThickness="1"/>
                <Line X1="0" Y1="-5" X2="0" Y2="5" Stroke="#FF4400" StrokeThickness="1"/>
            </Canvas>

            <!-- ═══ BOMB 1 ═══ -->
            <Canvas x:Name="bomb1" Canvas.Left="193" Canvas.Top="-40">
                <!-- Bomb body -->
                <Ellipse Width="14" Height="20" Canvas.Left="0" Fill="#333333" Stroke="#555555" StrokeThickness="1"/>
                <!-- Bomb fins -->
                <Polygon Points="0,14 -6,22 7,22" Fill="#222222"/>
                <Polygon Points="14,14 8,22 21,22" Fill="#222222"/>
                <!-- Fuse spark -->
                <Ellipse Canvas.Left="5" Canvas.Top="-4" Width="4" Height="4" Fill="#FFCC00">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FF8800" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <!-- ═══ EXPLOSION 1 ═══ (at target position, triggered after bomb lands) -->
            <Canvas x:Name="explosion1" Canvas.Left="200" Canvas.Top="578" Opacity="0">
                <!-- Initial flash -->
                <Ellipse x:Name="flash1" Width="200" Height="60" Canvas.Left="-100" Canvas.Top="-50" Opacity="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#FFFF88" Offset="0.2"/>
                            <GradientStop Color="#FF8800" Offset="0.5"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Fireball -->
                <Ellipse x:Name="fireball1" Width="10" Height="10" Canvas.Left="-5" Canvas.Top="-5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#FF8800" Offset="0.4"/>
                            <GradientStop Color="#CC2200" Offset="0.7"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FF6600" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
                    </Ellipse.Effect>
                </Ellipse>
                <!-- Shockwave ring -->
                <Ellipse x:Name="shockwave1" Width="4" Height="4" Canvas.Left="-2" Canvas.Top="-2"
                         Stroke="#FFCC66" StrokeThickness="3" Fill="Transparent" Opacity="0"/>
                <!-- Smoke -->
                <Ellipse x:Name="smoke1" Width="20" Height="20" Canvas.Left="-10" Canvas.Top="-80" Opacity="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#885533" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Debris particles -->
                <Canvas x:Name="debris1" Opacity="0">
                    <Ellipse Canvas.Left="-30" Canvas.Top="-20" Width="5" Height="5" Fill="#CC4400"/>
                    <Ellipse Canvas.Left="25"  Canvas.Top="-35" Width="4" Height="4" Fill="#AA3300"/>
                    <Ellipse Canvas.Left="-45" Canvas.Top="-10" Width="3" Height="3" Fill="#DD5500"/>
                    <Ellipse Canvas.Left="40"  Canvas.Top="-15" Width="6" Height="6" Fill="#FF4400"/>
                    <Ellipse Canvas.Left="10"  Canvas.Top="-50" Width="4" Height="4" Fill="#BB3300"/>
                    <Ellipse Canvas.Left="-20" Canvas.Top="-45" Width="3" Height="3" Fill="#CC4400"/>
                </Canvas>
            </Canvas>

            <!-- ═══ BOMB 2 ═══ -->
            <Canvas x:Name="bomb2" Canvas.Left="543" Canvas.Top="-40">
                <Ellipse Width="14" Height="20" Canvas.Left="0" Fill="#333333" Stroke="#555555" StrokeThickness="1"/>
                <Polygon Points="0,14 -6,22 7,22" Fill="#222222"/>
                <Polygon Points="14,14 8,22 21,22" Fill="#222222"/>
                <Ellipse Canvas.Left="5" Canvas.Top="-4" Width="4" Height="4" Fill="#FFCC00">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FF8800" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <!-- ═══ EXPLOSION 2 ═══ -->
            <Canvas x:Name="explosion2" Canvas.Left="550" Canvas.Top="578" Opacity="0">
                <Ellipse x:Name="flash2" Width="180" Height="55" Canvas.Left="-90" Canvas.Top="-45" Opacity="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#FFFF66" Offset="0.2"/>
                            <GradientStop Color="#FF6600" Offset="0.5"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="fireball2" Width="10" Height="10" Canvas.Left="-5" Canvas.Top="-5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#FF8800" Offset="0.4"/>
                            <GradientStop Color="#CC2200" Offset="0.7"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FF6600" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse x:Name="shockwave2" Width="4" Height="4" Canvas.Left="-2" Canvas.Top="-2"
                         Stroke="#FFCC66" StrokeThickness="3" Fill="Transparent" Opacity="0"/>
                <Ellipse x:Name="smoke2" Width="20" Height="20" Canvas.Left="-10" Canvas.Top="-80" Opacity="0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#885533" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <!-- Title overlay -->
            <TextBlock Canvas.Left="30" Canvas.Top="25"
                       Text="BOMBS AWAY — DIRECT HIT"
                       Foreground="#CC4400"
                       FontFamily="Consolas"
                       FontSize="20"
                       FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FF6600" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Canvas.Left="30" Canvas.Top="665"
                       Text="ESC to close  |  Space to drop bombs manually"
                       Foreground="#33FFFFFF"
                       FontFamily="Consolas" FontSize="9"/>

        </Canvas>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard x:Name="bombStoryboard">
                <Storyboard RepeatBehavior="Forever">

                    <!-- ═══ BOMB 1 DROPS ═══ -->
                    <!-- Falling with gravity (accelerating) -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="bomb1" Storyboard.TargetProperty="(Canvas.Top)">
                        <SplineDoubleKeyFrame KeyTime="0:0:0"   Value="-40" KeySpline="0,0,0.4,0"/>
                        <SplineDoubleKeyFrame KeyTime="0:0:2.5" Value="558" KeySpline="0,0,1,1"/>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- Bomb disappears at impact -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="bomb1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8"   Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.1" Value="1"/>
                    </DoubleAnimationUsingKeyFrames>
                    <!-- Reset bomb position for next loop -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="bomb1" Storyboard.TargetProperty="(Canvas.Top)">
                        <EasingDoubleKeyFrame KeyTime="0:0:0"   Value="-40"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="558"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8"   Value="558"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Explosion 1 appears -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="explosion1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:5.5"  Value="0.6"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.5"  Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8"    Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Flash 1 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flash1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:2.8"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Fireball 1 grows -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="fireball1" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="10"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.2" Value="160"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:5.0" Value="120"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.5" Value="20"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="fireball1" Storyboard.TargetProperty="Height">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5" Value="10"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.2" Value="120"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:5.0" Value="90"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.5" Value="15"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Shockwave 1 expands fast -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="shockwave1" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="4"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.2"  Value="300"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="shockwave1" Storyboard.TargetProperty="Height">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="4"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.2"  Value="80"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="shockwave1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="0.9"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Smoke rises -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="smoke1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.0"  Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="0.8"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:6.0"  Value="0.4"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="smoke1" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.0"  Value="20"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.0"  Value="120"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="smoke1" Storyboard.TargetProperty="(Canvas.Top)">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.0"  Value="-30"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.0"  Value="-200"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Debris 1 appears briefly -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="debris1" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:2.5"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.0"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- ═══ BOMB 2 DROPS (offset timing) ═══ -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="bomb2" Storyboard.TargetProperty="(Canvas.Top)">
                        <EasingDoubleKeyFrame KeyTime="0:0:0"    Value="-40"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:0.5"  Value="-40"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="558"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8"    Value="558"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="bomb2" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.4"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8"    Value="0"/>
                    </DoubleAnimationUsingKeyFrames>

                    <!-- Explosion 2 -->
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="explosion2" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:7.0"  Value="0.5"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flash2" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="1"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:3.8"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="fireball2" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="10"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.2"  Value="140"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="10"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="fireball2" Storyboard.TargetProperty="Height">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="10"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.2"  Value="110"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="10"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="shockwave2" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="4"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.2"  Value="260"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="shockwave2" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:3.5"  Value="0.9"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.5"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="smoke2" Storyboard.TargetProperty="Opacity">
                        <EasingDoubleKeyFrame KeyTime="0:0:4.0"  Value="0"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:4.5"  Value="0.7"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="0"/>
                    </DoubleAnimationUsingKeyFrames>
                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="smoke2" Storyboard.TargetProperty="Width">
                        <EasingDoubleKeyFrame KeyTime="0:0:4.0"  Value="20"/>
                        <EasingDoubleKeyFrame KeyTime="0:0:8.0"  Value="100"/>
                    </DoubleAnimationUsingKeyFrames>

                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
