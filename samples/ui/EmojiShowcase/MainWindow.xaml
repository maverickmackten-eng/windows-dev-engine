<Window x:Class="EmojiShowcase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emoji Showcase" Height="700" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Border Background="#0A0D12" BorderBrush="#2A3347" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>   <!-- Title bar -->
        <RowDefinition Height="Auto"/> <!-- Category tabs -->
        <RowDefinition Height="*"/>    <!-- Emoji grid -->
        <RowDefinition Height="64"/>   <!-- Selected preview -->
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="#12171F" MouseLeftButtonDown="TitleBar_MouseDown">
        <TextBlock Text="EMOJI SHOWCASE" FontFamily="Segoe UI Black" FontSize="13"
                   Foreground="#00B4FF" LetterSpacing="2"
                   VerticalAlignment="Center" Margin="16,0"/>
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                Foreground="#FF2D55" Background="Transparent" BorderThickness="0"
                Width="40" Height="48" HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
      </Grid>

      <!-- Category tabs -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,8" Background="#0A0D12">
        <Button x:Name="tabFaces"   Content="😀 Faces"   Click="Tab_Click" Tag="Faces"   Margin="0,0,4,0"
                Background="#00B4FF" Foreground="#000000" BorderThickness="0" Padding="12,6"/>
        <Button x:Name="tabSymbols" Content="⚡ Symbols" Click="Tab_Click" Tag="Symbols" Margin="0,0,4,0"
                Background="#12171F" Foreground="#8899AA" BorderBrush="#2A3347" BorderThickness="1" Padding="12,6"/>
        <Button x:Name="tabObjects" Content="🔧 Objects" Click="Tab_Click" Tag="Objects" Margin="0,0,4,0"
                Background="#12171F" Foreground="#8899AA" BorderBrush="#2A3347" BorderThickness="1" Padding="12,6"/>
        <Button x:Name="tabNature"  Content="🌟 Nature"  Click="Tab_Click" Tag="Nature"  Margin="0,0,4,0"
                Background="#12171F" Foreground="#8899AA" BorderBrush="#2A3347" BorderThickness="1" Padding="12,6"/>
        <Button x:Name="tabActions" Content="💥 Actions" Click="Tab_Click" Tag="Actions"
                Background="#12171F" Foreground="#8899AA" BorderBrush="#2A3347" BorderThickness="1" Padding="12,6"/>
      </StackPanel>

      <!-- Emoji grid -->
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                    Background="#0A0D12">
        <WrapPanel x:Name="emojiPanel" Margin="16,8" ItemWidth="56" ItemHeight="56"/>
      </ScrollViewer>

      <!-- Selected emoji preview -->
      <Border Grid.Row="3" Background="#12171F" BorderBrush="#2A3347" BorderThickness="0,1,0,0"
              Padding="16,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="selectedEmoji" Text="😀" FontSize="36"
                     FontFamily="Segoe UI Emoji"
                     VerticalAlignment="Center" Margin="0,0,16,0"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="selectedName"    Text="Grinning Face"
                       Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock x:Name="selectedCodepoint" Text="U+1F600"
                       Foreground="#8899AA" FontFamily="Cascadia Code" FontSize="12"/>
          </StackPanel>

          <!-- Usage examples in-line -->
          <Border Background="#0A0D12" BorderBrush="#2A3347" BorderThickness="1"
                  CornerRadius="6" Padding="12,8" Margin="32,0,0,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="In button: " Foreground="#8899AA" FontSize="12"
                         VerticalAlignment="Center"/>
              <Button Padding="10,6" Background="#12171F"
                      Foreground="#FFFFFF" BorderBrush="#3D5A8A" BorderThickness="1"
                      FontSize="13" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock x:Name="btnEmoji" Text="😀" FontFamily="Segoe UI Emoji"
                             FontSize="14" Margin="0,0,6,0"/>
                  <TextBlock Text="Send" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <TextBlock Text="In status: " Foreground="#8899AA" FontSize="12"
                         VerticalAlignment="Center"/>
              <TextBlock x:Name="statusEmoji" Text="✅ Ready"
                         Foreground="#00FF94" FontSize="13"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

    </Grid>
  </Border>
</Window>
