<Window x:Class="ButtonGallery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Button Gallery" Height="700" Width="1100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <!-- ── Shared card wrapper style ──────────────────────────── -->
    <Style x:Key="BtnCard" TargetType="Border">
      <Setter Property="Background"    Value="#12171F"/>
      <Setter Property="BorderBrush"   Value="#2A3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"  Value="8"/>
      <Setter Property="Padding"       Value="16,12"/>
      <Setter Property="Margin"        Value="6"/>
    </Style>

    <!-- PRIMARY -->
    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"        Value="#00B4FF"/>
      <Setter Property="Foreground"        Value="#000000"/>
      <Setter Property="BorderThickness"   Value="0"/>
      <Setter Property="Padding"           Value="20,10"/>
      <Setter Property="FontSize"          Value="13"/>
      <Setter Property="FontWeight"        Value="SemiBold"/>
      <Setter Property="Cursor"            Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#33C8FF"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0090CC"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#1C2333"/>
                <Setter Property="Foreground" Value="#445566"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- SECONDARY -->
    <Style x:Key="BtnSecondary" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#00B4FF"/>
      <Setter Property="BorderBrush"     Value="#00B4FF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="20,10"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>

    <!-- DANGER -->
    <Style x:Key="BtnDanger" TargetType="Button">
      <Setter Property="Background"    Value="#FF2D55"/>
      <Setter Property="Foreground"    Value="#FFFFFF"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"       Value="20,10"/>
      <Setter Property="FontSize"      Value="13"/>
      <Setter Property="Cursor"        Value="Hand"/>
    </Style>

    <!-- GHOST -->
    <Style x:Key="BtnGhost" TargetType="Button">
      <Setter Property="Background"    Value="Transparent"/>
      <Setter Property="Foreground"    Value="#8899AA"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"       Value="20,10"/>
      <Setter Property="FontSize"      Value="13"/>
      <Setter Property="Cursor"        Value="Hand"/>
    </Style>

    <!-- ICON-ONLY -->
    <Style x:Key="BtnIcon" TargetType="Button">
      <Setter Property="Width"         Value="44"/>
      <Setter Property="Height"        Value="44"/>
      <Setter Property="Background"    Value="#12171F"/>
      <Setter Property="Foreground"    Value="#00B4FF"/>
      <Setter Property="BorderBrush"   Value="#2A3347"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontFamily"    Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize"      Value="18"/>
      <Setter Property="Cursor"        Value="Hand"/>
    </Style>

    <!-- PILL -->
    <Style x:Key="BtnPill" TargetType="Button">
      <Setter Property="Background"    Value="#00B4FF"/>
      <Setter Property="Foreground"    Value="#000000"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"       Value="24,10"/>
      <Setter Property="FontSize"      Value="13"/>
      <Setter Property="Cursor"        Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="999"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Background="#0A0D12" BorderBrush="#2A3347" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Grid Grid.Row="0" Background="#12171F" MouseLeftButtonDown="TitleBar_MouseDown">
        <TextBlock Text="BUTTON GALLERY" FontFamily="Segoe UI Black" FontSize="13"
                   Foreground="#00B4FF" LetterSpacing="2"
                   VerticalAlignment="Center" Margin="16,0"/>
        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                Foreground="#FF2D55" Background="Transparent" BorderThickness="0"
                Width="40" Height="48" HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
      </Grid>

      <!-- Gallery grid -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <UniformGrid Columns="4" Margin="12">

          <!-- PRIMARY -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Primary" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="SAVE" Style="{StaticResource BtnPrimary}"/>
              <TextBlock Text="BtnPrimary" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- SECONDARY -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Secondary" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="CANCEL" Style="{StaticResource BtnSecondary}"/>
              <TextBlock Text="BtnSecondary" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- DANGER -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Danger" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="DELETE" Style="{StaticResource BtnDanger}"/>
              <TextBlock Text="BtnDanger" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- GHOST -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Ghost" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="SKIP" Style="{StaticResource BtnGhost}"/>
              <TextBlock Text="BtnGhost" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- ICON ONLY -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Icon Only" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="&#xE713;" Style="{StaticResource BtnIcon}"/>
              <TextBlock Text="BtnIcon" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- ICON + TEXT -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Icon + Text" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Style="{StaticResource BtnPrimary}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                             FontSize="14" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                  <TextBlock Text="COPY" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <TextBlock Text="BtnPrimary + icon" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- LOADING STATE -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Loading State" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Style="{StaticResource BtnPrimary}" IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                  <Ellipse Width="14" Height="14" Stroke="#445566" StrokeThickness="2"
                           StrokeDashArray="2 1" Margin="0,0,8,0"
                           RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><RotateTransform x:Name="loadingRotate"/></Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                      <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                          <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="loadingRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:0.8"/>
                          </Storyboard>
                        </BeginStoryboard>
                      </EventTrigger>
                    </Ellipse.Triggers>
                  </Ellipse>
                  <TextBlock Text="WORKING..." VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <TextBlock Text="IsEnabled=False + spinner" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- DISABLED -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Disabled" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="UNAVAILABLE" Style="{StaticResource BtnPrimary}"
                      IsEnabled="False"/>
              <TextBlock Text="IsEnabled=False" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- PILL -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Pill Shape" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="ACTIVATE" Style="{StaticResource BtnPill}"/>
              <TextBlock Text="BtnPill (CornerRadius=999)" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- SQUARE -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Square" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Width="64" Height="64"
                      Background="#12171F" Foreground="#00B4FF"
                      BorderBrush="#3D5A8A" BorderThickness="1"
                      HorizontalAlignment="Left">
                <StackPanel>
                  <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                             FontSize="20" HorizontalAlignment="Center"/>
                  <TextBlock Text="HOME" FontSize="9" HorizontalAlignment="Center"
                             Margin="0,4,0,0"/>
                </StackPanel>
              </Button>
              <TextBlock Text="Square icon button" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- WITH BADGE -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="With Shortcut Badge" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Style="{StaticResource BtnSecondary}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="SETTINGS" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <Border Background="#1C2333" BorderBrush="#3D5A8A" BorderThickness="1"
                          CornerRadius="3" Padding="4,2">
                    <TextBlock Text="Ctrl+," Foreground="#8899AA"
                               FontFamily="Cascadia Code" FontSize="10"/>
                  </Border>
                </StackPanel>
              </Button>
              <TextBlock Text="Badge inside button content" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

          <!-- SUCCESS -->
          <Border Style="{StaticResource BtnCard}">
            <StackPanel>
              <TextBlock Text="Success" Foreground="#8899AA" FontSize="11"
                         FontFamily="Cascadia Code" Margin="0,0,0,8"/>
              <Button Content="CONFIRM" Background="#00FF94" Foreground="#000000"
                      BorderThickness="0" Padding="20,10" FontSize="13"
                      FontWeight="SemiBold" Cursor="Hand"/>
              <TextBlock Text="AccentSuccess fill" Foreground="#445566" FontSize="10"
                         FontFamily="Cascadia Code" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>

        </UniformGrid>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
