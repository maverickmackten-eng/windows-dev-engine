<Window x:Class="SpinningWheels.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spinning Wheels — Progress Styles"
        Width="900" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0A0D12" CornerRadius="12"
            BorderBrush="#2A3347" BorderThickness="1">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="LOADING INDICATORS — SPINNER GALLERY"
                       Foreground="#445566" FontFamily="Consolas"
                       FontSize="12" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- ═══ SPINNER 1: Classic Arc ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center">
                        <!-- Track -->
                        <Ellipse Width="70" Height="70" Canvas.Left="5" Canvas.Top="5"
                                 Stroke="#1C2333" StrokeThickness="6" Fill="Transparent"/>
                        <!-- Arc (simulated with rotating partial stroke) -->
                        <Path Stroke="#00B4FF" StrokeThickness="6" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="40,8">
                                        <ArcSegment Size="32,32" Point="72,40"
                                                    SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="spin1" CenterX="40" CenterY="40"/>
                            </Path.RenderTransform>
                            <Path.Effect>
                                <DropShadowEffect Color="#00B4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                            </Path.Effect>
                        </Path>
                    </Canvas>
                    <TextBlock Text="CLASSIC ARC" Foreground="#445566"
                               FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ SPINNER 2: Dots Orbit ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="spin2"/>
                        </Canvas.RenderTransform>
                        <!-- 8 dots at different sizes/opacities -->
                        <Ellipse Canvas.Left="36" Canvas.Top="4"  Width="8" Height="8" Fill="#00B4FF"/>
                        <Ellipse Canvas.Left="60" Canvas.Top="14" Width="7" Height="7" Fill="#00B4FF" Opacity="0.8"/>
                        <Ellipse Canvas.Left="68" Canvas.Top="36" Width="6" Height="6" Fill="#00B4FF" Opacity="0.6"/>
                        <Ellipse Canvas.Left="58" Canvas.Top="58" Width="5" Height="5" Fill="#00B4FF" Opacity="0.5"/>
                        <Ellipse Canvas.Left="36" Canvas.Top="68" Width="4" Height="4" Fill="#00B4FF" Opacity="0.4"/>
                        <Ellipse Canvas.Left="14" Canvas.Top="58" Width="4" Height="4" Fill="#00B4FF" Opacity="0.3"/>
                        <Ellipse Canvas.Left="6"  Canvas.Top="36" Width="3" Height="3" Fill="#00B4FF" Opacity="0.2"/>
                        <Ellipse Canvas.Left="14" Canvas.Top="14" Width="3" Height="3" Fill="#00B4FF" Opacity="0.1"/>
                    </Canvas>
                    <TextBlock Text="DOTS ORBIT" Foreground="#445566"
                               FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ SPINNER 3: Double Ring ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center">
                        <!-- Outer ring CW -->
                        <Path Stroke="#FF6B35" StrokeThickness="4" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="40,6">
                                        <ArcSegment Size="34,34" Point="74,40"
                                                    SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform><RotateTransform x:Name="spin3a" CenterX="40" CenterY="40"/></Path.RenderTransform>
                        </Path>
                        <!-- Inner ring CCW -->
                        <Path Stroke="#FFD700" StrokeThickness="4" Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="40,18">
                                        <ArcSegment Size="22,22" Point="62,40"
                                                    SweepDirection="CounterClockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform><RotateTransform x:Name="spin3b" CenterX="40" CenterY="40"/></Path.RenderTransform>
                        </Path>
                    </Canvas>
                    <TextBlock Text="DOUBLE RING" Foreground="#445566"
                               FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ SPINNER 4: Pulse Ring ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center">
                        <Ellipse x:Name="pulseRing1" Width="10" Height="10" Canvas.Left="35" Canvas.Top="35"
                                 Stroke="#00FF94" StrokeThickness="2" Fill="Transparent" Opacity="1"/>
                        <Ellipse x:Name="pulseRing2" Width="10" Height="10" Canvas.Left="35" Canvas.Top="35"
                                 Stroke="#00FF94" StrokeThickness="1.5" Fill="Transparent" Opacity="0.7"/>
                        <Ellipse x:Name="pulseRing3" Width="10" Height="10" Canvas.Left="35" Canvas.Top="35"
                                 Stroke="#00FF94" StrokeThickness="1" Fill="Transparent" Opacity="0.4"/>
                        <!-- Center dot -->
                        <Ellipse Width="8" Height="8" Canvas.Left="36" Canvas.Top="36" Fill="#00FF94">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00FF94" BlurRadius="10" ShadowDepth="0" Opacity="0.9"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                    <TextBlock Text="PULSE RING" Foreground="#445566"
                               FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ SPINNER 5: Gear ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="80" Height="80" HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="spin5"/>
                        </Canvas.RenderTransform>
                        <!-- Gear teeth as rectangles around circle -->
                        <Path Fill="#9B59FF" Stroke="#7A3EDD" StrokeThickness="1">
                            <Path.Data>
                                <PathGeometry>
                                    <!-- Center circle -->
                                    <PathFigure>
                                        <ArcSegment Size="22,22" Point="62,40" SweepDirection="Clockwise" IsLargeArc="True"/>
                                        <ArcSegment Size="22,22" Point="18,40" SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                        <!-- Teeth (rectangles) -->
                        <Rectangle Canvas.Left="36" Canvas.Top="2"  Width="8" Height="16" Fill="#9B59FF" RadiusX="2" RadiusY="2"/>
                        <Rectangle Canvas.Left="36" Canvas.Top="62" Width="8" Height="16" Fill="#9B59FF" RadiusX="2" RadiusY="2"/>
                        <Rectangle Canvas.Left="2"  Canvas.Top="36" Width="16" Height="8" Fill="#9B59FF" RadiusX="2" RadiusY="2"/>
                        <Rectangle Canvas.Left="62" Canvas.Top="36" Width="16" Height="8" Fill="#9B59FF" RadiusX="2" RadiusY="2"/>
                        <Rectangle Canvas.Left="14" Canvas.Top="14" Width="12" Height="12" Fill="#9B59FF" RadiusX="2" RadiusY="2" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Canvas.Left="54" Canvas.Top="14" Width="12" Height="12" Fill="#9B59FF" RadiusX="2" RadiusY="2" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Canvas.Left="14" Canvas.Top="54" Width="12" Height="12" Fill="#9B59FF" RadiusX="2" RadiusY="2" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Canvas.Left="54" Canvas.Top="54" Width="12" Height="12" Fill="#9B59FF" RadiusX="2" RadiusY="2" RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform><RotateTransform Angle="45"/></Rectangle.RenderTransform>
                        </Rectangle>
                        <!-- Hole in center -->
                        <Ellipse Width="20" Height="20" Canvas.Left="30" Canvas.Top="30"
                                 Fill="#0A0D12"/>
                    </Canvas>
                    <TextBlock Text="GEAR SPIN" Foreground="#445566"
                               FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

            </WrapPanel>

            <Button Grid.Row="2" Content="CLOSE" HorizontalAlignment="Center" Margin="0,20,0,0"
                    Padding="24,8" Click="CloseBtn_Click"
                    FontFamily="Consolas" Background="#1C2333"
                    Foreground="#FF2D55" BorderBrush="#3A1522" BorderThickness="1" Cursor="Hand"/>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="spin1" Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="spin2" Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:1.2" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="spin3a" Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="spin3b" Storyboard.TargetProperty="Angle"
                                     From="360" To="0" Duration="0:0:0.9" RepeatBehavior="Forever"/>

                    <!-- Pulse ring 1 expands fast -->
                    <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="Width"
                                     From="10" To="70" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="Height"
                                     From="10" To="70" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="Opacity"
                                     From="0.9" To="0" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="(Canvas.Left)"
                                     From="35" To="5" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing1" Storyboard.TargetProperty="(Canvas.Top)"
                                     From="35" To="5" Duration="0:0:1.5" RepeatBehavior="Forever"/>

                    <!-- Pulse ring 2 (offset) -->
                    <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="Width"
                                     From="10" To="70" Duration="0:0:1.5" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="Height"
                                     From="10" To="70" Duration="0:0:1.5" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="Opacity"
                                     From="0.7" To="0" Duration="0:0:1.5" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="(Canvas.Left)"
                                     From="35" To="5" Duration="0:0:1.5" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="pulseRing2" Storyboard.TargetProperty="(Canvas.Top)"
                                     From="35" To="5" Duration="0:0:1.5" RepeatBehavior="Forever" BeginTime="0:0:0.5"/>

                    <DoubleAnimation Storyboard.TargetName="spin5" Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
