<Window x:Class="FillingBars.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filling Bars Gallery"
        Width="700" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0A0D12" CornerRadius="12"
            BorderBrush="#2A3347" BorderThickness="1">
        <StackPanel Margin="40">

            <TextBlock Text="PROGRESS BAR GALLERY"
                       Foreground="#445566" FontFamily="Consolas"
                       FontSize="12" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- ═══ BAR 1: Mission Progress ═══ -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="MISSION PROGRESS" Foreground="#8899AA" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock x:Name="bar1Label" Text="73%" Foreground="#00B4FF"
                               FontFamily="Consolas" FontSize="11" DockPanel.Dock="Right"/>
                </DockPanel>
                <Border Grid.Row="1" Height="12" Background="#0F1820" CornerRadius="6" Margin="0,6,0,0">
                    <Border x:Name="bar1Fill" HorizontalAlignment="Left" CornerRadius="6" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0070CC" Offset="0"/>
                                <GradientStop Color="#00B4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#00B4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                    </Border>
                </Border>
            </Grid>

            <!-- ═══ BAR 2: Health / HP ═══ -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="HULL INTEGRITY" Foreground="#8899AA" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock x:Name="bar2Label" Text="45%" Foreground="#FF2D55"
                               FontFamily="Consolas" FontSize="11" DockPanel.Dock="Right"/>
                </DockPanel>
                <Border Grid.Row="1" Height="16" Background="#1A0810" CornerRadius="8" Margin="0,6,0,0">
                    <Border x:Name="bar2Fill" HorizontalAlignment="Left" CornerRadius="8" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#CC0022" Offset="0"/>
                                <GradientStop Color="#FF2D55" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#FF2D55" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                    </Border>
                </Border>
            </Grid>

            <!-- ═══ BAR 3: XP / Level ═══ -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="EXPERIENCE" Foreground="#8899AA" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock x:Name="bar3Label" Text="88%" Foreground="#FFD700"
                               FontFamily="Consolas" FontSize="11" DockPanel.Dock="Right"/>
                </DockPanel>
                <Border Grid.Row="1" Height="12" Background="#161200" CornerRadius="6" Margin="0,6,0,0">
                    <Border x:Name="bar3Fill" HorizontalAlignment="Left" CornerRadius="6" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#CC9900" Offset="0"/>
                                <GradientStop Color="#FFD700" Offset="0.5"/>
                                <GradientStop Color="#FFEEAA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                    </Border>
                </Border>
            </Grid>

            <!-- ═══ BAR 4: Segmented / Chunked ═══ -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="AMMO" Foreground="#8899AA" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock Text="7 / 10" Foreground="#00FF94" FontFamily="Consolas" FontSize="11" DockPanel.Dock="Right"/>
                </DockPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <Border Width="54" Height="20" Background="#00FF94" CornerRadius="3" Margin="2,0">
                        <Border.Effect><DropShadowEffect Color="#00FF94" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/></Border.Effect>
                    </Border>
                    <!-- Empty segments -->
                    <Border Width="54" Height="20" Background="#0F2018" CornerRadius="3" Margin="2,0" BorderBrush="#1A3A28" BorderThickness="1"/>
                    <Border Width="54" Height="20" Background="#0F2018" CornerRadius="3" Margin="2,0" BorderBrush="#1A3A28" BorderThickness="1"/>
                    <Border Width="54" Height="20" Background="#0F2018" CornerRadius="3" Margin="2,0" BorderBrush="#1A3A28" BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <!-- ═══ BAR 5: Thin download-style with striped texture ═══ -->
            <Grid Margin="0,0,0,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="DOWNLOADING UPDATE" Foreground="#8899AA" FontFamily="Consolas" FontSize="11"/>
                    <TextBlock x:Name="bar5Label" Text="62%" Foreground="#9B59FF"
                               FontFamily="Consolas" FontSize="11" DockPanel.Dock="Right"/>
                </DockPanel>
                <Border Grid.Row="1" Height="8" Background="#100A1A" CornerRadius="4" Margin="0,6,0,0">
                    <Border x:Name="bar5Fill" HorizontalAlignment="Left" CornerRadius="4" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5500AA" Offset="0"/>
                                <GradientStop Color="#9B59FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#9B59FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                        </Border.Effect>
                    </Border>
                </Border>
            </Grid>

            <Button Content="CLOSE" HorizontalAlignment="Center" Margin="0,20,0,0"
                    Padding="24,8" Click="CloseBtn_Click"
                    FontFamily="Consolas" Background="#1C2333"
                    Foreground="#FF2D55" BorderBrush="#3A1522" BorderThickness="1" Cursor="Hand"/>

        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Bar 1 fills to 73% (width 620 * 0.73 = 453) -->
                    <DoubleAnimation Storyboard.TargetName="bar1Fill" Storyboard.TargetProperty="Width"
                                     From="0" To="453" Duration="0:0:1.5" BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Bar 2 fills to 45% (620 * 0.45 = 279) -->
                    <DoubleAnimation Storyboard.TargetName="bar2Fill" Storyboard.TargetProperty="Width"
                                     From="0" To="279" Duration="0:0:1.5" BeginTime="0:0:0.5">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Bar 3 fills to 88% (620 * 0.88 = 546) -->
                    <DoubleAnimation Storyboard.TargetName="bar3Fill" Storyboard.TargetProperty="Width"
                                     From="0" To="546" Duration="0:0:1.5" BeginTime="0:0:0.7">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Bar 5 fills to 62% (620 * 0.62 = 384) -->
                    <DoubleAnimation Storyboard.TargetName="bar5Fill" Storyboard.TargetProperty="Width"
                                     From="0" To="384" Duration="0:0:1.8" BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
