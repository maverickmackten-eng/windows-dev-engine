<Window x:Class="PieProgress.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pie / Donut Progress"
        Width="800" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0A0D12" CornerRadius="12"
            BorderBrush="#2A3347" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="PIE / DONUT PROGRESS GALLERY"
                       Foreground="#445566" FontFamily="Consolas"
                       FontSize="12" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,30,0,0"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- ═══ DONUT 1: 73% complete ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="120" Height="120" HorizontalAlignment="Center">
                        <!-- Track ring -->
                        <Ellipse Width="100" Height="100" Canvas.Left="10" Canvas.Top="10"
                                 Stroke="#1C2333" StrokeThickness="16" Fill="Transparent"/>
                        <!-- Progress arc — 73% = 262.8 degrees -->
                        <!-- Use Path to draw arc segment -->
                        <Path x:Name="donut1Arc" Stroke="#00B4FF" StrokeThickness="16"
                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Canvas.Left="10" Canvas.Top="10">
                            <Path.Data>
                                <!-- Arc from top (270°) covering 262.8° clockwise -->
                                <PathGeometry>
                                    <PathFigure StartPoint="50,0">
                                        <ArcSegment Size="50,50"
                                                    Point="2.4,28.2"
                                                    SweepDirection="Clockwise"
                                                    IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.Effect>
                                <DropShadowEffect Color="#00B4FF" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                            </Path.Effect>
                        </Path>
                        <!-- Center text -->
                        <TextBlock Canvas.Left="0" Canvas.Top="42" Width="120" TextAlignment="Center"
                                   Text="73%" Foreground="#00B4FF"
                                   FontFamily="Cascadia Code, Consolas" FontSize="22" FontWeight="Bold"/>
                    </Canvas>
                    <TextBlock Text="MISSION" Foreground="#445566"
                               FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ DONUT 2: 45% ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="120" Height="120" HorizontalAlignment="Center">
                        <Ellipse Width="100" Height="100" Canvas.Left="10" Canvas.Top="10"
                                 Stroke="#1C2333" StrokeThickness="16" Fill="Transparent"/>
                        <Path Stroke="#FF2D55" StrokeThickness="16"
                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Canvas.Left="10" Canvas.Top="10">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="50,0">
                                        <ArcSegment Size="50,50" Point="97.0,15.5"
                                                    SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.Effect>
                                <DropShadowEffect Color="#FF2D55" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Canvas.Left="0" Canvas.Top="42" Width="120" TextAlignment="Center"
                                   Text="45%" Foreground="#FF2D55"
                                   FontFamily="Cascadia Code, Consolas" FontSize="22" FontWeight="Bold"/>
                    </Canvas>
                    <TextBlock Text="SHIELDS" Foreground="#445566"
                               FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ DONUT 3: 88% ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="120" Height="120" HorizontalAlignment="Center">
                        <Ellipse Width="100" Height="100" Canvas.Left="10" Canvas.Top="10"
                                 Stroke="#1C2333" StrokeThickness="16" Fill="Transparent"/>
                        <Path Stroke="#FFD700" StrokeThickness="16"
                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Canvas.Left="10" Canvas.Top="10">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="50,0">
                                        <ArcSegment Size="50,50" Point="8.5,20.4"
                                                    SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Canvas.Left="0" Canvas.Top="42" Width="120" TextAlignment="Center"
                                   Text="88%" Foreground="#FFD700"
                                   FontFamily="Cascadia Code, Consolas" FontSize="22" FontWeight="Bold"/>
                    </Canvas>
                    <TextBlock Text="FUEL" Foreground="#445566"
                               FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ═══ DONUT 4: 99% (almost full) ═══ -->
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <Canvas Width="120" Height="120" HorizontalAlignment="Center">
                        <Ellipse Width="100" Height="100" Canvas.Left="10" Canvas.Top="10"
                                 Stroke="#1C2333" StrokeThickness="16" Fill="Transparent"/>
                        <Path Stroke="#00FF94" StrokeThickness="16"
                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Canvas.Left="10" Canvas.Top="10">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="50,0">
                                        <ArcSegment Size="50,50" Point="50.1,0.1"
                                                    SweepDirection="Clockwise" IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.Effect>
                                <DropShadowEffect Color="#00FF94" BlurRadius="14" ShadowDepth="0" Opacity="0.8"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Canvas.Left="0" Canvas.Top="42" Width="120" TextAlignment="Center"
                                   Text="99%" Foreground="#00FF94"
                                   FontFamily="Cascadia Code, Consolas" FontSize="22" FontWeight="Bold"/>
                    </Canvas>
                    <TextBlock Text="WEAPONS" Foreground="#445566"
                               FontFamily="Consolas" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>

            <Button Grid.Row="2" Content="CLOSE" HorizontalAlignment="Center" Margin="0,0,0,24"
                    Padding="24,8" Click="CloseBtn_Click"
                    FontFamily="Consolas" Background="#1C2333"
                    Foreground="#FF2D55" BorderBrush="#3A1522" BorderThickness="1" Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
