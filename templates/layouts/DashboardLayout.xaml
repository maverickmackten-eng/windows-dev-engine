<!--
    DashboardLayout.xaml — Card Grid Dashboard Layout (No Sidebar)
    ===============================================================
    USAGE: Use for data-dense overview screens — stat cards, charts,
    activity feeds. No navigation sidebar; navigation is handled by
    the parent shell (SidebarLayout) passing content to the frame.

    Structure:
      Row 0: 48px section header with title + action button
      Row 1: Auto — KPI stat cards row (WrapPanel)
      Row 2: * — main chart / data grid area
      Row 3: Auto — recent activity / log feed

    AGENT: Use this as a Page or UserControl inside SidebarLayout's Frame.
-->
<UserControl x:Class="__APP_NAME__.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDeepBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Section header -->
            <RowDefinition Height="Auto"/>  <!-- KPI card row -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="200"/>   <!-- Activity feed -->
        </Grid.RowDefinitions>

        <!-- ── SECTION HEADER ────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Dashboard"
                           FontFamily="Segoe UI Black" FontSize="28"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0:HH:mm:ss}'}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="&#xE72C;  Refresh"
                    FontFamily="Segoe UI"
                    Command="{Binding RefreshCommand}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- ── KPI STAT CARDS ROW ─────────────────────────────── -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding StatCards}" Margin="0,0,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Stat card -->
                    <Border Width="220" Height="100"
                            Background="{DynamicResource BackgroundPanelBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,16,0"
                            Padding="16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" Opacity="0.25"
                                             ShadowDepth="2" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Label}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextTransform="Uppercase"
                                       LetterSpacing="1"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Value}"
                                       FontFamily="Segoe UI Black" FontSize="32"
                                       Foreground="{Binding AccentColor}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── MAIN CHART / DATA AREA ─────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>  <!-- Primary chart -->
                <ColumnDefinition Width="16"/>  <!-- Gutter -->
                <ColumnDefinition Width="1*"/>  <!-- Secondary panel -->
            </Grid.ColumnDefinitions>

            <!-- Primary chart placeholder -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BackgroundPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Activity Over Time"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <!-- AGENT: Replace with LiveCharts2 or OxyPlot chart control -->
                    <Border Height="200" Background="{DynamicResource BackgroundElevatedBrush}"
                            CornerRadius="4">
                        <TextBlock Text="[ Chart Placeholder ]"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextDisabledBrush}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Secondary info panel -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BackgroundPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Status"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <!-- AGENT: Bind ItemsSource to a list of StatusItems -->
                    <ItemsControl ItemsSource="{Binding StatusItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Color dot -->
                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                             Fill="{Binding StatusColor}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Value}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── ACTIVITY FEED ─────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="{DynamicResource BackgroundPanelBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Recent Activity"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding RecentActivity}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                               FontFamily="Cascadia Code, Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextDisabledBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Message}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
