<!--
    SinglePageLayout.xaml — No-Navigation, Content-Fills-Window Layout
    ====================================================================
    USAGE: Use when your app is a single focused tool with no nav sidebar.
    Examples: a file converter, a launcher, a settings-only utility.

    Structure:
      Row 0: 48px title bar
      Row 1: * content area (full width)
      Row 2: 24px status bar

    AGENT: Copy the inner Grid into your MainWindow.xaml content.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Key="SinglePageLayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>  <!-- Title bar -->
            <RowDefinition Height="*"/>   <!-- Full content -->
            <RowDefinition Height="24"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── TITLE BAR ──────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource BackgroundPanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon + title (not hit-test visible so drag works) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0"
                        IsHitTestVisible="False">
                <TextBlock Text="&#xE80F;"
                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="__APP_NAME__"
                           FontFamily="Segoe UI Black" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Drag region spacer -->
            <Border Grid.Column="1" Background="Transparent"/>

            <!-- Window chrome buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Width="46" Height="48"
                        Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeButtonStyle}"/>
                <Button x:Name="MaximizeButton" Width="46" Height="48"
                        Content="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeButtonStyle}"/>
                <Button x:Name="CloseButton" Width="46" Height="48"
                        Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeCloseButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- ── CONTENT (fills entire middle row) ─────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource BackgroundDeepBrush}"
                Padding="24">
            <!-- AGENT: Place your main UserControl or ContentControl here -->
            <!-- Example:
            <local:MainContentView DataContext="{Binding MainContentViewModel}"/>
            -->
            <ContentPresenter x:Name="MainContent"
                              Content="{Binding CurrentContent}"/>
        </Border>

        <!-- ── STATUS BAR ──────────────────────────────────────── -->
        <Grid Grid.Row="2" Background="{DynamicResource BackgroundPanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage, FallbackValue='Ready'}"
                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
            <TextBlock Grid.Column="1"
                       Text="v1.0.0"
                       FontSize="11" Foreground="{DynamicResource TextDisabledBrush}"
                       VerticalAlignment="Center" Margin="12,0"/>
        </Grid>

    </Grid>

</ResourceDictionary>
