<!--
  SinglePageLayout.xaml — For apps with no sidebar navigation.
  The entire window is one content area. Use for tools, utilities, dialogs.

  Structure:
    Row 0: 48px title bar
    Row 1: * content (fills window)
    Row 2: 24px status bar
-->
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid.RowDefinitions>
    <RowDefinition Height="48"/>
    <RowDefinition Height="*"/>
    <RowDefinition Height="24"/>
  </Grid.RowDefinitions>

  <!-- Title Bar -->
  <Grid Grid.Row="0" Background="#0A0D12"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <TextBlock Grid.Column="0"
               Text="__APP_DISPLAY_NAME__"
               FontFamily="Segoe UI Black" FontSize="14"
               Foreground="#FFFFFF" LetterSpacing="2"
               VerticalAlignment="Center" Margin="16,0"/>

    <StackPanel Grid.Column="1" Orientation="Horizontal">
      <Button x:Name="btnMinimize" Content="&#xE921;"
              Style="{StaticResource WindowButtonStyle}"
              Click="BtnMinimize_Click"/>
      <Button x:Name="btnMaximize" Content="&#xE922;"
              Style="{StaticResource WindowButtonStyle}"
              Click="BtnMaximize_Click"/>
      <Button x:Name="btnClose" Content="&#xE8BB;"
              Style="{StaticResource WindowButtonDangerStyle}"
              Click="BtnClose_Click"/>
    </StackPanel>
  </Grid>

  <!-- Content — paste your page content here, or host a Frame -->
  <Grid Grid.Row="1" Background="#0A0D12" Margin="24">
    <!-- AGENT: Replace this placeholder with your content -->
    <TextBlock Text="[ content goes here ]"
               Foreground="#445566"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontFamily="Cascadia Code" FontSize="13"/>
  </Grid>

  <!-- Status Bar -->
  <Grid Grid.Row="2" Background="#0D1117">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
               Foreground="#8899AA" FontSize="11"
               VerticalAlignment="Center" Margin="12,0"/>
    <TextBlock Grid.Column="1" Text="{Binding AppVersion, StringFormat='v{0}'}"
               Foreground="#445566" FontSize="11"
               VerticalAlignment="Center" Margin="12,0"/>
  </Grid>

</Grid>
