<!--
    SidebarLayout.xaml — Sidebar + Content Frame Layout Pattern
    ============================================================
    USAGE: Copy this Grid pattern into your MainWindow.xaml as the root layout.
    Replace __APP_NAME__ throughout.

    Structure:
      Row 0: 48px custom title bar
      Row 1: * main area (sidebar + content side-by-side)
      Row 2: 24px status bar

    Sidebar:
      - 240px expanded / 64px collapsed (icon-only mode)
      - Collapse toggle animates width with DoubleAnimation
      - Wire navigation buttons in the sidebar StackPanel
      - Set Frame.Source or ContentControl.Content from NavigationService
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         PASTE THIS GRID INTO MainWindow.xaml WindowChrome content
         ═══════════════════════════════════════════════════════════ -->
    <Grid x:Key="SidebarLayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Main content area -->
            <RowDefinition Height="24"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── TITLE BAR ──────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource BackgroundPanelBrush}"
              x:Name="TitleBar">
            <!-- WindowChrome drag region covers this entire row -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- App icon -->
                <ColumnDefinition Width="*"/>     <!-- Title text -->
                <ColumnDefinition Width="Auto"/>  <!-- Window buttons -->
            </Grid.ColumnDefinitions>

            <!-- App icon / logo -->
            <Border Grid.Column="0" Width="48" Height="48"
                    Background="Transparent">
                <TextBlock Text="&#xE80F;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="{DynamicResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Border>

            <!-- App title -->
            <TextBlock Grid.Column="1"
                       Text="__APP_NAME__"
                       FontFamily="Segoe UI Black"
                       FontSize="14"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       IsHitTestVisible="False"/>

            <!-- Window chrome buttons (min / max / close) -->
            <!-- AGENT: Replace with your window chrome button UserControl -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinimizeButton" Width="46" Height="48"
                        Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeButtonStyle}"/>
                <Button x:Name="MaximizeButton" Width="46" Height="48"
                        Content="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeButtonStyle}"/>
                <Button x:Name="CloseButton" Width="46" Height="48"
                        Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{DynamicResource ChromeCloseButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- ── MAIN AREA (Sidebar + Content) ────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar: starts at 240, collapses to 64 via animation -->
                <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="64"/>
                <!-- Content area fills remaining space -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ──────────────────────────────────────── -->
            <Grid Grid.Column="0"
                  Background="{DynamicResource BackgroundPanelBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Nav items -->
                    <RowDefinition Height="Auto"/> <!-- Collapse toggle -->
                </Grid.RowDefinitions>

                <!-- Navigation items -->
                <!-- AGENT: Add your nav buttons here. Example: -->
                <StackPanel Grid.Row="0" Margin="8,12,8,0" Spacing="4">
                    <!--
                    <Button x:Name="NavDashboard"
                            Style="{DynamicResource NavButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            <TextBlock x:Name="NavDashboardLabel" Text="Dashboard"
                                       Visibility="{Binding IsExpanded, Converter={...}}"/>
                        </StackPanel>
                    </Button>
                    -->
                </StackPanel>

                <!-- Collapse toggle button -->
                <Button Grid.Row="1"
                        x:Name="SidebarToggle"
                        Height="40"
                        Margin="8"
                        Style="{DynamicResource NavButtonStyle}"
                        Click="SidebarToggle_Click">
                    <TextBlock x:Name="ToggleIcon"
                               Text="&#xE76B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"/>
                </Button>
            </Grid>

            <!-- ── CONTENT FRAME ─────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BackgroundDeepBrush}">
                <!-- AGENT: Use Frame for page navigation, or ContentControl for ViewModel-driven nav -->
                <Frame x:Name="ContentFrame"
                       NavigationUIVisibility="Hidden"
                       Margin="24"/>
                <!--
                    Alt: ContentControl for MVVM nav:
                    <ContentControl Content="{Binding CurrentPage}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                                <v:DashboardPage/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                -->
            </Border>
        </Grid>

        <!-- ── STATUS BAR ──────────────────────────────────────── -->
        <Grid Grid.Row="2"
              Background="{DynamicResource BackgroundPanelBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="StatusText"
                       Text="{Binding StatusMessage}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0"/>

            <TextBlock Grid.Column="1"
                       Text="v1.0.0"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       Foreground="{DynamicResource TextDisabledBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0"/>
        </Grid>

    </Grid>

</ResourceDictionary>
