<Page x:Class="__APP_NAME__.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="#0A0D12">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24">

      <!-- Page header -->
      <TextBlock Text="DASHBOARD"
                 FontFamily="Segoe UI Black" FontSize="22"
                 Foreground="#FFFFFF" LetterSpacing="3"
                 Margin="0,0,0,4"/>
      <TextBlock Text="{Binding PageSubtitle}"
                 FontSize="13" Foreground="#8899AA"
                 Margin="0,0,0,24"/>

      <!-- ── Stat Cards Row ───────────────────────────────────── -->
      <UniformGrid Rows="1" Height="100" Margin="0,0,0,16">

        <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Margin="0,0,12,0" Padding="16,12">
          <StackPanel>
            <TextBlock Text="STAT ONE" Foreground="#8899AA" FontSize="11"/>
            <TextBlock Text="{Binding StatOne}" Foreground="#00B4FF"
                       FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatOneTrend}" Foreground="#00FF94" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Margin="0,0,12,0" Padding="16,12">
          <StackPanel>
            <TextBlock Text="STAT TWO" Foreground="#8899AA" FontSize="11"/>
            <TextBlock Text="{Binding StatTwo}" Foreground="#00B4FF"
                       FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatTwoTrend}" Foreground="#FFD700" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Margin="0,0,12,0" Padding="16,12">
          <StackPanel>
            <TextBlock Text="STAT THREE" Foreground="#8899AA" FontSize="11"/>
            <TextBlock Text="{Binding StatThree}" Foreground="#00B4FF"
                       FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatThreeTrend}" Foreground="#FF6B35" FontSize="11"/>
          </StackPanel>
        </Border>

        <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                Padding="16,12" CornerRadius="8">
          <StackPanel>
            <TextBlock Text="STAT FOUR" Foreground="#8899AA" FontSize="11"/>
            <TextBlock Text="{Binding StatFour}" Foreground="#00B4FF"
                       FontSize="32" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatFourTrend}" Foreground="#8899AA" FontSize="11"/>
          </StackPanel>
        </Border>

      </UniformGrid>

      <!-- ── Main Content Area ─────────────────────────────────── -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Primary content card -->
        <Border Grid.Column="0"
                Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Padding="16" MinHeight="300">
          <StackPanel>
            <TextBlock Text="MAIN CONTENT"
                       Foreground="#8899AA" FontSize="11"
                       Margin="0,0,0,12"/>
            <!-- AGENT: Replace with real content / ItemsControl -->
            <TextBlock Text="[ bind your primary content here ]"
                       Foreground="#2A3347" FontFamily="Cascadia Code" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,80,0,0"/>
          </StackPanel>
        </Border>

        <!-- Side panel card -->
        <Border Grid.Column="2"
                Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
                CornerRadius="8" Padding="16" MinHeight="300">
          <StackPanel>
            <TextBlock Text="SIDE PANEL"
                       Foreground="#8899AA" FontSize="11"
                       Margin="0,0,0,12"/>
            <!-- AGENT: Replace with real side content -->
            <TextBlock Text="[ side content ]"
                       Foreground="#2A3347" FontFamily="Cascadia Code" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,40,0,0"/>
          </StackPanel>
        </Border>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</Page>
