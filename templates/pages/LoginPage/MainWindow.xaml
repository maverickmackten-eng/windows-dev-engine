<Window x:Class="LoginPage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AUTHENTICATION"
        Width="480" Height="580"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"  Color="#0A0D12"/>
        <SolidColorBrush x:Key="Bg1"  Color="#12171F"/>
        <SolidColorBrush x:Key="Bg2"  Color="#1C2333"/>
        <SolidColorBrush x:Key="Acc"  Color="#00B4FF"/>
        <SolidColorBrush x:Key="Red"  Color="#FF2D55"/>
        <SolidColorBrush x:Key="Dim"  Color="#445566"/>
        <SolidColorBrush x:Key="Text" Color="#CCDDEE"/>
        <SolidColorBrush x:Key="Bord" Color="#2A3347"/>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="card" Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="cardTranslate" Storyboard.TargetProperty="Y"
                                     From="20" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{StaticResource Bg0}" CornerRadius="12" BorderBrush="#1A00B4FF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#00B4FF" BlurRadius="40" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <!-- Top close bar -->
            <Border VerticalAlignment="Top" Height="46" Background="{StaticResource Bg1}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown"
                    BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <TextBlock Text="🔐  AUTHENTICATION" Foreground="{StaticResource Acc}"
                               FontFamily="Cascadia Code" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" DockPanel.Dock="Right" Click="CloseBtn_Click"
                            Width="36" Height="36" Background="Transparent" Foreground="{StaticResource Dim}"
                            BorderThickness="0" Cursor="Hand"/>
                </DockPanel>
            </Border>

            <!-- Login card (animated) -->
            <Border x:Name="card" Opacity="0" Margin="48,62,48,40" VerticalAlignment="Top">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="cardTranslate" Y="20"/>
                </Border.RenderTransform>
                <StackPanel>
                    <!-- App icon + name -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                        <TextBlock Text="⬡" FontFamily="Segoe UI" FontSize="40" Foreground="{StaticResource Acc}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00B4FF" BlurRadius="16" ShadowDepth="0" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="APP NAME" FontFamily="Segoe UI Black" FontSize="26"
                                   Foreground="{StaticResource Text}" HorizontalAlignment="Center" LetterSpacing="4"/>
                        <TextBlock Text="Sign in to continue" FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{StaticResource Dim}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Username field -->
                    <TextBlock Text="USERNAME" Foreground="{StaticResource Dim}"
                               FontFamily="Cascadia Code" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border x:Name="userBorder" Background="{StaticResource Bg2}" CornerRadius="6"
                            BorderBrush="{StaticResource Bord}" BorderThickness="1" Padding="14,11" Margin="0,0,0,16">
                        <TextBox x:Name="usernameBox" Background="Transparent" Foreground="{StaticResource Text}"
                                 BorderThickness="0" FontFamily="Segoe UI" FontSize="14"
                                 CaretBrush="{StaticResource Acc}" Text="commander.maverick"
                                 GotFocus="Field_GotFocus" LostFocus="Field_LostFocus" Tag="user"/>
                    </Border>

                    <!-- Password field -->
                    <TextBlock Text="PASSWORD" Foreground="{StaticResource Dim}"
                               FontFamily="Cascadia Code" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                    <Border x:Name="passBorder" Background="{StaticResource Bg2}" CornerRadius="6"
                            BorderBrush="{StaticResource Bord}" BorderThickness="1" Padding="14,11" Margin="0,0,0,8">
                        <Grid>
                            <PasswordBox x:Name="passwordBox" Background="Transparent" Foreground="{StaticResource Text}"
                                         BorderThickness="0" FontFamily="Segoe UI" FontSize="14"
                                         CaretBrush="{StaticResource Acc}" PasswordChar="●"
                                         GotFocus="PassField_GotFocus" LostFocus="PassField_LostFocus"/>
                            <Button x:Name="showPassBtn" Content="👁" HorizontalAlignment="Right" Margin="0,0,-8,0"
                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource Dim}"
                                    FontSize="14" Cursor="Hand" Click="ShowPass_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Error message (hidden by default) -->
                    <Border x:Name="errorBorder" Visibility="Collapsed" Background="#1AFF2D55" CornerRadius="6"
                            BorderBrush="{StaticResource Red}" BorderThickness="1" Padding="14,9" Margin="0,0,0,8">
                        <TextBlock x:Name="errorText" Text="Invalid credentials. Try again."
                                   Foreground="{StaticResource Red}" FontFamily="Segoe UI" FontSize="12"/>
                    </Border>

                    <!-- Forgot password link -->
                    <TextBlock HorizontalAlignment="Right" Margin="0,0,0,24" Cursor="Hand">
                        <Hyperlink Foreground="{StaticResource Acc}" TextDecorations="None">
                            Forgot password?
                        </Hyperlink>
                    </TextBlock>

                    <!-- Sign in button -->
                    <Button Content="SIGN IN  →" Click="SignIn_Click" Cursor="Hand"
                            FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                            BorderThickness="0" Height="46">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Height="{TemplateBinding Height}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#0066AA" Offset="0"/>
                                            <GradientStop Color="#00B4FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="glow" Color="#00B4FF" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextBlock.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="glow" Property="BlurRadius" Value="16"/>
                                        <Setter TargetName="glow" Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Divider -->
                    <Grid Margin="0,20,0,20">
                        <Rectangle Height="1" Fill="{StaticResource Bord}" Margin="0,8,0,0"/>
                        <TextBlock Text="or" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="12"
                                   HorizontalAlignment="Center" Background="{StaticResource Bg0}" Padding="12,0"/>
                    </Grid>

                    <!-- SSO button -->
                    <Button Content="🔑  Sign in with SSO" Cursor="Hand"
                            Background="{StaticResource Bg2}" Foreground="{StaticResource Text}"
                            BorderBrush="{StaticResource Bord}" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="13" Height="42">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                        Height="{TemplateBinding Height}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
