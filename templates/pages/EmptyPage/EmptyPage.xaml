<Page x:Class="__APP_NAME__.Views.Pages.EmptyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="__PAGE_TITLE__"
      Background="#0A0D12">

  <!--
    EmptyPage — Blank page scaffold with correct bindings and logging.

    USAGE:
      1. Copy this folder to Views/Pages/YourPageName/
      2. Find+Replace EmptyPage with YourPageName
      3. Find+Replace __PAGE_TITLE__ with your page title
      4. Find+Replace __APP_NAME__ with your namespace
      5. Create YourPageViewModel in ViewModels/
      6. Register in NavigationService
  -->

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="*"/>     <!-- Content -->
    </Grid.RowDefinitions>

    <!-- Page header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,24">
      <TextBlock Text="__PAGE_TITLE__"
                 FontFamily="Segoe UI Black" FontSize="22"
                 Foreground="#FFFFFF" LetterSpacing="3"
                 Margin="0,0,0,4"/>
      <TextBlock Text="{Binding PageSubtitle}"
                 FontSize="13" Foreground="#8899AA"/>
    </StackPanel>

    <!-- Content area -->
    <Border Grid.Row="1"
            Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
            CornerRadius="8">
      <!-- AGENT: Replace this placeholder with real page content -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="&#xE81E;"
                   FontFamily="Segoe MDL2 Assets" FontSize="48"
                   Foreground="#2A3347"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"/>
        <TextBlock Text="__PAGE_TITLE__ content goes here"
                   Foreground="#445566" FontSize="14"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Bind to {Binding YourViewModel}"
                   Foreground="#2A3347" FontFamily="Cascadia Code" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

  </Grid>
</Page>
