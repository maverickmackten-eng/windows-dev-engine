<Window x:Class="__APP_NAME__.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="620" Height="340"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <DropShadowEffect x:Key="TitleGlow" Color="#00B4FF" BlurRadius="24" ShadowDepth="0" Opacity="0.9"/>
        <Storyboard x:Key="FadeOutStoryboard" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.5"/>
        </Storyboard>
        <Storyboard x:Key="ProgressStoryboard">
            <DoubleAnimation Storyboard.TargetName="ProgressIndicator" Storyboard.TargetProperty="Width"
                             From="0" To="520" Duration="0:0:2.2"/>
        </Storyboard>
    </Window.Resources>
    <Border x:Name="RootBorder" Background="#0A0D12" CornerRadius="12"
            BorderBrush="#1E3A5F" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.8"/>
        </Border.Effect>
        <Grid Margin="50,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- App name -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="__APP_NAME__"
                           FontFamily="Segoe UI Black, Impact" FontSize="56" FontWeight="Black"
                           Foreground="White" HorizontalAlignment="Center"
                           Effect="{StaticResource TitleGlow}">
                    <TextBlock.RenderTransform><TranslateTransform x:Name="TitleTranslate" Y="0"/></TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="TitleTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     From="12" To="0" Duration="0:0:0.6">
                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="__APP_TAGLINE__" FontFamily="Segoe UI" FontSize="14"
                           Foreground="#8899AA" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
            <!-- Progress bar -->
            <Grid Grid.Row="1" Margin="0,24,0,8">
                <Border Height="3" Background="#1C2333" CornerRadius="2"/>
                <Border x:Name="ProgressIndicator" Height="3" Width="0"
                        HorizontalAlignment="Left" CornerRadius="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00B4FF" Offset="0"/>
                            <GradientStop Color="#00FF94" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect><DropShadowEffect Color="#00B4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Border.Effect>
                </Border>
            </Grid>
            <!-- Status + version -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Initializing..."
                           FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#445566"/>
                <TextBlock Grid.Column="1" Text="v1.0.0"
                           FontFamily="Cascadia Code, Consolas" FontSize="11" Foreground="#445566"/>
            </Grid>
        </Grid>
    </Border>
</Window>
