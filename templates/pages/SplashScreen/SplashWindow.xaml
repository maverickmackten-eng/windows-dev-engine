<Window x:Class="__APP_NAME__.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading"
        Height="400" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

  <Window.Resources>
    <!-- Glow effect for app name -->
    <DropShadowEffect x:Key="GlowBlue" Color="#00B4FF" BlurRadius="28"
                      ShadowDepth="0" Opacity="0.85"/>
    <DropShadowEffect x:Key="GlowSubtle" Color="#00B4FF" BlurRadius="12"
                      ShadowDepth="0" Opacity="0.4"/>

    <!-- Progress bar track style -->
    <Style x:Key="SplashProgressBar" TargetType="ProgressBar">
      <Setter Property="Height" Value="3"/>
      <Setter Property="Background" Value="#1C2333"/>
      <Setter Property="Foreground" Value="#00B4FF"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid>
              <Rectangle Fill="{TemplateBinding Background}" RadiusX="2" RadiusY="2"/>
              <Rectangle x:Name="PART_Track"/>
              <Rectangle x:Name="PART_Indicator"
                         Fill="{TemplateBinding Foreground}"
                         HorizontalAlignment="Left"
                         RadiusX="2" RadiusY="2">
                <Rectangle.Effect>
                  <DropShadowEffect Color="#00B4FF" BlurRadius="8" ShadowDepth="0"/>
                </Rectangle.Effect>
              </Rectangle>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <!-- Outer container with border + drop shadow -->
  <Border CornerRadius="12"
          Background="#0A0D12"
          BorderBrush="#2A3347"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="48" ShadowDepth="8"
                        Color="#000000" Opacity="0.7"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>     <!-- Main content -->
        <RowDefinition Height="Auto"/>  <!-- Progress area -->
        <RowDefinition Height="40"/>    <!-- Footer -->
      </Grid.RowDefinitions>

      <!-- ── Decorative accent line (top) ────────────────────── -->
      <Rectangle Height="2" VerticalAlignment="Top"
                 HorizontalAlignment="Stretch">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="Transparent" Offset="0"/>
            <GradientStop Color="#00B4FF"     Offset="0.5"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
      </Rectangle>

      <!-- ── Main content ───────────────────────────────────── -->
      <StackPanel Grid.Row="0" VerticalAlignment="Center"
                  HorizontalAlignment="Center">

        <!-- App name in display font with glow -->
        <TextBlock x:Name="txtAppName"
                   Text="__APP_DISPLAY_NAME__"
                   FontFamily="Segoe UI Black, Impact"
                   FontSize="52"
                   Foreground="#FFFFFF"
                   HorizontalAlignment="Center"
                   LetterSpacing="4"
                   Effect="{StaticResource GlowBlue}">
          <TextBlock.RenderTransform>
            <TranslateTransform x:Name="appNameTranslate" Y="20"/>
          </TextBlock.RenderTransform>
          <TextBlock.Triggers>
            <EventTrigger RoutedEvent="Loaded">
              <BeginStoryboard>
                <Storyboard>
                  <!-- Fade in -->
                  <DoubleAnimation Storyboard.TargetName="txtAppName"
                                   Storyboard.TargetProperty="Opacity"
                                   From="0" To="1" Duration="0:0:0.6"
                                   EasingFunction="{x:Null}"/>
                  <!-- Slide up -->
                  <DoubleAnimation Storyboard.TargetName="appNameTranslate"
                                   Storyboard.TargetProperty="Y"
                                   From="20" To="0" Duration="0:0:0.6">
                    <DoubleAnimation.EasingFunction>
                      <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                  </DoubleAnimation>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </TextBlock.Triggers>
        </TextBlock>

        <!-- Tagline -->
        <TextBlock x:Name="txtTagline"
                   Text="__APP_TAGLINE__"
                   FontFamily="Segoe UI" FontSize="14"
                   Foreground="#8899AA"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   Opacity="0">
          <TextBlock.Triggers>
            <EventTrigger RoutedEvent="Loaded">
              <BeginStoryboard>
                <Storyboard BeginTime="0:0:0.4">
                  <DoubleAnimation Storyboard.TargetName="txtTagline"
                                   Storyboard.TargetProperty="Opacity"
                                   From="0" To="1" Duration="0:0:0.8"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </TextBlock.Triggers>
        </TextBlock>

      </StackPanel>

      <!-- ── Progress area ───────────────────────────────────── -->
      <StackPanel Grid.Row="1" Margin="48,0,48,16">
        <TextBlock x:Name="txtStatus"
                   Text="Initializing..."
                   Foreground="#8899AA" FontSize="11"
                   FontFamily="Cascadia Code"
                   Margin="0,0,0,8"
                   HorizontalAlignment="Left"/>
        <ProgressBar x:Name="splashProgress"
                     Style="{StaticResource SplashProgressBar}"
                     Minimum="0" Maximum="100" Value="0"/>
      </StackPanel>

      <!-- ── Footer ──────────────────────────────────────── -->
      <Grid Grid.Row="2">
        <TextBlock Text="v__VERSION__"
                   Foreground="#445566" FontSize="11"
                   FontFamily="Cascadia Code"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Margin="16,0"/>
        <TextBlock Text="Commander Maverick"
                   Foreground="#2A3347" FontSize="11"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="0,0,16,0"/>
      </Grid>

    </Grid>
  </Border>

</Window>
