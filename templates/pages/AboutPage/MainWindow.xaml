<Window x:Class="AboutPage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ABOUT"
        Width="560" Height="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg0"  Color="#0A0D12"/>
        <SolidColorBrush x:Key="Bg1"  Color="#12171F"/>
        <SolidColorBrush x:Key="Bg2"  Color="#1C2333"/>
        <SolidColorBrush x:Key="Acc"  Color="#00B4FF"/>
        <SolidColorBrush x:Key="Gold" Color="#FFD700"/>
        <SolidColorBrush x:Key="Dim"  Color="#445566"/>
        <SolidColorBrush x:Key="Text" Color="#CCDDEE"/>
        <SolidColorBrush x:Key="Bord" Color="#2A3347"/>
    </Window.Resources>

    <Border Background="{StaticResource Bg0}" CornerRadius="12" BorderBrush="{StaticResource Bord}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Background="{StaticResource Bg1}" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown" BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
                <DockPanel Margin="16,0">
                    <TextBlock Text="ℹ  ABOUT APP NAME" Foreground="{StaticResource Text}"
                               FontFamily="Cascadia Code" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" DockPanel.Dock="Right" Click="CloseBtn_Click"
                            Width="36" Height="36" Background="Transparent" Foreground="{StaticResource Dim}"
                            BorderThickness="0" Cursor="Hand"/>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="40,32,40,32">
                <!-- Icon + name -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="80" Height="80" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0066AA" Offset="0"/>
                                <GradientStop Color="#00B4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#00B4FF" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <TextBlock Text="⬡" FontFamily="Segoe UI" FontSize="44" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="APP NAME" FontFamily="Segoe UI Black" FontSize="28"
                               Foreground="{StaticResource Text}" HorizontalAlignment="Center" LetterSpacing="4"/>
                    <TextBlock Text="Version 1.0.0" FontFamily="Cascadia Code" FontSize="12"
                               Foreground="{StaticResource Acc}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="Build 2026.04.27 — Release" FontFamily="Cascadia Code" FontSize="10"
                               Foreground="{StaticResource Dim}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{StaticResource Bord}" Margin="0,0,0,20"/>

                <!-- Description -->
                <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="13" Margin="0,0,0,24"
                           Text="Built on Windows Dev Engine — a dark, debug-first WPF development platform. Designed for tactical applications with military-grade precision."/>

                <!-- Links row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border Margin="0,0,12,0" Padding="14,8" CornerRadius="6"
                            Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}" BorderThickness="1"
                            Cursor="Hand">
                        <TextBlock Text="📄  License" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                    </Border>
                    <Border Margin="0,0,12,0" Padding="14,8" CornerRadius="6"
                            Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}" BorderThickness="1"
                            Cursor="Hand">
                        <TextBlock Text="🐛  Report Bug" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                    </Border>
                    <Border Padding="14,8" CornerRadius="6"
                            Background="{StaticResource Bg2}" BorderBrush="{StaticResource Bord}" BorderThickness="1"
                            Cursor="Hand">
                        <TextBlock Text="📡  GitHub" Foreground="{StaticResource Text}" FontFamily="Segoe UI" FontSize="12"/>
                    </Border>
                </StackPanel>

                <!-- Divider -->
                <Rectangle Height="1" Fill="{StaticResource Bord}" Margin="0,0,0,16"/>

                <!-- Credits -->
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Developed by" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="12"/>
                        <TextBlock Text="Commander Maverick" Foreground="{StaticResource Text}"
                                   FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Engine" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="12"/>
                        <TextBlock Text="Windows Dev Engine v1.0" Foreground="{StaticResource Acc}"
                                   FontFamily="Cascadia Code" FontSize="11" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Framework" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="12"/>
                        <TextBlock Text=".NET 8 + WPF" Foreground="{StaticResource Text}"
                                   FontFamily="Cascadia Code" FontSize="11" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Text="Copyright" Foreground="{StaticResource Dim}" FontFamily="Segoe UI" FontSize="12"/>
                        <TextBlock Text="© 2026 NCC-1701-M" Foreground="{StaticResource Dim}"
                                   FontFamily="Segoe UI" FontSize="12" DockPanel.Dock="Right"/>
                    </DockPanel>
                </StackPanel>

                <!-- Close button -->
                <Button Content="Close" Click="CloseBtn_Click" HorizontalAlignment="Right"
                        Margin="0,24,0,0" Padding="24,9" Cursor="Hand"
                        Background="{StaticResource Bg2}" Foreground="{StaticResource Text}"
                        BorderBrush="{StaticResource Bord}" BorderThickness="1" FontFamily="Segoe UI" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
