<Page x:Class="__APP_NAME__.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="#0A0D12">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" MaxWidth="640">

      <!-- Page header -->
      <TextBlock Text="SETTINGS"
                 FontFamily="Segoe UI Black" FontSize="22"
                 Foreground="#FFFFFF" LetterSpacing="3"
                 Margin="0,0,0,4"/>
      <TextBlock Text="Configure application preferences"
                 FontSize="13" Foreground="#8899AA"
                 Margin="0,0,0,32"/>

      <!-- ── APPEARANCE SECTION ────────────────────────────────── -->
      <TextBlock Text="APPEARANCE"
                 Foreground="#00B4FF" FontSize="11"
                 FontFamily="Cascadia Code" LetterSpacing="2"
                 Margin="0,0,0,12"/>

      <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
              CornerRadius="8" Padding="16" Margin="0,0,0,24">
        <StackPanel>

          <!-- Toggle: Dark mode (pill-style checkbox) -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Dark Mode" Foreground="#FFFFFF" FontSize="14"/>
              <TextBlock Text="Use dark background throughout the app"
                         Foreground="#8899AA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <CheckBox Grid.Column="1"
                      IsChecked="{Binding IsDarkMode}"
                      Style="{StaticResource PillToggleStyle}"
                      VerticalAlignment="Center"/>
          </Grid>

          <!-- Toggle: Animations -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Animations" Foreground="#FFFFFF" FontSize="14"/>
              <TextBlock Text="Enable UI transition animations"
                         Foreground="#8899AA" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <CheckBox Grid.Column="1"
                      IsChecked="{Binding AnimationsEnabled}"
                      Style="{StaticResource PillToggleStyle}"
                      VerticalAlignment="Center"/>
          </Grid>

        </StackPanel>
      </Border>

      <!-- ── BEHAVIOUR SECTION ────────────────────────────────── -->
      <TextBlock Text="BEHAVIOUR"
                 Foreground="#00B4FF" FontSize="11"
                 FontFamily="Cascadia Code" LetterSpacing="2"
                 Margin="0,0,0,12"/>

      <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
              CornerRadius="8" Padding="16" Margin="0,0,0,24">
        <StackPanel>

          <!-- Slider with value label -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="Auto-Save Interval" Foreground="#FFFFFF" FontSize="14"/>
            <TextBlock Grid.Column="0" Grid.Row="1"
                       Text="Minutes between automatic saves"
                       Foreground="#8899AA" FontSize="11" Margin="0,2,0,8"/>
            <Slider Grid.Column="0" Grid.Row="2"
                    Value="{Binding AutoSaveMinutes}"
                    Minimum="1" Maximum="60" TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Foreground="#00B4FF"/>
            <TextBlock Grid.Column="1" Grid.Row="2"
                       Text="{Binding AutoSaveMinutes}"
                       Foreground="#00B4FF" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Grid>

          <!-- TextBox with validation ring -->
          <StackPanel>
            <TextBlock Text="Data Path" Foreground="#FFFFFF" FontSize="14"/>
            <TextBlock Text="Folder where app data is stored"
                       Foreground="#8899AA" FontSize="11" Margin="0,2,0,8"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Text="{Binding DataPath, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                       Background="#0A0D12" Foreground="#FFFFFF"
                       BorderBrush="#2A3347" BorderThickness="1"
                       Padding="8" FontSize="13"/>
              <Button Grid.Column="1" Content="&#xE838;"
                      FontFamily="Segoe MDL2 Assets"
                      Foreground="#8899AA" Background="Transparent"
                      BorderThickness="0" Width="40"
                      Command="{Binding BrowseDataPathCommand}"
                      ToolTip="Browse..."/>
            </Grid>
            <TextBlock Text="{Binding DataPathError}"
                       Foreground="#FF2D55" FontSize="11"
                       Margin="0,4,0,0"
                       Visibility="{Binding HasDataPathError, Converter={StaticResource BoolToVisibility}}"/>
          </StackPanel>

        </StackPanel>
      </Border>

      <!-- ── ABOUT SECTION ───────────────────────────────────── -->
      <TextBlock Text="ABOUT"
                 Foreground="#00B4FF" FontSize="11"
                 FontFamily="Cascadia Code" LetterSpacing="2"
                 Margin="0,0,0,12"/>

      <Border Background="#12171F" BorderBrush="#2A3347" BorderThickness="1"
              CornerRadius="8" Padding="16" Margin="0,0,0,24">
        <StackPanel>
          <TextBlock Text="__APP_DISPLAY_NAME__"
                     Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"/>
          <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}"
                     Foreground="#8899AA" FontSize="12" Margin="0,4,0,0"/>
          <TextBlock Text="Built for Commander Maverick"
                     Foreground="#445566" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>

      <!-- Reset to defaults (danger style) -->
      <Button Content="Reset All Settings to Defaults"
              Command="{Binding ResetToDefaultsCommand}"
              HorizontalAlignment="Left"
              Padding="16,10"
              Background="#1A0A0A"
              Foreground="#FF2D55"
              BorderBrush="#FF2D55" BorderThickness="1"
              FontSize="13"
              Cursor="Hand"
              ToolTip="This will reset all settings. Cannot be undone."/>

    </StackPanel>
  </ScrollViewer>
</Page>
