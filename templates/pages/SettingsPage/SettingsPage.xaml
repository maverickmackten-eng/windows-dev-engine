<UserControl x:Class="__APP_NAME__.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundDeepBrush}">
    <!--
        SettingsPage.xaml — Grouped Settings with toggles, slider, textbox, reset
        DataContext: __APP_NAME__.ViewModels.SettingsViewModel
        Bindings: EnableAnimations (bool), StartMinimized (bool), AutoSaveInterval (int),
                  DefaultOutputPath (string), HasPathError (bool), OutputPathError (string),
                  AppVersion (string), Theme (string),
                  ResetToDefaultsCommand (ICommand), SaveCommand (ICommand)
    -->
    <UserControl.Resources>
        <!-- Pill toggle switch style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track" Width="40" Height="22" CornerRadius="11"
                                    Background="{DynamicResource BorderSubtleBrush}">
                                <Border x:Name="Thumb" Width="16" Height="16" CornerRadius="8"
                                        Background="#777777" HorizontalAlignment="Left"
                                        VerticalAlignment="Center" Margin="3,0">
                                    <Border.RenderTransform><TranslateTransform x:Name="ThumbX" X="0"/></Border.RenderTransform>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbX" Storyboard.TargetProperty="X" To="18" Duration="0:0:0.15"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard><Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbX" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15"/>
                                    </Storyboard></BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="Settings" FontFamily="Segoe UI Black" FontSize="28"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,28"/>

            <!-- APPEARANCE section -->
            <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource BackgroundPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel Spacing="20">
                    <!-- Animations toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Animations" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Enable UI animations and transitions" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding EnableAnimations}" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}"/>
                    <!-- Theme picker -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Theme" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Choose app color theme" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding Theme}" VerticalAlignment="Center">
                            <ComboBoxItem Content="Dark Military" Tag="DarkMilitary"/>
                            <ComboBoxItem Content="Cyber Neon" Tag="CyberNeon"/>
                            <ComboBoxItem Content="Gold Command" Tag="GoldCommand"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BEHAVIOR section -->
            <TextBlock Text="BEHAVIOR" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource BackgroundPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel Spacing="20">
                    <!-- Start minimized -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start Minimized" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Launch app to system tray" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding StartMinimized}" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}"/>
                    <!-- Auto-save slider -->
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Auto-Save Interval" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock Text="{Binding AutoSaveInterval}" FontFamily="Cascadia Code, Consolas"
                                           FontSize="14" Foreground="{DynamicResource AccentPrimaryBrush}" FontWeight="Bold"/>
                                <TextBlock Text=" min" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Slider Minimum="1" Maximum="60" Value="{Binding AutoSaveInterval}"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Style="{DynamicResource AccentSliderStyle}"/>
                    </StackPanel>
                    <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}"/>
                    <!-- Output path -->
                    <StackPanel>
                        <TextBlock Text="Default Output Path" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <Border BorderThickness="1" CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPathError}" Value="True">
                                            <Setter Property="BorderBrush" Value="#FF2D55"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox Text="{Binding DefaultOutputPath, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource BackgroundElevatedBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="0" Padding="10,8"
                                     FontFamily="Cascadia Code, Consolas" FontSize="12"/>
                        </Border>
                        <TextBlock Text="{Binding OutputPathError}" Foreground="#FF2D55" FontSize="11" Margin="0,4,0,0"
                                   Visibility="{Binding HasPathError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ABOUT section -->
            <TextBlock Text="ABOUT" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Background="{DynamicResource BackgroundPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="__APP_NAME__" FontFamily="Segoe UI Black" FontSize="18"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Built with Windows Dev Engine" FontSize="11"
                               Foreground="{DynamicResource TextDisabledBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Danger zone -->
            <Border Background="#0FFF2D55" BorderBrush="#33FF2D55" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Reset to Defaults" FontSize="14" FontWeight="SemiBold" Foreground="#FF2D55"/>
                        <TextBlock Text="Restores all settings to factory defaults. Cannot be undone."
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ResetToDefaultsCommand}"
                            Content="Reset" Style="{DynamicResource DangerButtonStyle}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Save button -->
            <Button Command="{Binding SaveCommand}" HorizontalAlignment="Right"
                    Style="{DynamicResource PrimaryButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Save Settings" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
