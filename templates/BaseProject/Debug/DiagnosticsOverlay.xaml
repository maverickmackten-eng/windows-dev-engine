<UserControl x:Class="BaseApp.Debug.DiagnosticsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280">

    <Border Background="#CC0A0D12"
            BorderBrush="#00B4FF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">

        <StackPanel>
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Ellipse Width="8" Height="8" Fill="#00FF94" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock Text="DEBUG OVERLAY"
                           Foreground="#00B4FF"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="10"
                           FontWeight="Bold"
                           LetterSpacing="2"/>
            </StackPanel>

            <Separator Background="#2A3347" Margin="0,0,0,8"/>

            <!-- FPS -->
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FPS" Foreground="#8899AA" FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                <TextBlock x:Name="FpsText" Grid.Column="1"
                           Text="--"
                           Foreground="#00FF94"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11" FontWeight="Bold"/>
            </Grid>

            <!-- Memory -->
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="MEMORY" Foreground="#8899AA" FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                <TextBlock x:Name="MemoryText" Grid.Column="1"
                           Text="-- MB"
                           Foreground="#FFB800"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11" FontWeight="Bold"/>
            </Grid>

            <!-- Uptime -->
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="UPTIME" Foreground="#8899AA" FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                <TextBlock x:Name="UptimeText" Grid.Column="1"
                           Text="00:00:00"
                           Foreground="#FFFFFF"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"/>
            </Grid>

            <!-- Current view -->
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="VIEW" Foreground="#8899AA" FontFamily="Cascadia Code, Consolas" FontSize="11"/>
                <TextBlock x:Name="ViewText" Grid.Column="1"
                           Text="--"
                           Foreground="#00B4FF"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Separator Background="#2A3347" Margin="0,8"/>

            <!-- Last log line -->
            <TextBlock Text="LAST LOG" Foreground="#8899AA"
                       FontFamily="Cascadia Code, Consolas" FontSize="10" Margin="0,0,0,4"/>
            <TextBlock x:Name="LastLogText"
                       Text="--"
                       Foreground="#CCCCCC"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="10"
                       TextWrapping="Wrap"
                       MaxHeight="60"/>

            <Separator Background="#2A3347" Margin="0,8"/>

            <!-- Keyboard shortcuts reminder -->
            <TextBlock Text="Ctrl+Shift+L  Open log file"
                       Foreground="#445566"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="9"/>
            <TextBlock Text="Ctrl+Shift+S  Dump state"
                       Foreground="#445566"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="9"/>
            <TextBlock Text="Ctrl+Shift+R  Restart app"
                       Foreground="#445566"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="9"/>
        </StackPanel>
    </Border>
</UserControl>
