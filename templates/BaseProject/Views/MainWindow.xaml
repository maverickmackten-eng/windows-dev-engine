<Window x:Class="BaseApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:debug="clr-namespace:BaseApp.Debug"
        mc:Ignorable="d"
        Title="BaseApp"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border provides the window shape and shadow -->
    <Border Background="{StaticResource BrushBackgroundDeep}"
            CornerRadius="12"
            BorderBrush="{StaticResource BrushBorderSubtle}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>    <!-- Title bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="24"/>    <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushBackgroundPanel}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App name and current page -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="BASE APP"
                                   Foreground="{StaticResource BrushAccentPrimary}"
                                   FontFamily="{StaticResource FontDisplay}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" / "
                                   Foreground="{StaticResource BrushTextDisabled}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentPage}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="&#x2014;"
                                Style="{StaticResource ButtonGhost}"
                                FontSize="14"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize"/>
                        <Button Content="&#x2610;"
                                Style="{StaticResource ButtonGhost}"
                                FontSize="14"
                                Click="MaximizeButton_Click"
                                ToolTip="Maximize"/>
                        <Button Content="&#x2715;"
                                Style="{StaticResource ButtonGhost}"
                                FontSize="14"
                                Foreground="{StaticResource BrushAccentDanger}"
                                Click="CloseButton_Click"
                                ToolTip="Close"
                                Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT AREA ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>    <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>      <!-- Page content -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        Background="{StaticResource BrushBackgroundPanel}"
                        BorderBrush="{StaticResource BrushBorderSubtle}"
                        BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,16">
                        <!-- Navigation items added here -->
                        <Button Content="Dashboard"
                                Style="{StaticResource ButtonGhost}"
                                HorizontalAlignment="Stretch"
                                Margin="8,2"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Dashboard"/>
                        <Button Content="Settings"
                                Style="{StaticResource ButtonGhost}"
                                HorizontalAlignment="Stretch"
                                Margin="8,2"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="Settings"/>
                    </StackPanel>
                </Border>

                <!-- Page frame -->
                <Frame x:Name="pageFrame"
                       Grid.Column="1"
                       NavigationUIVisibility="Hidden"/>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2"
                    Background="{StaticResource BrushBackgroundPanel}"
                    CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="{StaticResource FontSizeXS}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="v1.0.0"
                               Foreground="{StaticResource BrushTextDisabled}"
                               FontSize="{StaticResource FontSizeXS}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══ DIAGNOSTICS OVERLAY (hidden by default, Ctrl+Shift+D) ═══ -->
            <debug:DiagnosticsOverlay x:Name="diagnosticsOverlay"
                                      Grid.Row="0" Grid.RowSpan="3"
                                      Grid.Column="0" Grid.ColumnSpan="2"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,60,16,0"/>

            <!-- Resize grip -->
            <ResizeGrip Grid.Row="2" HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" Margin="0,0,4,2"/>
        </Grid>
    </Border>
</Window>
