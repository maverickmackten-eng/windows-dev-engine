<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         BACKGROUND COLORS
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="ColorBackgroundDeep">#0A0D12</Color>
    <Color x:Key="ColorBackgroundPanel">#12171F</Color>
    <Color x:Key="ColorBackgroundElevated">#1C2333</Color>
    <Color x:Key="ColorBackgroundHover">#242D3F</Color>

    <SolidColorBrush x:Key="BrushBackgroundDeep" Color="{StaticResource ColorBackgroundDeep}"/>
    <SolidColorBrush x:Key="BrushBackgroundPanel" Color="{StaticResource ColorBackgroundPanel}"/>
    <SolidColorBrush x:Key="BrushBackgroundElevated" Color="{StaticResource ColorBackgroundElevated}"/>
    <SolidColorBrush x:Key="BrushBackgroundHover" Color="{StaticResource ColorBackgroundHover}"/>

    <!-- ═══════════════════════════════════════════════════════════
         BORDER COLORS
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="ColorBorderSubtle">#2A3347</Color>
    <Color x:Key="ColorBorderActive">#3D5A8A</Color>

    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource ColorBorderSubtle}"/>
    <SolidColorBrush x:Key="BrushBorderActive" Color="{StaticResource ColorBorderActive}"/>

    <!-- ═══════════════════════════════════════════════════════════
         ACCENT COLORS
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="ColorAccentPrimary">#00B4FF</Color>
    <Color x:Key="ColorAccentSecondary">#FF6B35</Color>
    <Color x:Key="ColorAccentSuccess">#00FF94</Color>
    <Color x:Key="ColorAccentDanger">#FF2D55</Color>
    <Color x:Key="ColorAccentWarning">#FFB800</Color>
    <Color x:Key="ColorAccentGold">#FFD700</Color>
    <Color x:Key="ColorAccentPurple">#9B59FF</Color>

    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource ColorAccentPrimary}"/>
    <SolidColorBrush x:Key="BrushAccentSecondary" Color="{StaticResource ColorAccentSecondary}"/>
    <SolidColorBrush x:Key="BrushAccentSuccess" Color="{StaticResource ColorAccentSuccess}"/>
    <SolidColorBrush x:Key="BrushAccentDanger" Color="{StaticResource ColorAccentDanger}"/>
    <SolidColorBrush x:Key="BrushAccentWarning" Color="{StaticResource ColorAccentWarning}"/>
    <SolidColorBrush x:Key="BrushAccentGold" Color="{StaticResource ColorAccentGold}"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="{StaticResource ColorAccentPurple}"/>

    <!-- ═══════════════════════════════════════════════════════════
         TEXT COLORS
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondary">#8899AA</Color>
    <Color x:Key="ColorTextDisabled">#445566</Color>
    <Color x:Key="ColorTextAccent">#00B4FF</Color>

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextDisabled" Color="{StaticResource ColorTextDisabled}"/>
    <SolidColorBrush x:Key="BrushTextAccent" Color="{StaticResource ColorTextAccent}"/>

    <!-- ═══════════════════════════════════════════════════════════
         GLOW / EFFECT BRUSHES
    ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="ColorGlowPrimary">#4400B4FF</Color>
    <Color x:Key="ColorGlowDanger">#44FF2D55</Color>
    <Color x:Key="ColorGlowSuccess">#4400FF94</Color>

    <SolidColorBrush x:Key="BrushGlowPrimary" Color="{StaticResource ColorGlowPrimary}"/>
    <SolidColorBrush x:Key="BrushGlowDanger" Color="{StaticResource ColorGlowDanger}"/>
    <SolidColorBrush x:Key="BrushGlowSuccess" Color="{StaticResource ColorGlowSuccess}"/>

    <!-- ═══════════════════════════════════════════════════════════
         GRADIENT BRUSHES
    ═══════════════════════════════════════════════════════════ -->
    <LinearGradientBrush x:Key="BrushHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A0D12" Offset="0"/>
        <GradientStop Color="#12233A" Offset="0.5"/>
        <GradientStop Color="#0A1520" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushAccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00B4FF" Offset="0"/>
        <GradientStop Color="#0070CC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushDangerGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF2D55" Offset="0"/>
        <GradientStop Color="#CC0033" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
