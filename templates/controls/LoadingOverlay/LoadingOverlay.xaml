<UserControl x:Class="__APP_NAME__.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             IsHitTestVisible="True">

  <!--
    LoadingOverlay — Full-area dim + spinner.
    Usage:
      1. Place as the LAST child in your root Grid (draws on top of everything)
      2. Toggle: overlay.Show("Loading data...") / overlay.Hide()
      3. Or bind Visibility to {Binding IsLoading, Converter=...}
  -->

  <!-- Dimmed background -->
  <Grid Background="#CC000000">

    <!-- Spinner + message card -->
    <Border Background="#1C2333"
            BorderBrush="#2A3347"
            BorderThickness="1"
            CornerRadius="12"
            Padding="32,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="220">
      <StackPanel HorizontalAlignment="Center">

        <!-- Spinning ring (RotateTransform animated in code-behind) -->
        <Ellipse x:Name="spinnerRing"
                 Width="48" Height="48"
                 StrokeThickness="3"
                 Stroke="#00B4FF"
                 StrokeDashArray="2 1"
                 HorizontalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <RotateTransform x:Name="spinRotate"/>
          </Ellipse.RenderTransform>
          <Ellipse.Triggers>
            <EventTrigger RoutedEvent="Loaded">
              <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                  <DoubleAnimation Storyboard.TargetName="spinRotate"
                                   Storyboard.TargetProperty="Angle"
                                   From="0" To="360"
                                   Duration="0:0:1"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </Ellipse.Triggers>
        </Ellipse>

        <!-- Loading message -->
        <TextBlock x:Name="txtLoadingMessage"
                   Text="Loading..."
                   Foreground="#FFFFFF"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,16,0,0"/>

        <!-- Optional sub-message -->
        <TextBlock x:Name="txtLoadingDetail"
                   Text=""
                   Foreground="#8899AA"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"
                   Visibility="Collapsed"/>

        <!-- Optional cancel button -->
        <Button x:Name="btnCancel"
                Content="Cancel"
                Visibility="Collapsed"
                Margin="0,16,0,0"
                Padding="24,8"
                Background="Transparent"
                Foreground="#8899AA"
                BorderBrush="#2A3347" BorderThickness="1"
                Click="BtnCancel_Click"
                HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
