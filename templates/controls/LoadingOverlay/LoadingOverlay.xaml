<UserControl x:Class="__APP_NAME__.Views.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             Panel.ZIndex="500">
    <!--
        LoadingOverlay.xaml — Full-window dim + spinner
        =================================================
        USAGE:
          Place as the LAST child in your root Grid (renders on top).
          Bind Visibility to IsLoading via BoolToVisibilityConverter, OR
          call overlay.Show("message") / overlay.Hide() from code-behind.

          <local:LoadingOverlay x:Name="LoadingOverlay"
              Grid.RowSpan="3" Grid.ColumnSpan="2"/>
    -->
    <UserControl.Resources>
        <Storyboard x:Key="SpinForever" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinAngle"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:0.9"/>
        </Storyboard>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <!-- Dim layer -->
    <Grid x:Name="Root" Opacity="0" Background="#CC0A0D12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- Ring spinner using arc geometry -->
            <Grid Width="56" Height="56" HorizontalAlignment="Center">
                <!-- Track ring -->
                <Ellipse Width="52" Height="52" Stroke="#1C2333" StrokeThickness="4"/>
                <!-- Spinning arc -->
                <Path Data="M 28,4 A 24,24 0 0 1 52,28"
                      Stroke="#00B4FF" StrokeThickness="4" StrokeLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="SpinAngle" Angle="0"
                                         CenterX="28" CenterY="28"/>
                    </Path.RenderTransform>
                    <Path.Effect>
                        <DropShadowEffect Color="#00B4FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                    </Path.Effect>
                </Path>
            </Grid>

            <!-- Loading message -->
            <TextBlock x:Name="MessageText"
                       Text="Loading..."
                       FontFamily="Segoe UI" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
