<Window x:Class="__APP_NAME__.Views.Controls.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="420" Height="200"
        ShowInTaskbar="False">
    <!--
        ConfirmDialog.xaml — Modal confirm/cancel dialog
        =================================================
        USAGE:
          var dlg = new ConfirmDialog("Delete file?", "This cannot be undone.");
          dlg.Owner = Application.Current.MainWindow;
          bool confirmed = dlg.ShowDialogResult();
    -->
    <Window.Resources>
        <Storyboard x:Key="ScaleIn">
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleX" From="0.85" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentScale"
                             Storyboard.TargetProperty="ScaleY" From="0.85" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DialogBorder"
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <!-- Darkened overlay (behind dialog) -->
    <Grid Background="#AA000000">
        <Border x:Name="DialogBorder" Opacity="0"
                Background="{DynamicResource BackgroundPanelBrush}"
                BorderBrush="{DynamicResource BorderActiveBrush}"
                BorderThickness="1" CornerRadius="10"
                Width="400" Height="180"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" Opacity="0.6" ShadowDepth="4" Color="#000000"/>
            </Border.Effect>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Text -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               FontFamily="Segoe UI Black" FontSize="16"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="MessageText"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,6,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click"/>
                    <Button x:Name="ConfirmButton"
                            Content="Confirm"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            IsDefault="True"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
