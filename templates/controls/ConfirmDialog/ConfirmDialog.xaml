<Window x:Class="__APP_NAME__.Controls.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="400" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

  <Window.Resources>
    <DropShadowEffect x:Key="DialogShadow"
                      BlurRadius="32" ShadowDepth="6"
                      Color="#000000" Opacity="0.6"/>
  </Window.Resources>

  <Grid>
    <!-- Dim overlay behind the dialog -->
    <Rectangle Fill="#99000000"
               IsHitTestVisible="False"/>

    <!-- Dialog card -->
    <Border Background="#1C2333"
            BorderBrush="#3D5A8A"
            BorderThickness="1"
            CornerRadius="10"
            Padding="28,24"
            Effect="{StaticResource DialogShadow}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="340">

      <Border.RenderTransform>
        <ScaleTransform x:Name="dialogScale" ScaleX="0.85" ScaleY="0.85"
                        CenterX="200" CenterY="100"/>
      </Border.RenderTransform>

      <Border.Triggers>
        <EventTrigger RoutedEvent="Loaded">
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetName="dialogScale"
                               Storyboard.TargetProperty="ScaleX"
                               From="0.85" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <DoubleAnimation Storyboard.TargetName="dialogScale"
                               Storyboard.TargetProperty="ScaleY"
                               From="0.85" To="1.0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                  <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </Border.Triggers>

      <StackPanel>

        <!-- Icon + title -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <TextBlock x:Name="txtIcon"
                     Text="&#xE7BA;"
                     FontFamily="Segoe MDL2 Assets" FontSize="20"
                     Foreground="#FFD700"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"/>
          <TextBlock x:Name="txtTitle"
                     Text="Confirm Action"
                     FontFamily="Segoe UI Black" FontSize="16"
                     Foreground="#FFFFFF"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Message -->
        <TextBlock x:Name="txtMessage"
                   Text="Are you sure you want to proceed?"
                   Foreground="#AABBCC" FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,0,0,24"/>

        <!-- Buttons -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <!-- NO / Cancel -->
          <Button Grid.Column="0"
                  x:Name="btnNo"
                  Content="CANCEL"
                  Height="40"
                  Background="Transparent"
                  Foreground="#8899AA"
                  BorderBrush="#2A3347" BorderThickness="1"
                  FontSize="12" FontWeight="Bold"
                  Click="BtnNo_Click"/>

          <!-- YES / Confirm -->
          <Button Grid.Column="2"
                  x:Name="btnYes"
                  Content="CONFIRM"
                  Height="40"
                  Background="#00B4FF"
                  Foreground="#000000"
                  BorderThickness="0"
                  FontSize="12" FontWeight="Bold"
                  Click="BtnYes_Click"/>
        </Grid>

      </StackPanel>
    </Border>
  </Grid>
</Window>
