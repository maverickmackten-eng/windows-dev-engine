<UserControl x:Class="__APP_NAME__.Views.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320" HorizontalAlignment="Right">
    <!--
        ToastNotification.xaml — Slide-in toast from bottom-right
        ===========================================================
        USAGE: See ToastNotification.xaml.cs for the Show() API.
        Host in a Canvas/Grid overlay at the bottom-right of MainWindow.
        Types: Info, Success, Warning, Error — each has a distinct left-border color.
    -->
    <UserControl.Resources>
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="340" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="SlideOut" Completed="SlideOut_Completed">
            <DoubleAnimation Storyboard.TargetName="RootTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="340" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="Root" Opacity="0"
            Background="{DynamicResource BackgroundPanelBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1" CornerRadius="8"
            Margin="0,0,0,8">
        <Border.RenderTransform><TranslateTransform x:Name="RootTranslate" X="340"/></Border.RenderTransform>
        <Border.Effect><DropShadowEffect BlurRadius="16" Opacity="0.4" ShadowDepth="4" Color="#000000"/></Border.Effect>

        <Grid>
            <!-- Colored left-border accent bar -->
            <Border x:Name="AccentBar" Width="4" HorizontalAlignment="Left"
                    CornerRadius="8,0,0,8" Background="#00B4FF"/>
            <!-- Content -->
            <Grid Margin="16,12,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Icon -->
                <TextBlock x:Name="IconGlyph" Grid.Column="0"
                           FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="#00B4FF" VerticalAlignment="Top"
                           Text="&#xE946;" Margin="0,0,10,0"/>
                <!-- Text -->
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="MessageText"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
                <!-- Close button -->
                <Button Grid.Column="2" x:Name="CloseBtn"
                        Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Top" Padding="4"
                        Click="CloseBtn_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
